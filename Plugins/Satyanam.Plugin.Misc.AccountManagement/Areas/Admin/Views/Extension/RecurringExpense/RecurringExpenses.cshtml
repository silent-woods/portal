@model RecurringExpenseSearchModel

@{
    Layout = "_AdminLayout";
    ViewBag.PageTitle = T("Satyanam.Plugin.Misc.AccountManagement.Admin.RecurringExpense.List").Text;
    NopHtml.SetActiveMenuItemSystemName("Satyanam.Plugin.Misc.AccountManagement.Admin.RecurringExpenses");

    const string hideSearchBlockAttributeName = "RecurringExpenseListPage.HideSearchBlock";
    var hideSearchBlock = await genericAttributeService.GetAttributeAsync<bool>(await workContext.GetCurrentCustomerAsync(), hideSearchBlockAttributeName);
}

<div class="content-header clearfix">
    <h1 class="float-left">
        @T("Satyanam.Plugin.Misc.AccountManagement.Admin.RecurringExpense.List")
    </h1>
    @if (await permissionService.AuthorizeAsync(AccountManagementPermissionProvider.ManageRecurringExpenses, PermissionAction.Add))
    {
        <div class="float-right">
            <a asp-action="RecurringExpenseCreate" asp-controller="RecurringExpense" class="btn btn-primary">
                <i class="fas fa-plus-square"></i>
                @T("Admin.Common.AddNew")
            </a>
        </div>
    }
</div>
<section class="content">
    <div class="container-fluid">
        <div class="form-horizontal">
            <div class="cards-group">
                <div class="card card-default card-search">
                    <div class="card-body">
                        <div class="row search-row @(!hideSearchBlock ? "opened" : "")" data-hideAttribute="@hideSearchBlockAttributeName">
                            <div class="search-text">@T("Admin.Common.Search")</div>
                            <div class="icon-search"><i class="fas fa-search" aria-hidden="true"></i></div>
                            <div class="icon-collapse"><i class="far fa-angle-@(!hideSearchBlock ? "up" : "down")" aria-hidden="true"></i></div>
                        </div>
                        <div class="search-body @(hideSearchBlock ? "closed" : "")">
                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="SearchTitle" />
                                        </div>
                                        <div class="col-md-8">
                                            <input asp-for="SearchTitle" class="form-control" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="SearchCategoryId" />
                                        </div>
                                        <div class="col-md-8">
                                            <nop-select asp-for="SearchCategoryId" asp-items="Model.AvailableCategories" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="SearchFrequencyId" />
                                        </div>
                                        <div class="col-md-8">
                                            <nop-select asp-for="SearchFrequencyId" asp-items="Model.AvailableFrequencies" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="text-center col-12">
                                    <button type="button" id="search-recurring-expenses" class="btn btn-primary btn-search">
                                        <i class="fas fa-search"></i>
                                        @T("Admin.Common.Search")
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card card-default">
                    <div class="card-body">
                        @{
                            var gridModel = new DataTablesModel
                            {
                                Name = "recurring-expenses-grid",
                                UrlRead = new DataUrl("RecurringExpenses", "RecurringExpense", null),
                                UrlDelete = new DataUrl("RecurringExpenseDelete", "RecurringExpense", null),
                                SearchButtonId = "search-recurring-expenses",
                                Length = Model.PageSize,
                                LengthMenu = Model.AvailablePageSizes,
                                Filters = new List<FilterParameter>
                                {
                                    new FilterParameter(nameof(Model.SearchTitle)),
                                    new FilterParameter(nameof(Model.SearchCategoryId)),
                                    new FilterParameter(nameof(Model.SearchFrequencyId))
                                }
                            };
                            gridModel.ColumnCollection.Add(new ColumnProperty(nameof(RecurringExpenseModel.Title))
                            {
                                Title = T("Satyanam.Plugin.Misc.AccountManagement.Admin.RecurringExpense.Fields.Title").Text
                            });
                            gridModel.ColumnCollection.Add(new ColumnProperty(nameof(RecurringExpenseModel.ExpenseCategoryName))
                            {
                                Title = T("Satyanam.Plugin.Misc.AccountManagement.Admin.RecurringExpense.Fields.ExpenseCategory").Text
                            });
                            gridModel.ColumnCollection.Add(new ColumnProperty(nameof(RecurringExpenseModel.Amount))
                            {
                                Title = T("Satyanam.Plugin.Misc.AccountManagement.Admin.RecurringExpense.Fields.Amount").Text,
                                ClassName = NopColumnClassDefaults.CenterAll
                            });
                            gridModel.ColumnCollection.Add(new ColumnProperty(nameof(RecurringExpenseModel.FrequencyName))
                            {
                                Title = T("Satyanam.Plugin.Misc.AccountManagement.Admin.RecurringExpense.Fields.Frequency").Text,
                                ClassName = NopColumnClassDefaults.CenterAll
                            });
                            gridModel.ColumnCollection.Add(new ColumnProperty(nameof(RecurringExpenseModel.NextGenerateStr))
                            {
                                Title = T("Satyanam.Plugin.Misc.AccountManagement.Admin.RecurringExpense.Fields.NextGenerate").Text,
                                ClassName = NopColumnClassDefaults.CenterAll,
                                Width = "140"
                            });
                            gridModel.ColumnCollection.Add(new ColumnProperty(nameof(RecurringExpenseModel.IsActive))
                            {
                                Title = T("Satyanam.Plugin.Misc.AccountManagement.Admin.RecurringExpense.Fields.IsActive").Text,
                                ClassName = NopColumnClassDefaults.CenterAll,
                                Render = new RenderBoolean(),
                                Width = "80"
                            });
                            @if (await permissionService.AuthorizeAsync(AccountManagementPermissionProvider.ManageRecurringExpenses, PermissionAction.Edit))
                            {
                                gridModel.ColumnCollection.Add(new ColumnProperty(nameof(RecurringExpenseModel.Id))
                                {
                                    Title = T("Admin.Common.Edit").Text,
                                    Width = "100",
                                    ClassName = NopColumnClassDefaults.Button,
                                    Render = new RenderButtonEdit(new DataUrl("~/Admin/RecurringExpense/RecurringExpenseEdit/"))
                                });
                            }
                            @if (await permissionService.AuthorizeAsync(AccountManagementPermissionProvider.ManageRecurringExpenses, PermissionAction.Delete))
                            {
                                gridModel.ColumnCollection.Add(new ColumnProperty(nameof(RecurringExpenseModel.Id))
                                {
                                    Title = T("Admin.Common.Delete").Text,
                                    Width = "100",
                                    Render = new RenderButtonRemove(T("Admin.Common.Delete").Text),
                                    ClassName = NopColumnClassDefaults.Button
                                });
                            }
                        }
                        @await Html.PartialAsync("Table", gridModel)
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
