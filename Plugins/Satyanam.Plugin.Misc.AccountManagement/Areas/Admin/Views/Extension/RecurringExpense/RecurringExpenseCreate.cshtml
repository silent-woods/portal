@model RecurringExpenseModel

@{
    Layout = "_AdminLayout";
    ViewBag.PageTitle = T("Satyanam.Plugin.Misc.AccountManagement.Admin.RecurringExpense.Add").Text;
    NopHtml.SetActiveMenuItemSystemName("Satyanam.Plugin.Misc.AccountManagement.Admin.RecurringExpenses");
}

<form asp-controller="RecurringExpense" asp-action="RecurringExpenseCreate" method="post">
    <div class="content-header clearfix">
        <h1 class="float-left">
            @T("Satyanam.Plugin.Misc.AccountManagement.Admin.RecurringExpense.Add")
            <small>
                <i class="fas fa-arrow-circle-left"></i>
                <a asp-action="RecurringExpenses" asp-controller="RecurringExpense">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.RecurringExpense.BackToList")</a>
            </small>
        </h1>
        @if (await permissionService.AuthorizeAsync(AccountManagementPermissionProvider.ManageRecurringExpenses, PermissionAction.Add))
        {
            <div class="float-right">
                <button type="submit" name="save" class="btn btn-primary">
                    <i class="far fa-save"></i>
                    @T("Admin.Common.Save")
                </button>
                <button type="submit" name="save-continue" class="btn btn-primary">
                    <i class="far fa-save"></i>
                    @T("Admin.Common.SaveContinue")
                </button>
            </div>
        }
    </div>
    @await Html.PartialAsync("~/Plugins/Misc.AccountManagement/Areas/Admin/Views/Extension/RecurringExpense/_CreateOrUpdateRecurringExpense.cshtml", Model)
</form>
