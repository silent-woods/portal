@model ExpenseCategorySearchModel

@{
    Layout = "_AdminLayout";
    ViewBag.PageTitle = T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExpenseCategory.List").Text;
    NopHtml.SetActiveMenuItemSystemName("Satyanam.Plugin.Misc.AccountManagement.Admin.ExpenseCategories");

    const string hideSearchBlockAttributeName = "ExpenseCategoryListPage.HideSearchBlock";
    var hideSearchBlock = await genericAttributeService.GetAttributeAsync<bool>(await workContext.GetCurrentCustomerAsync(), hideSearchBlockAttributeName);
}

<div class="content-header clearfix">
    <h1 class="float-left">
        @T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExpenseCategory.List")
    </h1>
    @if (await permissionService.AuthorizeAsync(AccountManagementPermissionProvider.ManageExpenseCategories, PermissionAction.Add))
    {
        <div class="float-right">
            <a asp-action="ExpenseCategoryCreate" asp-controller="ExpenseCategory" class="btn btn-primary">
                <i class="fas fa-plus-square"></i>
                @T("Admin.Common.AddNew")
            </a>
        </div>
    }
</div>
<section class="content">
    <div class="container-fluid">
        <div class="form-horizontal">
            <div class="cards-group">
                <div class="card card-default card-search">
                    <div class="card-body">
                        <div class="row search-row @(!hideSearchBlock ? "opened" : "")" data-hideAttribute="@hideSearchBlockAttributeName">
                            <div class="search-text">@T("Admin.Common.Search")</div>
                            <div class="icon-search"><i class="fas fa-search" aria-hidden="true"></i></div>
                            <div class="icon-collapse"><i class="far fa-angle-@(!hideSearchBlock ? "up" : "down")" aria-hidden="true"></i></div>
                        </div>
                        <div class="search-body @(hideSearchBlock ? "closed" : "")">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="SearchName" />
                                        </div>
                                        <div class="col-md-8">
                                            <nop-editor asp-for="SearchName" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="text-center col-12">
                                    <button type="button" id="search-expense-categories" class="btn btn-primary btn-search">
                                        <i class="fas fa-search"></i>
                                        @T("Admin.Common.Search")
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card card-default">
                    <div class="card-body">
                        @{
                            var gridModel = new DataTablesModel
                            {
                                Name = "expense-categories-grid",
                                UrlRead = new DataUrl("ExpenseCategories", "ExpenseCategory", null),
                                UrlDelete = new DataUrl("ExpenseCategoryDelete", "ExpenseCategory", null),
                                SearchButtonId = "search-expense-categories",
                                Length = Model.PageSize,
                                LengthMenu = Model.AvailablePageSizes,
                                Filters = new List<FilterParameter>
                                {
                                    new FilterParameter(nameof(Model.SearchName))
                                }
                            };
                            gridModel.ColumnCollection.Add(new ColumnProperty(nameof(ExpenseCategoryModel.Name))
                            {
                                Title = T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExpenseCategory.Fields.Name").Text
                            });
                            gridModel.ColumnCollection.Add(new ColumnProperty(nameof(ExpenseCategoryModel.CategoryTypeName))
                            {
                                Title = T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExpenseCategory.Fields.CategoryType").Text
                            });
                            gridModel.ColumnCollection.Add(new ColumnProperty(nameof(ExpenseCategoryModel.IsActive))
                            {
                                Title = T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExpenseCategory.Fields.IsActive").Text,
                                ClassName = NopColumnClassDefaults.CenterAll,
                                Render = new RenderBoolean(),
                                Width = "80"
                            });
                            gridModel.ColumnCollection.Add(new ColumnProperty(nameof(ExpenseCategoryModel.DisplayOrder))
                            {
                                Title = T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExpenseCategory.Fields.DisplayOrder").Text,
                                ClassName = NopColumnClassDefaults.CenterAll,
                                Width = "80"
                            });
                            @if (await permissionService.AuthorizeAsync(AccountManagementPermissionProvider.ManageExpenseCategories, PermissionAction.Edit))
                            {
                                gridModel.ColumnCollection.Add(new ColumnProperty(nameof(ExpenseCategoryModel.Id))
                                {
                                    Title = T("Admin.Common.Edit").Text,
                                    Width = "100",
                                    ClassName = NopColumnClassDefaults.Button,
                                    Render = new RenderButtonEdit(new DataUrl("~/Admin/ExpenseCategory/ExpenseCategoryEdit/"))
                                });
                            }
                            @if (await permissionService.AuthorizeAsync(AccountManagementPermissionProvider.ManageExpenseCategories, PermissionAction.Delete))
                            {
                                gridModel.ColumnCollection.Add(new ColumnProperty(nameof(ExpenseCategoryModel.Id))
                                {
                                    Title = T("Admin.Common.Delete").Text,
                                    Width = "100",
                                    Render = new RenderButtonRemove(T("Admin.Common.Delete").Text),
                                    ClassName = NopColumnClassDefaults.Button
                                });
                            }
                        }
                        @await Html.PartialAsync("Table", gridModel)
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
