<div class="card card-default ops-section-card">
    <div class="card-body">

        <div class="section-header ops-section-header">
            <span class="section-title">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Section.Title")</span>
            <div class="ops-filters-row">
                <select id="ops-employee-filter" class="ops-filter-select">
                    <option value="0">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Filter.AllEmployees")</option>
                </select>
                <select id="ops-project-filter" class="ops-filter-select">
                    <option value="0">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Filter.AllProjects")</option>
                </select>
                <div class="btn-group ops-granularity-toggle" role="group">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-ops-granularity="week">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Granularity.Week")</button>
                    <button type="button" class="btn btn-outline-secondary btn-sm active" data-ops-granularity="month">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Granularity.Month")</button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-ops-granularity="year">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Granularity.Year")</button>
                </div>
            </div>
        </div>

        <div id="ops-preset-bar-week" class="preset-bar" style="display:none;">
            <button class="btn-preset active" data-ops-preset="thisweek">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Filter.CurrentWeek")</button>
            <button class="btn-preset" data-ops-preset="lastweek">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Filter.PastWeek")</button>
        </div>

        <div id="ops-preset-bar-month" class="preset-bar">
            <button class="btn-preset" data-ops-preset="currentmonth">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Filter.CurrentMonth")</button>
            <button class="btn-preset active" data-ops-preset="lastmonth">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Filter.LastMonth")</button>
            <button class="btn-preset" data-ops-preset="last3months">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Filter.Last3Months")</button>
            <button class="btn-preset" data-ops-preset="last6months">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Filter.Last6Months")</button>
            <div class="period-inputs ms-2">
                <select id="ops-month-from">
                    @for (var m = 1; m <= 12; m++) { <option value="@m">@(new DateTime(2000, m, 1).ToString("MMM"))</option> }
                </select>
                <select id="ops-year-from-month">
                    @for (var y = DateTime.Now.Year; y >= DateTime.Now.Year - 5; y--) { <option value="@y">@y</option> }
                </select>
                <span class="ops-period-separator">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Period.To")</span>
                <select id="ops-month-to">
                    @for (var m = 1; m <= 12; m++) { <option value="@m">@(new DateTime(2000, m, 1).ToString("MMM"))</option> }
                </select>
                <select id="ops-year-to-month">
                    @for (var y = DateTime.Now.Year; y >= DateTime.Now.Year - 5; y--) { <option value="@y">@y</option> }
                </select>
            </div>
        </div>

        <div id="ops-preset-bar-year" class="preset-bar" style="display:none;">
            @{ var opsfyM = ViewBag.FyStartMonth != null ? (int)ViewBag.FyStartMonth : 1; }
            <button class="btn-preset active" data-ops-preset="thisyear">@(opsfyM > 1 ? "This FY" : T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Filter.ThisYear").Text)</button>
            <button class="btn-preset" data-ops-preset="lastyear">@(opsfyM > 1 ? "Last FY" : T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Filter.LastYear").Text)</button>
            <div class="period-inputs ms-2">
                <select id="ops-year-from">
                    @for (var y = DateTime.Now.Year; y >= DateTime.Now.Year - 5; y--) { <option value="@y">@y</option> }
                </select>
                <span class="ops-period-separator">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Period.To")</span>
                <select id="ops-year-to">
                    @for (var y = DateTime.Now.Year; y >= DateTime.Now.Year - 5; y--) { <option value="@y">@y</option> }
                </select>
            </div>
        </div>

        <div class="kpi-grid">
            <div class="kpi-card ops-billable" data-ops-card="billable">
                <div class="kpi-card-top">
                    <span class="kpi-label kpi-label-wrap">
                        @T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Card.BillableUtil")
                        <i class="fas fa-info-circle kpi-info-icon" data-toggle="tooltip" data-placement="top" title="@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Card.BillableUtil.Tooltip")"></i>
                    </span>
                    <div class="kpi-icon ops-billable-icon"><i class="fas fa-clock"></i></div>
                </div>
                <div class="kpi-value" id="ops-val-billable">—</div>
                <div><span class="kpi-trend neutral" id="ops-trend-billable">—</span></div>
                <div class="kpi-subtitle" id="ops-sub-billable"></div>
                <div class="kpi-sparkline-wrap"><canvas id="ops-spark-billable"></canvas></div>
                <div class="kpi-loading" id="ops-load-billable"><div class="spinner-sm"></div></div>
            </div>

            <div class="kpi-card ops-dot" data-ops-card="dot">
                <div class="kpi-card-top">
                    <span class="kpi-label kpi-label-wrap">
                        @T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Card.DOT")
                        <i class="fas fa-info-circle kpi-info-icon" data-toggle="tooltip" data-placement="top" title="@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Card.DOT.Tooltip")"></i>
                    </span>
                    <div class="kpi-icon ops-dot-icon"><i class="fas fa-check-circle"></i></div>
                </div>
                <div class="kpi-value" id="ops-val-dot">—</div>
                <div><span class="kpi-trend neutral" id="ops-trend-dot">—</span></div>
                <div class="kpi-subtitle" id="ops-sub-dot"></div>
                <div class="kpi-sparkline-wrap"><canvas id="ops-spark-dot"></canvas></div>
                <div class="kpi-loading" id="ops-load-dot"><div class="spinner-sm"></div></div>
            </div>

            <div class="kpi-card ops-quality" data-ops-card="quality">
                <div class="kpi-card-top">
                    <span class="kpi-label kpi-label-wrap">
                        @T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Card.WorkQuality")
                        <i class="fas fa-info-circle kpi-info-icon" data-toggle="tooltip" data-placement="top" title="@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Card.WorkQuality.Tooltip")"></i>
                    </span>
                    <div class="kpi-icon ops-quality-icon"><i class="fas fa-star"></i></div>
                </div>
                <div class="kpi-value" id="ops-val-quality">—</div>
                <div><span class="kpi-trend neutral" id="ops-trend-quality">—</span></div>
                <div class="kpi-subtitle" id="ops-sub-quality"></div>
                <div class="kpi-sparkline-wrap"><canvas id="ops-spark-quality"></canvas></div>
                <div class="kpi-loading" id="ops-load-quality"><div class="spinner-sm"></div></div>
            </div>

        </div>

        <div class="cashflow-chart-section ops-chart-section">
            <div class="cashflow-chart-header">
                <span class="cashflow-chart-title">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Chart.BillableHours")</span>
            </div>
            <div class="cashflow-chart-wrap">
                <canvas id="ops-billable-hours-chart"></canvas>
            </div>
        </div>

        <div class="cashflow-chart-section ops-chart-section">
            <div class="cashflow-chart-header">
                <span class="cashflow-chart-title">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Chart.ProjectHealth")</span>
                <span class="ops-radar-top-label" id="ops-radar-top-label">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Chart.ProjectHealth.TopLabel")</span>
            </div>
            <div class="ops-radar-wrap">
                <canvas id="ops-project-radar-chart"></canvas>
            </div>
            <div id="ops-radar-legend" class="ops-radar-legend"></div>
        </div>

        <div class="inv-status-section ops-chart-section">
            <div class="cashflow-chart-header ops-task-health-header">
                <span class="cashflow-chart-title">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Chart.TaskHealth")</span>
                <div class="ops-task-health-controls">
                    <span class="ops-click-hint">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.InvoiceStatus.ClickHint")</span>
                    <select id="task-health-period-select" class="ops-filter-select ops-th-period-select">
                        <option value="last3months">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Filter.Last3Months")</option>
                        <option value="last6months" selected>@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Filter.Last6Months")</option>
                        <option value="thisyear">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Filter.ThisYear")</option>
                        <option value="lastyear">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Filter.LastYear")</option>
                        <option value="last2years">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Filter.Last2Years")</option>
                        <option value="alltime">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Filter.AllTime")</option>
                    </select>
                </div>
            </div>
            <div class="inv-status-layout">
                <div class="inv-donut-wrap">
                    <canvas id="ops-task-donut-chart"></canvas>
                    <div class="inv-donut-center">
                        <div class="inv-donut-total-label">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.TaskHealth.TotalLabel")</div>
                        <div class="inv-donut-total-value" id="ops-donut-total">—</div>
                    </div>
                </div>
                <div class="inv-status-grid">
                    <div class="inv-stat-card ops-stat-completed" data-task-status="completed">
                        <div class="inv-stat-label ops-stat-label-completed">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Status.Completed")</div>
                        <div class="inv-stat-count" id="ops-count-completed">—</div>
                        <div class="inv-stat-sub" id="ops-pct-completed"></div>
                    </div>
                    <div class="inv-stat-card ops-stat-inprogress" data-task-status="inprogress">
                        <div class="inv-stat-label ops-stat-label-inprogress">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Status.InProgress")</div>
                        <div class="inv-stat-count" id="ops-count-inprogress">—</div>
                        <div class="inv-stat-sub" id="ops-pct-inprogress"></div>
                    </div>
                    <div class="inv-stat-card ops-stat-notstarted" data-task-status="notstarted">
                        <div class="inv-stat-label ops-stat-label-notstarted">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Status.NotStarted")</div>
                        <div class="inv-stat-count" id="ops-count-notstarted">—</div>
                        <div class="inv-stat-sub" id="ops-pct-notstarted"></div>
                    </div>
                    <div class="inv-stat-card ops-stat-overdue" data-task-status="overdue">
                        <div class="inv-stat-label ops-stat-label-overdue">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Status.Overdue")</div>
                        <div class="inv-stat-count" id="ops-count-overdue">—</div>
                        <div class="inv-stat-sub" id="ops-pct-overdue"></div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<div class="modal fade" id="opsTaskListModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="opsTaskListModalTitle">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Modal.TaskList.TaskTitle")</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body" id="opsTaskListModalBody"></div>
        </div>
    </div>
</div>

<div class="modal fade" id="opsKpiDetailModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="opsKpiDetailModalTitle"></h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body" id="opsKpiDetailModalBody">
                <div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>
            </div>
        </div>
    </div>
</div>

<style>
    /* KPI card accents */
    .kpi-card.ops-billable  { border-left: 5px solid #7c3aed; }
    .kpi-card.ops-dot       { border-left: 5px solid #0284c7; }
    .kpi-card.ops-quality   { border-left: 5px solid #d97706; }
    .kpi-icon.ops-billable-icon { background: rgba(124,58,237,0.10); color: #7c3aed; }
    .kpi-icon.ops-dot-icon      { background: rgba(2,132,199,0.10); color: #0284c7; }
    .kpi-icon.ops-quality-icon  { background: rgba(217,119,6,0.10); color: #d97706; }

    /* Task health stat card accents */
    .inv-stat-card.ops-stat-completed  { border-left: 4px solid #16a34a; }
    .inv-stat-card.ops-stat-inprogress { border-left: 4px solid #2563eb; }
    .inv-stat-card.ops-stat-notstarted { border-left: 4px solid #9ca3af; }
    .inv-stat-card.ops-stat-overdue    { border-left: 4px solid #dc2626; }
    .inv-stat-label.ops-stat-label-completed  { color: #16a34a; }
    .inv-stat-label.ops-stat-label-inprogress { color: #2563eb; }
    .inv-stat-label.ops-stat-label-notstarted { color: #9ca3af; }
    .inv-stat-label.ops-stat-label-overdue    { color: #dc2626; }

    /* Section layout */
    .ops-section-card { margin-top: 0; }
    .ops-section-header { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; margin-bottom: 12px; }
    .ops-filters-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .ops-filter-select { font-size: 12px; padding: 4px 8px; border: 1px solid #d1d5db; border-radius: 6px; background: #fff; color: #374151; }
    .ops-th-period-select { min-width: 130px; }
    .ops-period-separator { font-size: 12px; color: #6b7280; padding: 0 4px; }
    .ops-chart-section { margin-top: 20px; }
    .ops-task-health-header { display: flex; justify-content: space-between; align-items: center; }
    .ops-task-health-controls { display: flex; align-items: center; gap: 10px; }
    .ops-click-hint { font-size: 11px; color: #9ca3af; font-style: italic; }

    /* Detail modal tables */
    .ops-detail-table { font-size: 13px; }
    .ops-thead-row { background: #f9fafb; }
    .ops-thead-row th { font-weight: 600; }
    .ops-th-bar { min-width: 140px; }
    .ops-detail-section-title { font-size: 13px; font-weight: 600; color: #374151; margin: 16px 0 8px; }
    .ops-detail-trend-label { font-size: 11px; color: #6b7280; margin: 8px 0 4px; }
    .ops-detail-chart-canvas { max-height: 200px; margin-bottom: 16px; display: block; }

    /* Billable hours chart canvas */
    #ops-billable-hours-chart { height: 240px; }

    /* Table cell helpers */
    .ops-td-name    { vertical-align: middle; font-weight: 500; }
    .ops-td-billable { vertical-align: middle; font-weight: 600; color: #10b981; }
    .ops-td-muted   { vertical-align: middle; color: #6b7280; }
    .ops-td-neutral { vertical-align: middle; color: #374151; }
    .ops-td-bold    { vertical-align: middle; font-weight: 600; }
    .ops-td-success { vertical-align: middle; color: #16a34a; font-weight: 600; }
    .ops-td-danger  { vertical-align: middle; color: #dc2626; font-weight: 600; }

    /* Task link */
    .ops-task-link { color: #2563eb; text-decoration: none; font-weight: 500; }
    .ops-task-link:hover { text-decoration: underline; }

    /* Radar chart */
    .ops-radar-top-label { font-size: 11px; color: #9ca3af; font-style: italic; }
    .ops-radar-wrap { max-width: 520px; margin: 0 auto; height: 460px; position: relative; }
    .ops-radar-legend { display: flex; flex-wrap: wrap; gap: 8px 16px; justify-content: center; margin-top: 12px; }
    .ops-radar-legend-item { display: flex; align-items: center; gap: 6px; font-size: 12px; color: #374151; font-weight: 500; }
    .ops-radar-legend-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .ops-radar-nodata { font-size: 13px; color: #9ca3af; margin: 16px 0; text-align: center; }

    /* Progress bar */
    .ops-bar-wrap  { display: flex; align-items: center; gap: 6px; }
    .ops-bar-track { flex: 1; background: #f3f4f6; border-radius: 4px; height: 8px; overflow: hidden; }
    .ops-bar-fill  { height: 8px; border-radius: 4px; transition: width .4s; }
    .ops-bar-label { font-size: 12px; font-weight: 600; min-width: 38px; text-align: right; }

    /* Pagination */
    .ops-pagination-footer { display: flex; justify-content: space-between; align-items: center; padding: 6px 2px; margin-top: 4px; }
    .ops-pagination-info   { font-size: 12px; color: #6b7280; }
    .ops-pagination-btns   { display: flex; gap: 4px; }

    /* Mini KPI cards inside detail modals */
    .mini-kpi-row {
        display: flex;
        gap: 12px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }
    .mini-kpi-card {
        flex: 1;
        min-width: 120px;
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 14px 18px;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }
    .mini-kpi-label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #6b7280;
    }
    .mini-kpi-value {
        font-size: 22px;
        font-weight: 700;
        color: #111827;
        line-height: 1.2;
    }
</style>

<script>
(function () {
    var opsSparkCharts = {};
    var opsBillableHoursChart = null;
    var opsTaskDonutChart = null;
    var opsRadarChart = null;
    var opsDetailChart = null;
    var PROJECT_COLORS = ['#7c3aed','#0284c7','#16a34a','#d97706','#dc2626','#0891b2'];
    var opsState = { granularity: 'month', preset: 'lastmonth', projectId: 0, employeeId: 0 };
    var taskHealthPeriod = 'last6months';

    function debounce(fn, ms) {
        var timer;
        return function () { clearTimeout(timer); timer = setTimeout(fn, ms); };
    }
    var debouncedLoadMetrics   = debounce(loadOperationalMetrics, 350);
    var debouncedLoadBreakdown = debounce(loadTaskBreakdown, 350);

    function buildOpsPeriodPayload() {
        var p = { period: opsState.preset };
        if (opsState.granularity === 'month' && !opsState.preset) {
            p.period = null;
            p.monthFrom = parseInt($('#ops-month-from').val());
            p.yearFrom  = parseInt($('#ops-year-from-month').val());
            p.monthTo   = parseInt($('#ops-month-to').val());
            p.yearTo    = parseInt($('#ops-year-to-month').val());
        } else if (opsState.granularity === 'year' && !opsState.preset) {
            p.period = null;
            p.yearFrom = parseInt($('#ops-year-from').val());
            p.yearTo   = parseInt($('#ops-year-to').val());
        }
        if (opsState.projectId > 0)  p.projectId  = opsState.projectId;
        if (opsState.employeeId > 0) p.employeeId = opsState.employeeId;
        p.taskPeriod = taskHealthPeriod;
        return p;
    }

    var currentOpsPeriod = 'last3months';
    var currentOpsProjectId = 0;
    var currentOpsEmployeeId = 0;

    var _ot = {
        trendNA:       '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Trend.NA")',
        trendNewUp:    '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Trend.NewUp")',
        trendNewDown:  '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Trend.NewDown")',
        noData:        '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Chart.NoData")',
        billableHours: '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Chart.BillableHoursLabel")',
        nonBillable:   '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Chart.NonBillableHoursLabel")',
        completed:     '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Status.Completed")',
        inProgress:    '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Status.InProgress")',
        notStarted:    '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Status.NotStarted")',
        overdueStatus: '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Status.Overdue")',
        noTasks:       '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Modal.TaskList.NoTasks")',
        colTask:       '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Modal.TaskList.TaskTitle")',
        colProject:    '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Modal.TaskList.Project")',
        colAssignee:   '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Modal.TaskList.Assignee")',
        colDueDate:    '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Modal.TaskList.DueDate")',
        colStatus:     '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Modal.TaskList.Status")',
        wqTitle:       '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Modal.WorkQuality.Title")',
        wqAvgScore:    '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Modal.WorkQuality.AvgScore")',
        wqTotalBugs:   '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Modal.WorkQuality.TotalBugs")',
        wqEvaluated:   '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Modal.WorkQuality.TasksEvaluated")',
        wqQuality:     '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Operational.Modal.WorkQuality.Columns.QualityScore")',
