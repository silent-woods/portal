    function opsTrendHtml(current, previous) {
        if (previous == null) return '<span class="kpi-trend neutral">' + _ot.trendNA + '</span>';
        if (previous === 0) {
            if (current > 0) return '<span class="kpi-trend up">' + _ot.trendNewUp + '</span>';
            if (current < 0) return '<span class="kpi-trend down">' + _ot.trendNewDown + '</span>';
            return '<span class="kpi-trend neutral">' + _ot.trendNA + '</span>';
        }
        var diff = ((current - previous) / Math.abs(previous)) * 100;
        var up = diff >= 0;
        return '<span class="kpi-trend ' + (up ? 'up' : 'down') + '">' + (up ? '↑' : '↓') + ' ' + Math.abs(diff).toFixed(1) + '%</span>';
    }

    function setOpsLoading(show) {
        ['billable', 'dot', 'quality', 'overdue'].forEach(function (k) {
            var el = document.getElementById('ops-load-' + k);
            if (el) el.style.display = show ? 'flex' : 'none';
        });
    }

    function drawOpsSparkline(id, points, color) {
        if (opsSparkCharts[id]) { opsSparkCharts[id].destroy(); delete opsSparkCharts[id]; }
        var canvas = document.getElementById(id);
        if (!canvas || !points || !points.length) return;
        var validPoints = points.map(function (p) { return p; });
        opsSparkCharts[id] = new Chart(canvas, {
            type: 'line',
            data: { labels: validPoints.map(function (_, i) { return i; }), datasets: [{ data: validPoints, borderColor: color, borderWidth: 1.5, pointRadius: 0, fill: false, tension: 0.3, spanGaps: false }] },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false }, tooltip: { enabled: false } }, scales: { x: { display: false }, y: { display: false } }, animation: false }
        });
    }

    function loadEmployeesList() {
        $.post('@Url.Action("GetEmployeesList", "ExecutiveDashboard")', addAntiForgeryToken({}), function (employees) {
            var $sel = $('#ops-employee-filter');
            $sel.find('option:not(:first)').remove();
            employees.forEach(function (e) {
                $sel.append($('<option>').val(e.id).text(e.name));
            });
        });
    }

    function loadProjectsList() {
        $.post('@Url.Action("GetProjectsList", "ExecutiveDashboard")', addAntiForgeryToken({}), function (projects) {
            var $sel = $('#ops-project-filter');
            $sel.find('option:not(:first)').remove();
            projects.forEach(function (p) {
                $sel.append($('<option>').val(p.id).text(p.title));
            });
        });
    }

    function loadOperationalMetrics() {
        opsState.projectId  = parseInt($('#ops-project-filter').val()) || 0;
        opsState.employeeId = parseInt($('#ops-employee-filter').val()) || 0;
        currentOpsPeriod    = opsState.preset || '';
        currentOpsProjectId  = opsState.projectId;
        currentOpsEmployeeId = opsState.employeeId;
        setOpsLoading(true);
        var payload = buildOpsPeriodPayload();
        $.post('@Url.Action("GetOperationalMetricsData", "ExecutiveDashboard")', addAntiForgeryToken(payload), function (d) {
            setOpsLoading(false);
            $('#ops-val-billable').text(d.billableUtilPct != null ? d.billableUtilPct.toFixed(1) + '%' : '—');
            $('#ops-trend-billable').replaceWith($(opsTrendHtml(d.billableUtilPct, d.prevBillableUtilPct)).attr('id', 'ops-trend-billable'));
            $('#ops-sub-billable').text(d.prevPeriodLabel || '');
            drawOpsSparkline('ops-spark-billable', d.billableUtilPoints, '#7c3aed');

            $('#ops-val-dot').text(d.dotPct != null ? d.dotPct.toFixed(1) + '%' : '—');
            $('#ops-trend-dot').replaceWith($(opsTrendHtml(d.dotPct, d.prevDotPct)).attr('id', 'ops-trend-dot'));
            $('#ops-sub-dot').text(d.prevPeriodLabel || '');
            drawOpsSparkline('ops-spark-dot', d.dotPoints, '#0284c7');

            $('#ops-val-quality').text(d.workQualityScore != null ? d.workQualityScore.toFixed(1) : '—');
            $('#ops-trend-quality').replaceWith($(opsTrendHtml(d.workQualityScore, d.prevWorkQualityScore)).attr('id', 'ops-trend-quality'));
            $('#ops-sub-quality').text(d.workQualityTaskCount + ' tasks · ' + d.workQualityBugCount + ' bugs');
            drawOpsSparkline('ops-spark-quality', d.workQualityPoints, '#d97706');

            drawBillableHoursChart(d.sparklineLabels, d.billableHoursPoints, d.nonBillableHoursPoints);
            drawProjectRadarChart(d.projectRadar);
            if (d.taskHealth) renderTaskHealth(d.taskHealth);
        }).fail(function () { setOpsLoading(false); });
    }

    function drawBillableHoursChart(labels, billable, nonBillable) {
        if (opsBillableHoursChart) { opsBillableHoursChart.destroy(); opsBillableHoursChart = null; }
        var canvas = document.getElementById('ops-billable-hours-chart');
        if (!canvas || !labels || !labels.length) return;
        opsBillableHoursChart = new Chart(canvas, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [
                    { label: _ot.billableHours, data: billable, backgroundColor: '#10b981', borderRadius: 4 },
                    { label: _ot.nonBillable,   data: nonBillable, backgroundColor: '#9ca3af', borderRadius: 4 }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: true, position: 'top' } },
                scales: { x: { stacked: false }, y: { beginAtZero: true } }
            }
        });
    }

    function hexToRgba(hex, alpha) {
        var r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
        return 'rgba(' + r + ',' + g + ',' + b + ',' + alpha + ')';
    }

    function drawProjectRadarChart(projects) {
        if (opsRadarChart) { opsRadarChart.destroy(); opsRadarChart = null; }
        var canvas = document.getElementById('ops-project-radar-chart');
        var legend = document.getElementById('ops-radar-legend');
        var topLabel = document.getElementById('ops-radar-top-label');
        if (legend) legend.innerHTML = '';
        if (!canvas) return;
        if (!projects || !projects.length) {
            if (legend) legend.innerHTML = '<p class="text-muted ops-radar-nodata">' + _ot.radarNoData + '</p>';
            return;
        }

        var datasets;
        if (projects.length > 1) {
            // Employee view — per-project polygons + server-supplied global average line
            if (topLabel) topLabel.textContent = _ot.radarEmpLabel;
            var avgEntry      = projects.filter(function (p) { return !!p.isAverage; })[0];
            var projectsOnly  = projects.filter(function (p) { return !p.isAverage; });
            var avgColor      = '#f59e0b';
            datasets = projectsOnly.map(function (p, i) {
                var color = PROJECT_COLORS[i % PROJECT_COLORS.length];
                if (legend) {
                    legend.innerHTML += '<span class="ops-radar-legend-item">'
                        + '<span class="ops-radar-legend-dot" style="background:' + color + ';"></span>'
                        + p.project + ' <small>(' + p.totalHrs + 'h)</small></span>';
                }
                return {
                    label: p.project,
                    data: [p.billablePct, p.dotPct, p.workQuality, p.overdueHealth],
                    backgroundColor: hexToRgba(color, 0.10),
                    borderColor: color,
                    borderWidth: 2,
                    pointBackgroundColor: color,
                    pointRadius: 4,
                    pointHoverRadius: 6
                };
            });
            if (avgEntry) {
                if (legend) {
                    legend.innerHTML += '<span class="ops-radar-legend-item">'
                        + '<span class="ops-radar-legend-dot" style="background:' + avgColor + '; border: 2px dashed ' + avgColor + ';"></span>'
                        + _ot.radarAvgLabel + '</span>';
                }
                datasets.push({
                    label: _ot.radarAvgLabel,
                    data: [avgEntry.billablePct, avgEntry.dotPct, avgEntry.workQuality, avgEntry.overdueHealth],
                    backgroundColor: hexToRgba(avgColor, 0.08),
                    borderColor: avgColor,
                    borderWidth: 2.5,
                    borderDash: [6, 4],
                    pointBackgroundColor: avgColor,
                    pointRadius: 5,
                    pointHoverRadius: 7
                });
            }
        } else {
            // Single polygon — team avg or specific project
            var p = projects[0];
            var isAvg = !!p.isAverage;
            var color = isAvg ? '#0d9488' : PROJECT_COLORS[0];
            if (topLabel) topLabel.textContent = isAvg ? _ot.radarAvgLabel : p.project;
            if (legend) {
                legend.innerHTML = '<span class="ops-radar-legend-item">'
                    + '<span class="ops-radar-legend-dot" style="background:' + color + ';"></span>'
                    + p.project + ' &nbsp;·&nbsp; ' + p.totalHrs + ' hrs</span>';
            }
            datasets = [{
                label: p.project,
                data: [p.billablePct, p.dotPct, p.workQuality, p.overdueHealth],
                backgroundColor: hexToRgba(color, isAvg ? 0.18 : 0.12),
                borderColor: color,
                borderWidth: 2,
                pointBackgroundColor: color,
                pointRadius: 4,
                pointHoverRadius: 6
            }];
        }

        opsRadarChart = new Chart(canvas, {
            type: 'radar',
            data: {
                labels: [_ot.radarBillable, _ot.radarDot, _ot.radarQuality, _ot.radarCompletion],
                datasets: datasets
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    r: {
                        min: 0, max: 100,
                        ticks: { stepSize: 25, font: { size: 11 }, backdropColor: 'transparent' },
                        pointLabels: { font: { size: 13, weight: '600' } },
                        grid: { color: 'rgba(0,0,0,0.08)' },
                        angleLines: { color: 'rgba(0,0,0,0.08)' }
                    }
                }
            }
        });
    }

    function renderTaskHealth(d) {
        var total = d.total || 1;
        var segments = [
            { key: 'completed',  count: d.completed,  color: '#16a34a' },
            { key: 'inprogress', count: d.inProgress, color: '#2563eb' },
            { key: 'notstarted', count: d.notStarted, color: '#9ca3af' },
            { key: 'overdue',    count: d.overdue,    color: '#dc2626' }
        ];
        segments.forEach(function (s) {
            $('#ops-count-' + s.key).text(s.count);
            $('#ops-pct-' + s.key).text(total > 0 ? ((s.count / d.total) * 100).toFixed(1) + '%' : '0%');
        });
        $('#ops-donut-total').text(d.total);
        drawTaskDonut(segments);
    }

    function loadTaskBreakdown() {
        var payload = { taskPeriod: taskHealthPeriod };
        if (currentOpsProjectId > 0) payload.projectId = currentOpsProjectId;
        if (currentOpsEmployeeId > 0) payload.employeeId = currentOpsEmployeeId;
        $.post('@Url.Action("GetTaskStatusBreakdown", "ExecutiveDashboard")', addAntiForgeryToken(payload), function (d) {
            renderTaskHealth(d);
        });
    }

    function drawTaskDonut(segments) {
        if (opsTaskDonutChart) { opsTaskDonutChart.destroy(); opsTaskDonutChart = null; }
        var canvas = document.getElementById('ops-task-donut-chart');
        if (!canvas) return;
        opsTaskDonutChart = new Chart(canvas, {
            type: 'doughnut',
            data: {
                labels: [_ot.completed, _ot.inProgress, _ot.notStarted, _ot.overdueStatus],
                datasets: [{ data: [segments[0].count, segments[1].count, segments[2].count, segments[3].count], backgroundColor: segments.map(function (s) { return s.color; }), borderWidth: 2 }]
            },
            options: { responsive: true, cutout: '68%', plugins: { legend: { display: false }, tooltip: { enabled: true } } }
        });
    }

    function buildTaskTable(tasks) {
        var headers = '<th>' + _ot.colTask + '</th><th>' + _ot.colProject + '</th><th>' + _ot.colAssignee + '</th>'
            + '<th>' + _ot.colDueDate + '</th><th>' + _ot.colStatus + '</th>';
        return buildPagedTable(tasks, headers, function (t) {
            var rowClass = t.isOverdue ? ' class="table-danger"' : '';
            return '<tr' + rowClass + '><td>' + taskLink(t.id, t.title) + '</td><td>' + (t.projectName || '—') + '</td>'
                + '<td>' + (t.assignee || '—') + '</td><td>' + (t.dueDate || '—') + '</td><td>' + (t.statusName || '—') + '</td></tr>';
        });
    }

    function loadTaskStatusPage(status, page) {
        var payload = { status: status, page: page, pageSize: 15, taskPeriod: taskHealthPeriod };
        if (currentOpsProjectId > 0) payload.projectId = currentOpsProjectId;
        if (currentOpsEmployeeId > 0) payload.employeeId = currentOpsEmployeeId;
        $('#opsTaskListModalBody').html('<div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>');
        $.post('@Url.Action("GetTaskStatusList", "ExecutiveDashboard")', addAntiForgeryToken(payload), function (d) {
            var headers = '<th>' + _ot.colTask + '</th><th>' + _ot.colProject + '</th><th>' + _ot.colAssignee + '</th><th>' + _ot.colDueDate + '</th><th>' + _ot.colStatus + '</th>';
            var rows = '';
            if (d.tasks && d.tasks.length) {
                d.tasks.forEach(function (t) {
                    var rowClass = t.isOverdue ? ' class="table-danger"' : '';
                    rows += '<tr' + rowClass + '><td>' + taskLink(t.id, t.title) + '</td><td>' + (t.projectName || '—') + '</td><td>' + (t.assignee || '—') + '</td><td>' + (t.dueDate || '—') + '</td><td>' + (t.statusName || '—') + '</td></tr>';
                });
            }
            var tableHtml = d.tasks && d.tasks.length
                ? '<div class="table-responsive"><table class="table table-sm table-hover ops-detail-table"><thead><tr class="ops-thead-row">' + headers + '</tr></thead><tbody>' + rows + '</tbody></table></div>'
                : '<p class="text-muted p-3">' + _ot.noTasks + '</p>';

            var s = d.page * d.pageSize + 1, e = Math.min((d.page + 1) * d.pageSize, d.total);
            var info = '<span class="ops-pagination-info">' + _ot.paginationShowing.replace('{0}', s).replace('{1}', e).replace('{2}', d.total) + '</span>';
            var pagination = '';
            if (d.totalPages > 1) {
                pagination = '<div class="ops-pagination-btns">'
                    + '<button class="btn btn-sm btn-outline-secondary" onclick="loadTaskStatusPage(\'' + status + '\',' + (d.page - 1) + ')"' + (d.page === 0 ? ' disabled' : '') + '>‹ Prev</button>'
                    + '<button class="btn btn-sm btn-outline-secondary" onclick="loadTaskStatusPage(\'' + status + '\',' + (d.page + 1) + ')"' + (d.page >= d.totalPages - 1 ? ' disabled' : '') + '>Next ›</button>'
                    + '</div>';
            }
            var footer = '<div class="ops-pagination-footer">' + info + pagination + '</div>';
            $('#opsTaskListModalBody').html(tableHtml + (d.total > 0 ? footer : ''));
        });
    }

    $(document).on('click', '[data-task-status]', function () {
        var status = $(this).data('task-status');
        var titles = { completed: _ot.completed, inprogress: _ot.inProgress, notstarted: _ot.notStarted, overdue: _ot.overdueStatus };
        $('#opsTaskListModalTitle').text(titles[status] || status);
        $('#opsTaskListModal').modal('show');
        loadTaskStatusPage(status, 0);
    });

    $(document).on('click', '[data-ops-card]', function () {
        var card = $(this).data('ops-card');
        var actions = {
            billable: '@Url.Action("GetBillableUtilDetail", "ExecutiveDashboard")',
            dot:      '@Url.Action("GetDotDetail", "ExecutiveDashboard")',
            quality:  '@Url.Action("GetWorkQualityDetail", "ExecutiveDashboard")',
            overdue:  null
        };
        if (card === 'overdue') {
            $('#opsTaskListModalTitle').text(_ot.overdueStatus);
            $('#opsTaskListModal').modal('show');
            loadTaskStatusPage('overdue', 0);
            return;
        }
        var url = actions[card];
        if (!url) return;
        $('#opsKpiDetailModalBody').html('<div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>');
        if (opsDetailChart) { opsDetailChart.destroy(); opsDetailChart = null; }
        $('#opsKpiDetailModal').modal('show');
        var detailPayload = buildOpsPeriodPayload();
        $.post(url, addAntiForgeryToken(detailPayload), function (d) {
            if (card === 'billable') renderBillableDetail(d);
            else if (card === 'dot') renderDotDetail(d);
            else if (card === 'quality') renderQualityDetail(d);
        });
    });

    var _pagedTables = {};

    function buildPagedTable(tasks, headerHtml, rowFn, pageSize) {
        pageSize = pageSize || 15;
        if (!tasks || !tasks.length) return '<p class="text-muted p-3">' + _ot.noTasks + '</p>';
        var tid = 'pt-' + Math.random().toString(36).substr(2, 8);
        _pagedTables[tid] = { tasks: tasks, rowFn: rowFn, pageSize: pageSize, page: 0 };
        var totalPages = Math.ceil(tasks.length / pageSize);
        var html = '<div id="' + tid + '">'
            + '<div class="table-responsive"><table class="table table-sm table-hover ops-detail-table">'
            + '<thead><tr class="ops-thead-row">' + headerHtml + '</tr></thead>'
            + '<tbody id="' + tid + '-body">' + _ptRows(tid, 0) + '</tbody>'
            + '</table></div>'
            + '<div class="ops-pagination-footer">'
            + '<span class="ops-pagination-info" id="' + tid + '-info">' + _ptInfo(tid) + '</span>';
        if (totalPages > 1) {
            html += '<div class="ops-pagination-btns">'
                + '<button class="btn btn-sm btn-outline-secondary pt-prev" data-tid="' + tid + '" disabled>‹ Prev</button>'
                + '<button class="btn btn-sm btn-outline-secondary pt-next" data-tid="' + tid + '"' + (totalPages <= 1 ? ' disabled' : '') + '>Next ›</button>'
                + '</div>';
        }
        html += '</div></div>';
        return html;
    }

    function _ptRows(tid, page) {
        var d = _pagedTables[tid]; if (!d) return '';
        var s = page * d.pageSize, e = Math.min(s + d.pageSize, d.tasks.length), rows = '';
        for (var i = s; i < e; i++) rows += d.rowFn(d.tasks[i]);
        return rows;
    }

    function _ptInfo(tid) {
        var d = _pagedTables[tid]; if (!d) return '';
        var s = d.page * d.pageSize + 1, e = Math.min(s + d.pageSize - 1, d.tasks.length);
        return _ot.paginationShowing.replace('{0}', s).replace('{1}', e).replace('{2}', d.tasks.length);
    }

    $(document).on('click', '.pt-prev, .pt-next', function () {
        var tid = $(this).data('tid'), d = _pagedTables[tid]; if (!d) return;
        var total = Math.ceil(d.tasks.length / d.pageSize);
        d.page = $(this).hasClass('pt-next') ? d.page + 1 : d.page - 1;
        d.page = Math.max(0, Math.min(d.page, total - 1));
        $('#' + tid + '-body').html(_ptRows(tid, d.page));
        $('#' + tid + '-info').text(_ptInfo(tid));
        $('#' + tid).find('.pt-prev').prop('disabled', d.page === 0);
        $('#' + tid).find('.pt-next').prop('disabled', d.page >= total - 1);
    });

    function taskLink(id, title) {
        if (!id) return title || '—';
        return '<a href="/ProjectTask/Edit?id=' + id + '" target="_blank" class="ops-task-link">' + (title || '—') + '</a>';
    }

    function miniKpi(label, value, color) {
        var style = color ? ' style="border-top:3px solid ' + color + ';"' : '';
        return '<div class="mini-kpi-card"' + style + '>'
            + '<div class="mini-kpi-label">' + label + '</div>'
            + '<div class="mini-kpi-value">' + value + '</div>'
            + '</div>';
    }

    function renderBillableDetail(d) {
        $('#opsKpiDetailModalTitle').text(_ot.billTitle);
        var overallUtil = d.totalHrs > 0 ? ((d.billableHrs / d.totalHrs) * 100).toFixed(1) + '%' : '—';
        var html = '<div class="mini-kpi-row">'
            + miniKpi(_ot.billTotal, d.totalHrs + ' hrs', '#6b7280')
            + miniKpi(_ot.billBillable, d.billableHrs + ' hrs', '#10b981')
            + miniKpi(_ot.billUtil, overallUtil, '#7c3aed')
            + '</div>'
            + '<p class="ops-detail-trend-label">' + _ot.billTrendLbl + '</p>'
            + '<canvas id="ops-detail-chart" class="ops-detail-chart-canvas"></canvas>';
        if (d.projectUtil && d.projectUtil.length) {
            html += '<h6 class="ops-detail-section-title">' + _ot.billProjectWise + '</h6>'
                + '<div class="table-responsive"><table class="table table-sm table-hover ops-detail-table">'
                + '<thead><tr class="ops-thead-row">'
                + '<th>' + _ot.colProjectHdr + '</th>'
                + '<th class="text-right">' + _ot.billBillable + '</th>'
                + '<th class="text-right">' + _ot.billNonBill + '</th>'
                + '<th class="text-right">' + _ot.colTotalHrs + '</th>'
                + '<th class="ops-th-bar">' + _ot.colUtilPct + '</th>'
                + '</tr></thead><tbody>';
            d.projectUtil.forEach(function (p) {
                html += '<tr>'
                    + '<td class="ops-td-name">' + p.project + '</td>'
                    + '<td class="text-right ops-td-billable">' + p.billableHrs + '</td>'
                    + '<td class="text-right ops-td-muted">' + p.nonBillableHrs + '</td>'
                    + '<td class="text-right ops-td-neutral">' + p.totalHrs + '</td>'
                    + '<td>' + dotBar(p.utilPct) + '</td>'
                    + '</tr>';
            });
            html += '</tbody></table></div>';
        }

        if (d.topEmployees && d.topEmployees.length) {
            html += '<h6 class="ops-detail-section-title">' + _ot.billEmpWise + '</h6>'
                + '<div class="table-responsive"><table class="table table-sm table-hover ops-detail-table">'
                + '<thead><tr class="ops-thead-row">'
                + '<th>' + _ot.colEmployee + '</th>'
                + '<th class="text-right">' + _ot.billBillable + '</th>'
                + '<th class="text-right">' + _ot.billNonBill + '</th>'
                + '<th class="ops-th-bar">' + _ot.colUtilPct + '</th>'
                + '</tr></thead><tbody>';
            d.topEmployees.forEach(function (e) {
                html += '<tr>'
                    + '<td>' + e.employee + '</td>'
                    + '<td class="text-right ops-td-billable">' + e.billableHrs + '</td>'
                    + '<td class="text-right ops-td-muted">' + e.nonBillableHrs + '</td>'
                    + '<td>' + dotBar(e.utilPct) + '</td>'
                    + '</tr>';
            });
            html += '</tbody></table></div>';
        }
        $('#opsKpiDetailModalBody').html(html);
        if (d.chartData && d.chartData.length) {
            var utilPoints = d.chartData.map(function (x) {
                var tot = x.billable + x.nonBillable;
                return tot > 0 ? parseFloat(((x.billable / tot) * 100).toFixed(1)) : 0;
            });
            opsDetailChart = new Chart(document.getElementById('ops-detail-chart'), {
                type: 'line',
                data: {
                    labels: d.chartData.map(function (x) { return x.label; }),
                    datasets: [{
                        label: _ot.billUtil,
                        data: utilPoints,
                        borderColor: '#7c3aed',
                        backgroundColor: 'rgba(124,58,237,0.08)',
                        fill: true,
                        tension: 0.3,
                        pointRadius: 5,
                        pointBackgroundColor: '#7c3aed'
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true, max: 100, ticks: { callback: function (v) { return v + '%'; } } } }
                }
            });
        }
    }

    function dotBar(pct) {
        var color = pct >= 80 ? '#16a34a' : pct >= 50 ? '#d97706' : '#dc2626';
        return '<div class="ops-bar-wrap">'
            + '<div class="ops-bar-track">'
            + '<div class="ops-bar-fill" style="width:' + pct + '%;background:' + color + ';"></div></div>'
            + '<span class="ops-bar-label" style="color:' + color + ';">' + pct.toFixed(1) + '%</span>'
            + '</div>';
    }

    function renderDotDetail(d) {
        $('#opsKpiDetailModalTitle').text(_ot.dotTitle);
        var html = '<div class="mini-kpi-row">'
            + miniKpi(_ot.dotOnTime, d.onTime, '#16a34a')
            + miniKpi(_ot.dotLate, d.late, '#dc2626')
            + miniKpi(_ot.dotPct, (d.dotPct || 0).toFixed(1) + '%', '#0284c7')
            + '</div><canvas id="ops-detail-chart" class="ops-detail-chart-canvas"></canvas>';
        if (d.employeeDot && d.employeeDot.length) {
            html += '<h6 class="ops-detail-section-title mt-3">' + _ot.dotEmpWise + '</h6>'
                + '<div class="table-responsive"><table class="table table-sm table-hover ops-detail-table">'
                + '<thead><tr class="ops-thead-row">'
                + '<th>' + _ot.colEmployee + '</th>'
                + '<th class="text-center">' + _ot.colOnTime + '</th>'
                + '<th class="text-center">' + _ot.colLate + '</th>'
                + '<th class="text-center">' + _ot.colTotal + '</th>'
                + '<th class="ops-th-bar">' + _ot.dotPct + '</th>'
                + '</tr></thead><tbody>';
            d.employeeDot.forEach(function (e) {
                html += '<tr>'
                    + '<td>' + e.employee + '</td>'
                    + '<td class="text-center ops-td-success">' + e.onTime + '</td>'
                    + '<td class="text-center ops-td-danger">' + e.late + '</td>'
                    + '<td class="text-center ops-td-muted">' + e.total + '</td>'
                    + '<td>' + dotBar(e.dotPct) + '</td>'
                    + '</tr>';
            });
            html += '</tbody></table></div>';
        }
        if (d.projectDot && d.projectDot.length) {
            html += '<h6 class="ops-detail-section-title mt-3">' + _ot.dotProjWise + '</h6>'
                + '<div class="table-responsive"><table class="table table-sm table-hover ops-detail-table">'
                + '<thead><tr class="ops-thead-row">'
                + '<th>' + _ot.colProjectHdr + '</th>'
                + '<th class="text-center">' + _ot.colOnTime + '</th>'
                + '<th class="text-center">' + _ot.colLate + '</th>'
                + '<th class="text-center">' + _ot.colTotal + '</th>'
                + '<th class="ops-th-bar">' + _ot.dotPct + '</th>'
                + '</tr></thead><tbody>';
            d.projectDot.forEach(function (p) {
                html += '<tr>'
                    + '<td>' + (p.project || '—') + '</td>'
                    + '<td class="text-center ops-td-success">' + p.onTime + '</td>'
                    + '<td class="text-center ops-td-danger">' + p.late + '</td>'
                    + '<td class="text-center ops-td-muted">' + p.total + '</td>'
                    + '<td>' + dotBar(p.dotPct) + '</td>'
                    + '</tr>';
            });
            html += '</tbody></table></div>';
        }
        $('#opsKpiDetailModalBody').html(html);
        if (d.chartData && d.chartData.length) {
            opsDetailChart = new Chart(document.getElementById('ops-detail-chart'), {
                type: 'line',
                data: { labels: d.chartData.map(function (x) { return x.label; }), datasets: [{ label: _ot.dotPct, data: d.chartData.map(function (x) { return x.dotPct; }), borderColor: '#0284c7', backgroundColor: 'rgba(2,132,199,0.1)', fill: true, tension: 0.3, pointRadius: 4 }] },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, max: 100 } } }
            });
        }
    }

    function renderQualityDetail(d) {
        $('#opsKpiDetailModalTitle').text(_ot.wqTitle);
        var html = '<div class="mini-kpi-row">'
            + miniKpi(_ot.wqAvgScore, d.avgScore != null ? d.avgScore.toFixed(1) : '—', '#d97706')
            + miniKpi(_ot.wqTotalBugs, d.totalBugs, '#dc2626')
            + miniKpi(_ot.wqEvaluated, d.tasksEvaluated, '#6b7280')
            + '</div><canvas id="ops-detail-chart" class="ops-detail-chart-canvas"></canvas>';
        if (d.employeeQuality && d.employeeQuality.length) {
            html += '<h6 class="ops-detail-section-title mt-3">' + _ot.wqEmpWise + '</h6>'
                + '<div class="table-responsive"><table class="table table-sm table-hover ops-detail-table">'
                + '<thead><tr class="ops-thead-row">'
                + '<th>' + _ot.colEmployee + '</th>'
                + '<th class="text-center">' + _ot.colAvgScore + '</th>'
                + '<th class="text-center">' + _ot.wqBugCount + '</th>'
                + '<th class="text-center">' + _ot.colTasks + '</th>'
                + '<th class="ops-th-bar">' + _ot.colQualityPct + '</th>'
                + '</tr></thead><tbody>';
            d.employeeQuality.forEach(function (e) {
                html += '<tr>'
                    + '<td>' + e.employee + '</td>'
                    + '<td class="text-center ops-td-bold">' + (e.avgScore != null ? e.avgScore.toFixed(1) : '—') + '</td>'
                    + '<td class="text-center ops-td-danger">' + e.bugCount + '</td>'
                    + '<td class="text-center ops-td-muted">' + e.taskCount + '</td>'
                    + '<td>' + dotBar(e.avgScore || 0) + '</td>'
                    + '</tr>';
            });
            html += '</tbody></table></div>';
        }
        if (d.projectQuality && d.projectQuality.length) {
            html += '<h6 class="ops-detail-section-title mt-3">' + _ot.wqProjWise + '</h6>'
                + '<div class="table-responsive"><table class="table table-sm table-hover ops-detail-table">'
                + '<thead><tr class="ops-thead-row">'
                + '<th>' + _ot.colProjectHdr + '</th>'
                + '<th class="text-center">' + _ot.colAvgScore + '</th>'
                + '<th class="text-center">' + _ot.wqBugCount + '</th>'
                + '<th class="text-center">' + _ot.colTasks + '</th>'
                + '<th class="ops-th-bar">' + _ot.colQualityPct + '</th>'
                + '</tr></thead><tbody>';
            d.projectQuality.forEach(function (p) {
                html += '<tr>'
                    + '<td>' + (p.project || '—') + '</td>'
                    + '<td class="text-center ops-td-bold">' + (p.avgScore != null ? p.avgScore.toFixed(1) : '—') + '</td>'
                    + '<td class="text-center ops-td-danger">' + p.bugCount + '</td>'
                    + '<td class="text-center ops-td-muted">' + p.taskCount + '</td>'
                    + '<td>' + dotBar(p.avgScore || 0) + '</td>'
                    + '</tr>';
            });
            html += '</tbody></table></div>';
        }

        if (d.belowAvgTasks && d.belowAvgTasks.length) {
            html += '<h6 class="ops-detail-section-title mt-3">' + _ot.wqBelow + ' (' + d.belowAvgTasks.length + ')</h6>';
            html += buildPagedTable(d.belowAvgTasks,
                '<th>' + _ot.colTask + '</th><th>' + _ot.colProject + '</th><th>' + _ot.colAssignee + '</th><th>' + _ot.wqQuality + '</th><th>' + _ot.wqBugCount + '</th>',
                function (t) {
                    var rowClass = t.qualityScore < 50 ? ' class="table-danger"' : '';
                    return '<tr' + rowClass + '><td>' + taskLink(t.id, t.title) + '</td><td>' + (t.projectName || '—') + '</td><td>' + (t.assignee || '—') + '</td><td>' + t.qualityScore + '</td><td>' + t.bugCount + '</td></tr>';
                });
        }
        $('#opsKpiDetailModalBody').html(html);
        if (d.chartData && d.chartData.length) {
            opsDetailChart = new Chart(document.getElementById('ops-detail-chart'), {
                type: 'line',
                data: { labels: d.chartData.map(function (x) { return x.label; }), datasets: [{ label: _ot.wqAvgScore, data: d.chartData.map(function (x) { return x.avgQuality; }), borderColor: '#d97706', backgroundColor: 'rgba(217,119,6,0.1)', fill: true, tension: 0.3, pointRadius: 4, spanGaps: false }] },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: false, min: 0, max: 100 } } }
            });
        }
    }

    $('#opsKpiDetailModal').on('hidden.bs.modal', function () {
        if (opsDetailChart) { opsDetailChart.destroy(); opsDetailChart = null; }
    });

    $('.ops-granularity-toggle .btn').on('click', function () {
        $('.ops-granularity-toggle .btn').removeClass('active');
        $(this).addClass('active');
        opsState.granularity = $(this).data('ops-granularity');
        $('#ops-preset-bar-week').toggle(opsState.granularity === 'week');
        $('#ops-preset-bar-month').toggle(opsState.granularity === 'month');
        $('#ops-preset-bar-year').toggle(opsState.granularity === 'year');
        var barId = { week: '#ops-preset-bar-week', month: '#ops-preset-bar-month', year: '#ops-preset-bar-year' }[opsState.granularity];
        var $firstPreset = $(barId).find('.btn-preset').first();
        $('.btn-preset').removeClass('active');
        $firstPreset.addClass('active');
        opsState.preset = $firstPreset.data('ops-preset') || null;
        loadOperationalMetrics();
    });

    $(document).on('click', '.btn-preset[data-ops-preset]', function () {
        var $bar = $(this).closest('.preset-bar');
        $bar.find('.btn-preset').removeClass('active');
        $(this).addClass('active');
        opsState.preset = $(this).data('ops-preset') || null;
        debouncedLoadMetrics();
    });

    $('#ops-month-from, #ops-year-from-month, #ops-month-to, #ops-year-to-month').on('change', function () {
        $('#ops-preset-bar-month .btn-preset').removeClass('active');
        opsState.preset = null;
        debouncedLoadMetrics();
    });
    $('#ops-year-from, #ops-year-to').on('change', function () {
        $('#ops-preset-bar-year .btn-preset').removeClass('active');
        opsState.preset = null;
        debouncedLoadMetrics();
    });

    $('#task-health-period-select').on('change', function () {
        taskHealthPeriod = $(this).val();
        debouncedLoadBreakdown();
    });

    $('#ops-employee-filter, #ops-project-filter').on('change', debouncedLoadMetrics);

    window.loadTaskStatusPage = loadTaskStatusPage;

    function _opsInitLoad() {
        loadEmployeesList();
        loadProjectsList();
        var now = new Date();
        var fromM = now.getMonth() - 2;
        var fromY = now.getFullYear();
        if (fromM < 0) { fromM += 12; fromY--; }
        $('#ops-month-from').val(fromM + 1);
        $('#ops-year-from-month').val(fromY);
        $('#ops-month-to').val(now.getMonth() + 1);
        $('#ops-year-to-month').val(now.getFullYear());
        $('#ops-year-from').val(now.getFullYear());
        $('#ops-year-to').val(now.getFullYear());
        // Re-assert default preset after dropdown init (select .val() can fire change handlers)
        opsState.preset = 'lastmonth';
        $('.btn-preset').removeClass('active');
        $('[data-ops-preset="lastmonth"]').addClass('active');
        loadOperationalMetrics();
        $('[data-toggle="tooltip"]').tooltip();
    }

    $(document).ready(function () {
        if ($('#exec-tab-operational').is(':visible')) {
            _opsInitLoad();
        } else {
            $(document).one('exec:load:operational', _opsInitLoad);
        }
    });
}());
</script>
