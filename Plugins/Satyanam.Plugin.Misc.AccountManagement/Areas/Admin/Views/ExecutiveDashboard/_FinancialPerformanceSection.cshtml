                        labels: d.chartData.map(function (x) { return x.label; }),
                        datasets: [
                            { label: _t.revenue, data: d.chartData.map(function (x) { return x.revenue; }), backgroundColor: '#bfdbfe', borderColor: '#2563eb', borderWidth: 1 },
                            { label: _t.expense, data: d.chartData.map(function (x) { return x.expense; }), backgroundColor: '#fecaca', borderColor: '#dc2626', borderWidth: 1 }
                        ]
                    },
                    options: { responsive: true, plugins: { legend: { position: 'top' } }, scales: { y: { ticks: { callback: function (v) { return '₹' + v.toLocaleString('en-IN'); } } } } }
                });
            }
            return;
        }
        else if (cardType === 'cashflow') {
            html += '<div class="modal-kpi-mini">';
            html += '<div class="modal-kpi-mini-card"><div class="modal-kpi-mini-label">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Modal.CashFlow.TotalCashIn")</div><div class="modal-kpi-mini-value" style="color:#16a34a">' + fmt(d.cashIn) + '</div></div>';
            html += '<div class="modal-kpi-mini-card"><div class="modal-kpi-mini-label">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Modal.CashFlow.TotalCashOut")</div><div class="modal-kpi-mini-value" style="color:#dc2626">' + fmt(d.cashOut) + '</div></div>';
            html += '<div class="modal-kpi-mini-card"><div class="modal-kpi-mini-label">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Modal.CashFlow.NetPosition")</div><div class="modal-kpi-mini-value" style="color:' + (d.netPosition >= 0 ? '#16a34a' : '#dc2626') + '">' + fmt(d.netPosition) + '</div></div>';
            html += '</div>';
            html += '<table class="table table-sm cashflow-table"><thead><tr><th>@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Modal.CashFlow.Columns.Category")</th><th>@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Modal.CashFlow.Columns.Type")</th><th class="text-right">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Modal.CashFlow.Columns.Amount")</th></tr></thead><tbody>';
            html += '<tr><td>@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Modal.CashFlow.ClientInvoices")</td><td><span class="badge-inflow">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Modal.CashFlow.Inflow")</span></td><td class="text-right text-success font-weight-bold">+' + fmt(d.cashIn) + '</td></tr>';
            if (d.expenseRows && d.expenseRows.length) {
                $.each(d.expenseRows, function (_, row) {
                    if (!row) return true;
                    html += '<tr><td>' + row.category + '</td><td><span class="badge-outflow">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Modal.CashFlow.Outflow")</span></td><td class="text-right text-danger">-' + fmt(row.amount) + '</td></tr>';
                });
            }
            html += '<tr class="net-position-row"><td colspan="2"><strong>@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Modal.CashFlow.NetPosition")</strong></td><td class="text-right" style="color:' + (d.netPosition >= 0 ? '#16a34a' : '#dc2626') + '"><strong>' + (d.netPosition >= 0 ? '+' : '') + fmt(d.netPosition) + '</strong></td></tr>';
            html += '</tbody></table>';
        }
        $('#kpiDetailModalBody').html(html);
    }
    $('#inv-period-filter').on('change', loadInvoiceStatusSummary);
    $('[data-toggle="tooltip"]').tooltip({ trigger: 'hover', html: false });
    applyPreset('lastmonth');
    loadInvoiceStatusSummary();
    loadProjList();

    function loadProjList() {
        $.post('@Url.Action("GetProjectsList", "ExecutiveDashboard")', addAntiForgeryToken({}), function (projects) {
            if (!Array.isArray(projects)) return;
            var $sel = $('#fin-proj-filter');
            $sel.find('option:not(:first)').remove();
            projects.forEach(function (p) { $sel.append($('<option>').val(p.id).text(p.title)); });
        });
    }

    $('#fin-proj-filter').on('change', function () {
        finProjFilter = parseInt($(this).val()) || 0;
        loadAll();
        loadInvoiceStatusSummary();
    });

    $(document).on('exec:show:financial', function () {
        var barId = state.granularity === 4 ? '#preset-bar-year' : '#preset-bar-month';
        $(barId + ' .btn-preset').removeClass('active');
        if (state.currentPreset) $(barId + ' [data-preset="' + state.currentPreset + '"]').addClass('active');
    });
}());
</script>
<link rel="stylesheet" href="~/Plugins/Misc.AccountManagement/Content/financial-performance.css" />
