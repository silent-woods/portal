    function drawInvoiceDonut(paid, pending, overdue, draft) {
        paid = paid || 0; pending = pending || 0; overdue = overdue || 0; draft = draft || 0;
        var canvas = document.getElementById('inv-donut-chart');
        if (!canvas) return;
        if (invDonutChart) { invDonutChart.destroy(); invDonutChart = null; }

        var total = paid + pending + overdue + draft;
        var allZero = total === 0;
        var totalFmt = allZero ? '—'
            : total >= 10000000 ? '₹' + (total / 10000000).toFixed(1) + 'Cr'
            : total >= 100000  ? '₹' + (total / 100000).toFixed(1) + 'L'
            : total >= 1000    ? '₹' + (total / 1000).toFixed(0) + 'K'
            : '₹' + total.toFixed(0);
        $('#inv-donut-total').text(totalFmt);

        invDonutChart = new Chart(canvas, {
            type: 'doughnut',
            data: {
                labels: [_t.paid, _t.pending, _t.overdue, _t.draft],
                datasets: [{
                    data: allZero ? [1, 0, 0, 0] : [paid, pending, overdue, draft],
                    backgroundColor: allZero
                        ? ['#e5e7eb', '#e5e7eb', '#e5e7eb', '#e5e7eb']
                        : ['#16a34a', '#2563eb', '#dc2626', '#d1d5db'],
                    borderWidth: 2,
                    borderColor: '#fff',
                    hoverOffset: 6
                }]
            },
            options: {
                cutout: '68%',
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: function (ctx) {
                                if (allZero) return ' ' + _t.noData;
                                var val = ctx.raw;
                                var pct = total > 0 ? ' (' + ((val / total) * 100).toFixed(1) + '%)' : '';
                                return ' ' + ctx.label + ': ₹' + parseFloat(val).toLocaleString('en-IN', { minimumFractionDigits: 0, maximumFractionDigits: 0 }) + pct;
                            }
                        }
                    }
                }
            }
        });
    }
    function buildInvoiceRequestData() {
        var months = parseInt($('#inv-period-filter').val());
        var today = new Date();
        var toMonth = today.getMonth() + 1;
        var toYear = today.getFullYear();
        var from = addMonths(toMonth, toYear, -(months - 1));
        var data = {
            granularityId: 3,
            monthFrom: from.month, yearFrom: from.year,
            monthTo: toMonth, yearTo: toYear,
            projectId: finProjFilter
        };
        addAntiForgeryToken(data);
        return data;
    }
