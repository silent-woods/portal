    $('.granularity-toggle .btn').on('click', function () {
        $('.granularity-toggle .btn').removeClass('active');
        $(this).addClass('active');
        state.granularity = parseInt($(this).data('granularity'));
        $('#preset-bar-month').toggle(state.granularity === 3);
        $('#preset-bar-year').toggle(state.granularity === 4);
        if (state.granularity === 3) applyPreset('lastmonth');
        else applyPreset('thisyear');
    });

    function applyPreset(preset) {
        var today = new Date();
        state.currentPreset = preset;

        $('.btn-preset').removeClass('active');
        $('[data-preset="' + preset + '"]').addClass('active');

        switch (preset) {
            case 'thismonth':
                var tm = addMonths(today.getMonth() + 1, today.getFullYear(), 0);
                state.monthFrom = tm.month; state.yearFrom = tm.year;
                state.monthTo = tm.month;   state.yearTo = tm.year;
                syncMonthSelectors(); break;
            case 'lastmonth':
                var lm = addMonths(today.getMonth() + 1, today.getFullYear(), -1);
                state.monthFrom = lm.month; state.yearFrom = lm.year;
                state.monthTo = lm.month;   state.yearTo = lm.year;
                syncMonthSelectors(); break;
            case 'last3months':
                var l3to = addMonths(today.getMonth() + 1, today.getFullYear(), -1);
                var l3from = addMonths(l3to.month, l3to.year, -2);
                state.monthFrom = l3from.month; state.yearFrom = l3from.year;
                state.monthTo = l3to.month;     state.yearTo = l3to.year;
                syncMonthSelectors(); break;
            case 'last6months':
                var l6to = addMonths(today.getMonth() + 1, today.getFullYear(), -1);
                var l6from = addMonths(l6to.month, l6to.year, -5);
                state.monthFrom = l6from.month; state.yearFrom = l6from.year;
                state.monthTo = l6to.month;     state.yearTo = l6to.year;
                syncMonthSelectors(); break;
            case 'thisyear':
                var fyThis = (today.getMonth() + 1 >= fyStartMonth) ? today.getFullYear() : today.getFullYear() - 1;
                state.yearFrom = fyThis; state.yearTo = fyThis;
                $('#yearFromSelector').val(state.yearFrom); $('#yearToSelector').val(state.yearTo); break;
            case 'lastyear':
                var fyLast = ((today.getMonth() + 1 >= fyStartMonth) ? today.getFullYear() : today.getFullYear() - 1) - 1;
                state.yearFrom = fyLast; state.yearTo = fyLast;
                $('#yearFromSelector').val(state.yearFrom); $('#yearToSelector').val(state.yearTo); break;
        }
        loadAll();
    }

    function syncMonthSelectors() {
        $('#monthFromSelector').val(state.monthFrom); $('#yearFromMonthSelector').val(state.yearFrom);
        $('#monthToSelector').val(state.monthTo);     $('#yearToMonthSelector').val(state.yearTo);
    }

    $('.btn-preset').on('click', function () { applyPreset($(this).data('preset')); });

    $('#monthFromSelector, #yearFromMonthSelector, #monthToSelector, #yearToMonthSelector').on('change', function () {
        state.monthFrom = parseInt($('#monthFromSelector').val());
        state.yearFrom  = parseInt($('#yearFromMonthSelector').val());
        state.monthTo   = parseInt($('#monthToSelector').val());
        state.yearTo    = parseInt($('#yearToMonthSelector').val());
        $('.btn-preset').removeClass('active');
        loadAll();
    });

    $('#yearFromSelector, #yearToSelector').on('change', function () {
