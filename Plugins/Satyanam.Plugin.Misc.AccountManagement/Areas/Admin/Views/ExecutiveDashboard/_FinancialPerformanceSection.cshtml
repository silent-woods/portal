@using Satyanam.Plugin.Misc.AccountManagement.Services
<div class="exec-dashboard content-header">
    <div class="container-fluid">

        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Title")</h1>
            </div>
        </div>

        <div class="card card-default">
            <div class="card-body">

                <div class="section-header">
                    <span class="section-title">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.FinancialPerformance.Title")</span>
                    <div class="fin-header-controls">
                        <select id="fin-proj-filter" class="ops-filter-select">
                            <option value="0">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Financial.ProjectFilter.AllProjects")</option>
                        </select>
                        <div class="btn-group granularity-toggle" role="group">
                            <button type="button" class="btn btn-outline-secondary btn-sm active" data-granularity="3">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Granularity.Month")</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" data-granularity="4">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Granularity.Year")</button>
                        </div>
                    </div>
                </div>

<div id="preset-bar-month" class="preset-bar">
                    <button class="btn-preset active" data-preset="lastmonth">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Preset.LastMonth")</button>
                    <button class="btn-preset" data-preset="thismonth">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Preset.ThisMonth")</button>
                    <button class="btn-preset" data-preset="last3months">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Preset.Last3Months")</button>
                    <button class="btn-preset" data-preset="last6months">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Preset.Last6Months")</button>
                    <div class="period-inputs ms-2">
                        <select id="monthFromSelector">
                            @for (var m = 1; m <= 12; m++) { <option value="@m">@(new DateTime(2000, m, 1).ToString("MMM"))</option> }
                        </select>
                        <select id="yearFromMonthSelector">
                            @for (var y = DateTime.Now.Year; y >= DateTime.Now.Year - 5; y--) { <option value="@y">@y</option> }
                        </select>
                        <span style="font-size:12px;color:#6b7280;padding:0 4px;">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Period.To")</span>
                        <select id="monthToSelector">
                            @for (var m = 1; m <= 12; m++) { <option value="@m">@(new DateTime(2000, m, 1).ToString("MMM"))</option> }
                        </select>
                        <select id="yearToMonthSelector">
                            @for (var y = DateTime.Now.Year; y >= DateTime.Now.Year - 5; y--) { <option value="@y">@y</option> }
                        </select>
                    </div>
                </div>

                <div id="preset-bar-year" class="preset-bar" style="display:none;">
                    <button class="btn-preset" data-preset="thisyear">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Preset.ThisYear")</button>
                    <button class="btn-preset" data-preset="lastyear">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Preset.LastYear")</button>
                    <div class="period-inputs ms-2">
                        <select id="yearFromSelector">
                            @for (var y = DateTime.Now.Year; y >= DateTime.Now.Year - 5; y--)
                            {
                                <option value="@y">@y</option>
                            }
                        </select>
                        <span style="font-size:12px;color:#6b7280;padding:0 4px;">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Period.To")</span>
                        <select id="yearToSelector">
                            @for (var y = DateTime.Now.Year; y >= DateTime.Now.Year - 5; y--)
                            {
                                <option value="@y">@y</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="kpi-grid">
                    <div class="kpi-card revenue" data-card="revenue">
                        <div class="kpi-card-top">
                            <span class="kpi-label kpi-label-wrap">
                                @T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.KPI.TotalRevenue")
                                <i class="fas fa-info-circle kpi-info-icon" data-toggle="tooltip" data-placement="top" title="@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.KPI.Tooltip.TotalRevenue")"></i>
                            </span>
                            <div class="kpi-icon"><i class="fas fa-rupee-sign"></i></div>
                        </div>
                        <div class="kpi-value" id="val-revenue">—</div>
                        <div><span class="kpi-trend neutral" id="trend-revenue">—</span></div>
                        <div class="kpi-subtitle" id="sub-revenue"></div>
                        <div class="kpi-sparkline-wrap"><canvas id="spark-revenue"></canvas></div>
                        <div class="kpi-loading" id="load-revenue"><div class="spinner-sm"></div></div>
                    </div>

                    <div class="kpi-card gross" data-card="gross">
                        <div class="kpi-card-top">
                            <span class="kpi-label kpi-label-wrap">
                                @T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.KPI.GrossProfitPercent")
                                <i class="fas fa-info-circle kpi-info-icon" data-toggle="tooltip" data-placement="top" title="@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.KPI.Tooltip.GrossProfit")"></i>
                            </span>
                            <div class="kpi-icon"><i class="fas fa-chart-bar"></i></div>
                        </div>
                        <div class="kpi-value" id="val-gross">—</div>
                        <div><span class="kpi-trend neutral" id="trend-gross">—</span></div>
                        <div class="kpi-subtitle" id="sub-gross"></div>
                        <div class="kpi-sparkline-wrap"><canvas id="spark-gross"></canvas></div>
                        <div class="kpi-loading" id="load-gross"><div class="spinner-sm"></div></div>
                    </div>

                    <div class="kpi-card net" data-card="net">
                        <div class="kpi-card-top">
                            <span class="kpi-label kpi-label-wrap">
                                @T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.KPI.NetProfitPercent")
                                <i class="fas fa-info-circle kpi-info-icon" data-toggle="tooltip" data-placement="top" title="@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.KPI.Tooltip.NetProfit")"></i>
                            </span>
                            <div class="kpi-icon"><i class="fas fa-percentage"></i></div>
                        </div>
                        <div class="kpi-value" id="val-net">—</div>
                        <div><span class="kpi-trend neutral" id="trend-net">—</span></div>
                        <div class="kpi-subtitle" id="sub-net"></div>
                        <div class="kpi-sparkline-wrap"><canvas id="spark-net"></canvas></div>
                        <div class="kpi-loading" id="load-net"><div class="spinner-sm"></div></div>
                    </div>

                    <div class="kpi-card cashflow" data-card="cashflow">
                        <div class="kpi-card-top">
                            <span class="kpi-label kpi-label-wrap">
                                @T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.KPI.NetCashFlow")
                                <i class="fas fa-info-circle kpi-info-icon" data-toggle="tooltip" data-placement="top" title="@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.KPI.Tooltip.NetCashFlow")"></i>
                            </span>
                            <div class="kpi-icon"><i class="fas fa-exchange-alt"></i></div>
                        </div>
                        <div class="kpi-value" id="val-cashflow">—</div>
                        <div><span class="kpi-trend neutral" id="trend-cashflow">—</span></div>
                        <div class="kpi-subtitle" id="sub-cashflow"></div>
                        <div class="kpi-sparkline-wrap"><canvas id="spark-cashflow"></canvas></div>
                        <div class="kpi-loading" id="load-cashflow"><div class="spinner-sm"></div></div>
                    </div>
                </div>

                <div class="cashflow-chart-section">
                    <div class="cashflow-chart-header">
                        <span class="cashflow-chart-title">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Chart.CashFlowOverview")</span>
                        <span id="cashflow-chart-note" style="font-size:11px;color:#9ca3af;">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Chart.CashFlowNote")</span>
                    </div>
                    <div class="cashflow-chart-wrap">
                        <canvas id="cashflow-overview-chart"></canvas>
                    </div>
                </div>

                <div class="rev-cost-chart-section">
                    <div class="cashflow-chart-header">
                        <span class="cashflow-chart-title">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Chart.RevenueVsDirectCost")</span>
                        <span id="revcost-chart-note" style="font-size:11px;color:#9ca3af;">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Chart.RevCostNote")</span>
                    </div>
                    <div class="rev-cost-chart-wrap">
                        <canvas id="rev-cost-chart"></canvas>
                    </div>
                </div>

                <div class="inv-status-section">
                    <div class="cashflow-chart-header">
                        <span class="cashflow-chart-title">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.InvoiceStatus.Title")</span>
                        <div style="display:flex;align-items:center;gap:10px;">
                            <span style="font-size:11px;color:#9ca3af;">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.InvoiceStatus.ClickHint")</span>
                            <select id="inv-period-filter" style="font-size:12px;padding:4px 10px;border:1px solid #d1d5db;border-radius:6px;background:#fff;color:#374151;cursor:pointer;">
                                <option value="3">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.InvoiceStatus.Filter.Last3Months")</option>
                                <option value="6" selected>@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.InvoiceStatus.Filter.Last6Months")</option>
                                <option value="12">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.InvoiceStatus.Filter.Last1Year")</option>
                            </select>
                        </div>
                    </div>
                    <div class="inv-status-layout">
                        <div class="inv-donut-wrap">
                            <canvas id="inv-donut-chart"></canvas>
                            <div class="inv-donut-center">
                                <div class="inv-donut-total-label">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.InvoiceStatus.Total")</div>
                                <div class="inv-donut-total-value" id="inv-donut-total">—</div>
                            </div>
                        </div>
                        <div class="inv-status-grid">
                            <div class="inv-stat-card paid" data-inv-status="Paid">
                                <div class="inv-stat-label">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.InvoiceStatus.Paid")</div>
                                <div class="inv-stat-count" id="inv-count-paid">—</div>
                                <div class="inv-stat-sub">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.InvoiceStatus.InvoicesCount")</div>
                                <div class="inv-stat-amount" id="inv-amount-paid">—</div>
                            </div>
                            <div class="inv-stat-card pending" data-inv-status="Pending">
                                <div class="inv-stat-label">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.InvoiceStatus.Pending")</div>
                                <div class="inv-stat-count" id="inv-count-pending">—</div>
                                <div class="inv-stat-sub">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.InvoiceStatus.InvoicesCount")</div>
                                <div class="inv-stat-amount" id="inv-amount-pending">—</div>
                            </div>
                            <div class="inv-stat-card overdue" data-inv-status="Overdue">
                                <div class="inv-stat-label">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.InvoiceStatus.Overdue")</div>
                                <div class="inv-stat-count" id="inv-count-overdue">—</div>
                                <div class="inv-stat-sub">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.InvoiceStatus.PastDueDate")</div>
                                <div class="inv-stat-amount" id="inv-amount-overdue">—</div>
                            </div>
                            <div class="inv-stat-card draft" data-inv-status="Draft">
                                <div class="inv-stat-label">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.InvoiceStatus.Draft")</div>
                                <div class="inv-stat-count" id="inv-count-draft">—</div>
                                <div class="inv-stat-sub">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.InvoiceStatus.NotSent")</div>
                                <div class="inv-stat-amount" id="inv-amount-draft">—</div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="invoiceListModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="invoiceListModalTitle">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Modal.InvoiceList.Title")</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body" id="invoiceListModalBody">
                <div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="kpiDetailModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="kpiDetailModalTitle"></h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body" id="kpiDetailModalBody">
                <div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>
            </div>
        </div>
    </div>
</div>


<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function () {
    var sparkCharts = {};
    var cashflowOverviewChart = null;
    var revCostChart = null;
    var invDonutChart = null;
    var invoiceEditBaseUrl = '@Url.Action("InvoiceEdit", "AccountManagement")';

    var now = new Date();
    var fyStartMonth = @(ViewBag.FyStartMonth ?? 4);
    var _t = {
        trendNewUp:     '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Trend.NewUp")',
        trendNewDown:   '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Trend.NewDown")',
        trendNA:        '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Trend.NA")',
        cashIn:         '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Chart.CashIn")',
        cashOut:        '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Chart.CashOut")',
        revenue:        '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Chart.Revenue")',
        directCost:     '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Chart.DirectCost")',
        netProfit:      '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Chart.NetProfit")',
        expense:        '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Chart.Expense")',
        salaryCost:     '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Chart.SalaryCost")',
        noData:         '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Chart.NoData")',
        noRevenue:      '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.KPI.NoRevenue")',
        cashFlowNote:   '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Chart.CashFlowNote")',
        revCostNote:    '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Chart.RevCostNote")',
        paid:           '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.InvoiceStatus.Paid")',
        pending:        '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.InvoiceStatus.Pending")',
        overdue:        '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.InvoiceStatus.Overdue")',
        draft:          '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.InvoiceStatus.Draft")',
        failedToLoad:   '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Modal.InvoiceList.FailedToLoad")',
        invNumber:      '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Modal.InvoiceList.Invoice")',
        invTitle:       '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Modal.InvoiceList.ItemTitle")',
        invDate:        '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Modal.InvoiceList.InvoiceDate")',
        invDueDate:     '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Modal.InvoiceList.DueDate")',
        colAmount:      '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Modal.Columns.Amount")',
        daysOverdue:    '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Modal.InvoiceList.DaysOverdue")',
        noInvoices:     '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Modal.InvoiceList.NoInvoices")',
        howCalculated:  '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Modal.GrossProfit.HowCalculated")',
        formulaRev:     '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Modal.GrossProfit.FormulaRevenue")',
        formulaSalTxn:  '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Modal.GrossProfit.FormulaSalaryTxn")',
        formulaGP:      '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Modal.GrossProfit.FormulaResult")',
        gpSalaryCost:   '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Modal.GrossProfit.SalaryCost")',
        npRevenue:      '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Modal.NetProfit.Revenue")',
        npTotalExpense: '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Modal.NetProfit.TotalExpense")',
        subCashIn:      '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.KPI.SubCashIn")',
        subCashOut:     '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.KPI.SubCashOut")',
        subSalaries:    '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.KPI.SubSalaries")',
        subRev:         '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.KPI.SubRev")'
    };
    var currentFYStartYear = (now.getMonth() + 1 >= fyStartMonth) ? now.getFullYear() : now.getFullYear() - 1;

    var lastMonth = now.getMonth() === 0 ? 12 : now.getMonth();
    var lastMonthYear = now.getMonth() === 0 ? now.getFullYear() - 1 : now.getFullYear();
    var state = {
        granularity: 3,
        monthFrom: lastMonth, yearFrom: lastMonthYear,
        monthTo: lastMonth, yearTo: lastMonthYear,
        yearFrom: currentFYStartYear, yearTo: currentFYStartYear
    };

    function addMonths(month, year, n) {
        var d = new Date(year, month - 1 + n, 1);
        return { month: d.getMonth() + 1, year: d.getFullYear() };
    }

    $('#monthFromSelector').val(state.monthFrom); $('#yearFromMonthSelector').val(state.yearFrom);
    $('#monthToSelector').val(state.monthTo);     $('#yearToMonthSelector').val(state.yearTo);
    $('#yearFromSelector').val(state.yearFrom);   $('#yearToSelector').val(state.yearTo);
    function fyLabel(year) {
        if (fyStartMonth === 1) return year.toString();
        var endYr = (year + 1) % 100;
        return 'FY ' + year + '-' + (endYr < 10 ? '0' + endYr : endYr);
    }
    if (fyStartMonth !== 1) {
        $('#yearFromSelector option, #yearToSelector option').each(function () {
            $(this).text(fyLabel(parseInt($(this).val())));
        });
    }

    function fmt(n) {
        if (n == null || n === '') return '—';
        return '₹' + parseFloat(n).toLocaleString('en-IN', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    }
    function fmtPct(n) {
        if (n == null) return '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.KPI.NoData")';
        return parseFloat(n).toFixed(1) + '%';
    }
    function setTrend(id, current, previous, isAmount) {
        var $el = $('#' + id);
        if (!$el.length) return;
        var $new = $(trendHtml(current, previous, isAmount));
        $el.attr('class', $new.attr('class')).html($new.html());
    }
    function trendHtml(current, previous, isAmount) {
        if (previous == null || previous === 0) {
            if (current != null && current > 0) return '<span class="kpi-trend up">' + _t.trendNewUp + '</span>';
            if (current != null && current < 0) return '<span class="kpi-trend down">' + _t.trendNewDown + '</span>';
            return '<span class="kpi-trend neutral">' + _t.trendNA + '</span>';
        }
        var diff = ((current - previous) / Math.abs(previous)) * 100;
        var up = diff >= 0;
        var icon = up ? '↑' : '↓';
        var cls = up ? 'up' : 'down';
        return '<span class="kpi-trend ' + cls + '">' + icon + ' ' + Math.abs(diff).toFixed(1) + '%</span>';
    }
    function trendPctHtml(current, previous) {
        if (previous == null || previous < -0.5) return '<span class="kpi-trend neutral">— N/A</span>';
        var diff = current - previous;
        var up = diff >= 0;
        var icon = up ? '↑' : '↓';
        var cls = up ? 'up' : 'down';
        return '<span class="kpi-trend ' + cls + '">' + icon + ' ' + Math.abs(diff).toFixed(1) + 'pp</span>';
    }

    function showLoaders() {
        ['revenue', 'gross', 'net', 'cashflow'].forEach(function (k) { $('#load-' + k).show(); });
    }
    function hideLoaders() {
        ['revenue', 'gross', 'net', 'cashflow'].forEach(function (k) { $('#load-' + k).hide(); });
    }

    var sparkCfg = {
        type: 'line',
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false }, tooltip: { enabled: false } },
            scales: { x: { display: false }, y: { display: false } },
            elements: { point: { radius: 0 }, line: { borderWidth: 2, tension: 0.4 } },
            animation: false
        }
    };

    function drawSparkline(id, points, color) {
        var canvas = document.getElementById(id);
        if (!canvas) return;
        if (sparkCharts[id]) { sparkCharts[id].destroy(); }
        var cfg = JSON.parse(JSON.stringify(sparkCfg));
        cfg.data = {
            labels: points.map(function (_, i) { return i; }),
            datasets: [{ data: points, borderColor: color, backgroundColor: color + '22', fill: true }]
        };
        sparkCharts[id] = new Chart(canvas, cfg);
    }

    function drawCashFlowChart(labels, cashIn, cashOut) {
        var canvas = document.getElementById('cashflow-overview-chart');
        if (!canvas) return;
        if (cashflowOverviewChart) { cashflowOverviewChart.destroy(); cashflowOverviewChart = null; }
        cashflowOverviewChart = new Chart(canvas, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [
                    {
                        label: _t.cashIn,
                        data: cashIn,
                        borderColor: '#10b981',
                        backgroundColor: 'rgba(16,185,129,0.08)',
                        fill: true,
                        tension: 0.4,
                        borderWidth: 2.5,
                        pointRadius: 4,
                        pointBackgroundColor: '#10b981'
                    },
                    {
                        label: _t.cashOut,
