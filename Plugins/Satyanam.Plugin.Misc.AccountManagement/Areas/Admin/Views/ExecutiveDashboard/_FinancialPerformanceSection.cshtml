    function updateCards(d) {
        if (!d || typeof d !== 'object') return;
        $('#val-revenue').text(fmt(d.revenue));
        setTrend('trend-revenue', d.revenue, d.prevRevenue, true);
        $('#sub-revenue').text('vs ' + fmt(d.prevRevenue) + ' ' + (d.prevPeriodLabel || ''));
        var gVal = d.grossPct == null ? '—' : parseFloat(d.grossPct).toFixed(1) + '%';
        $('#val-gross').text(gVal);
        setTrend('trend-gross', d.grossPct != null ? parseFloat(d.grossPct) : null, d.prevGrossPct != null ? parseFloat(d.prevGrossPct) : null, false);
        $('#sub-gross').text(d.grossPct == null ? _t.noRevenue : _t.subRev + ' ' + fmt(d.revenue) + ' · ' + _t.subSalaries + ' ' + fmt(d.directCost));
        var nVal = d.netPct == null ? '—' : parseFloat(d.netPct).toFixed(1) + '%';
        var netColor = d.netPct == null ? '#9ca3af' : (d.netPct >= 0 ? '#111827' : '#dc2626');
        $('#val-net').text(nVal).css('color', netColor);
        setTrend('trend-net', d.netPct != null ? parseFloat(d.netPct) : null, d.prevNetPct != null ? parseFloat(d.prevNetPct) : null, false);
        $('#sub-net').text(d.netPct == null ? _t.noRevenue : 'After overheads ' + fmt(d.totalExpense));
        var cfPositive = d.netCashFlow >= 0;
        $('#val-cashflow').text(fmt(d.netCashFlow)).css('color', cfPositive ? '#111827' : '#dc2626');
        setTrend('trend-cashflow', d.netCashFlow, d.prevNetCashFlow, true);
        $('#sub-cashflow').text(_t.subCashIn + ' ' + fmt(d.cashIn || d.revenue) + ' · ' + _t.subCashOut + ' ' + fmt(d.totalExpense));

        drawSparkline('spark-revenue', d.revenuePoints || [], '#0d9488');
        drawSparkline('spark-gross', d.revenuePoints || [], '#16a34a');
        drawSparkline('spark-net', (d.netProfitPoints || d.cashFlowPoints || []), '#d97706');
        drawSparkline('spark-cashflow', d.cashFlowPoints || [], '#2563eb');

        var chartNote = d.chartNote || '';
        $('#cashflow-chart-note').text(chartNote ? _t.cashIn + ' vs ' + _t.cashOut + ' · ' + chartNote : _t.cashFlowNote);
        $('#revcost-chart-note').text(chartNote ? _t.revenue + ' · ' + _t.salaryCost + ' · ' + _t.netProfit + ' · ' + chartNote : _t.revCostNote);

        drawCashFlowChart(d.sparklineLabels || [], d.cashInPoints || [], d.cashOutPoints || []);

        var netProfitPoints = (d.cashInPoints || []).map(function (r, i) { return r - (d.cashOutPoints || [])[i]; });
        drawRevCostChart(d.sparklineLabels || [], d.cashInPoints || [], d.directCostPoints || [], netProfitPoints);
    }

    function buildRequestData() {
        var data = { granularityId: state.granularity, projectId: finProjFilter };
        if (state.granularity === 3) {
            data.monthFrom = state.monthFrom; data.yearFrom = state.yearFrom;
            data.monthTo = state.monthTo;     data.yearTo = state.yearTo;
        } else if (state.granularity === 4) {
            data.yearFrom = state.yearFrom;
            data.yearTo = state.yearTo;
        }
        addAntiForgeryToken(data);
        return data;
    }

