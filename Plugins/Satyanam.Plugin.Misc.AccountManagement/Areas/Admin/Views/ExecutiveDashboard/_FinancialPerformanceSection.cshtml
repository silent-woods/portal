    function loadKPIData() {
        showLoaders();
        $.ajax({
            cache: false,
            type: 'POST',
            url: '@Url.Action("GetFinancialKPIData", "ExecutiveDashboard")',
            data: buildRequestData(),
            success: function (d) {
                if (d && typeof d === 'object') { updateCards(d); }
                hideLoaders();
            },
            error: function (xhr) {
                hideLoaders();
                console.error('KPI load failed', xhr.status, xhr.responseText);
            }
        });
