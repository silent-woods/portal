@{
    Layout = "_AdminLayout";
    ViewBag.PageTitle = T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Title").Text;
    NopHtml.SetActiveMenuItemSystemName("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard");

    bool canViewFinancial             = ViewBag.CanViewFinancial           == true;
    bool canViewOperational           = ViewBag.CanViewOperational         == true;
    bool canViewCRM                   = ViewBag.CanViewCRM                 == true;
    bool canViewEmployeeUtilization   = ViewBag.CanViewEmployeeUtilization == true;

    // Determine which tab should be active (first visible one)
    string activeTab = canViewFinancial ? "financial"
                     : canViewOperational ? "operational"
                     : canViewCRM ? "crm"
                     : canViewEmployeeUtilization ? "utilization" : "";
}

@if (!canViewFinancial && !canViewOperational && !canViewCRM && !canViewEmployeeUtilization)
{
    <div class="alert alert-warning">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.NoSectionAccess")</div>
}
else
{
    <div class="exec-tab-bar">
        @if (canViewFinancial)
        {
            <button class="exec-tab @(activeTab == "financial" ? "active" : "")" data-tab="financial">
                <i class="fas fa-chart-line"></i> @T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Tab.Financial")
            </button>
        }
        @if (canViewOperational)
        {
            <button class="exec-tab @(activeTab == "operational" ? "active" : "")" data-tab="operational">
                <i class="fas fa-tasks"></i> @T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Tab.Operational")
            </button>
        }
        @if (canViewCRM)
        {
            <button class="exec-tab @(activeTab == "crm" ? "active" : "")" data-tab="crm">
                <i class="fas fa-handshake"></i> @T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Tab.CRM")
            </button>
        }
        @if (canViewEmployeeUtilization)
        {
            <button class="exec-tab @(activeTab == "utilization" ? "active" : "")" data-tab="utilization">
                <i class="fas fa-user-clock"></i> @T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.Tab.EmployeeUtilization")
            </button>
        }
    </div>

    @if (canViewFinancial)
    {
        <div id="exec-tab-financial" @(activeTab != "financial" ? Html.Raw("style=\"display:none;\"") : Html.Raw(""))>
            @await Html.PartialAsync("~/Plugins/Misc.AccountManagement/Areas/Admin/Views/ExecutiveDashboard/_FinancialPerformanceSection.cshtml")
        </div>
    }
    @if (canViewOperational)
    {
        <div id="exec-tab-operational" @(activeTab != "operational" ? Html.Raw("style=\"display:none;\"") : Html.Raw(""))>
            @await Html.PartialAsync("~/Plugins/Misc.AccountManagement/Areas/Admin/Views/ExecutiveDashboard/_OperationalMetricsSection.cshtml")
        </div>
    }
    @if (canViewCRM)
    {
        <div id="exec-tab-crm" @(activeTab != "crm" ? Html.Raw("style=\"display:none;\"") : Html.Raw(""))>
            @await Html.PartialAsync("~/Plugins/Misc.AccountManagement/Areas/Admin/Views/ExecutiveDashboard/_CRMInsightsSection.cshtml")
        </div>
    }
    @if (canViewEmployeeUtilization)
    {
        <div id="exec-tab-utilization" @(activeTab != "utilization" ? Html.Raw("style=\"display:none;\"") : Html.Raw(""))>
            @await Html.PartialAsync("~/Plugins/Misc.AccountManagement/Areas/Admin/Views/ExecutiveDashboard/_EmployeeUtilizationSection.cshtml")
        </div>
    }
}

<style>
    .exec-tab-bar {
        display: flex;
        gap: 4px;
        margin-bottom: 4px;
        border-bottom: 2px solid #e5e7eb;
        padding-bottom: 0;
    }
    .exec-tab {
        padding: 10px 24px;
        font-size: 13px;
        font-weight: 600;
        color: #6b7280;
        background: none;
        border: none;
        border-bottom: 3px solid transparent;
        margin-bottom: -2px;
        cursor: pointer;
        border-radius: 6px 6px 0 0;
        transition: color 0.15s, border-color 0.15s;
    }
    .exec-tab:hover { color: #1d4ed8; }
    .exec-tab.active {
        color: #1d4ed8;
        border-bottom-color: #1d4ed8;
        background: #f0f4ff;
    }
    .exec-tab i { margin-right: 6px; }
</style>

<script>
(function () {
    var activeTab = '@activeTab';
    var loaded = {
        financial:   activeTab === 'financial',
        operational: activeTab === 'operational',
        crm:         activeTab === 'crm',
        utilization: activeTab === 'utilization'
    };

    $(document).ready(function () {
        $('.exec-tab').on('click', function () {
            var tab = $(this).data('tab');
            if ($(this).hasClass('active')) return;

            $('.exec-tab').removeClass('active');
            $(this).addClass('active');

            $('#exec-tab-financial, #exec-tab-operational, #exec-tab-crm, #exec-tab-utilization').hide();
            $('#exec-tab-' + tab).show();

            if (!loaded[tab]) {
                loaded[tab] = true;
                $(document).trigger('exec:load:' + tab);
            }
            $(document).trigger('exec:show:' + tab);
        });
    });
}());
</script>
