    $(document).on('click', '[data-crm-granularity]', function () {
        var g = $(this).data('crm-granularity');
        crmState.granularity = g;
        crmState.preset = g === 'month' ? 'lastmonth' : 'thisyear';
        $('.crm-granularity-toggle .btn').removeClass('active');
        $(this).addClass('active');
        if (g === 'month') {
            $('#crm-preset-bar-month').show();
            $('#crm-preset-bar-year').hide();
            $('#crm-preset-bar-month .btn-preset').removeClass('active');
            $('#crm-preset-bar-month [data-crm-preset="lastmonth"]').addClass('active');
        } else {
            $('#crm-preset-bar-month').hide();
            $('#crm-preset-bar-year').show();
            $('#crm-preset-bar-year .btn-preset').removeClass('active');
            $('#crm-preset-bar-year [data-crm-preset="thisyear"]').addClass('active');
        }
