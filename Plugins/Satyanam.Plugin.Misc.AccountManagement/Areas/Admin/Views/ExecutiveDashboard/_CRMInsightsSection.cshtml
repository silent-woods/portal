    var _crmPT = {};   
    var CRM_PAGE_SIZE = 15;

    function crmBuildPagedTable(rows, headerHtml, rowFn, emptyMsg) {
        if (!rows || !rows.length) return '<p class="text-muted text-center py-3">' + emptyMsg + '</p>';
        var tid = 'crm-pt-' + Math.random().toString(36).substr(2, 8);
        _crmPT[tid] = { rows: rows, rowFn: rowFn, pageSize: CRM_PAGE_SIZE, page: 0 };
        var totalPages = Math.ceil(rows.length / CRM_PAGE_SIZE);
        var html = '<div id="' + tid + '">'
            + '<div class="table-responsive"><table class="table table-hover crm-detail-table">'
            + '<thead><tr class="crm-thead-row">' + headerHtml + '</tr></thead>'
            + '<tbody id="' + tid + '-body">' + _crmPTRows(tid, 0) + '</tbody>'
            + '</table></div>'
            + '<div class="ops-pagination-footer">'
            + '<span class="ops-pagination-info" id="' + tid + '-info">' + _crmPTInfo(tid) + '</span>';
        if (totalPages > 1) {
            html += '<div class="ops-pagination-btns">'
                + '<button class="btn btn-sm btn-outline-secondary crm-pt-prev" data-tid="' + tid + '" disabled>‹ Prev</button>'
                + '<button class="btn btn-sm btn-outline-secondary crm-pt-next" data-tid="' + tid + '">Next ›</button>'
                + '</div>';
        }
        html += '</div></div>';
        return html;
    }

    function _crmPTRows(tid, page) {
        var d = _crmPT[tid]; if (!d) return '';
        var s = page * d.pageSize, e = Math.min(s + d.pageSize, d.rows.length), out = '';
        for (var i = s; i < e; i++) out += d.rowFn(d.rows[i]);
        return out;
    }

    function _crmPTInfo(tid) {
        var d = _crmPT[tid]; if (!d) return '';
        var s = d.page * d.pageSize + 1, e = Math.min(s + d.pageSize - 1, d.rows.length);
        return 'Showing ' + s + '–' + e + ' of ' + d.rows.length;
    }

    function bucketDailyData(dates, opens, clicks, bounces, rangeDays) {
        if (rangeDays < 45) return { labels: dates, opens: opens, clicks: clicks, bounces: bounces };

        var monthly = rangeDays >= 180;
        var buckets = {}, order = [];

        dates.forEach(function (d, i) {
            var parts  = d.split(' ');
            var day    = parseInt(parts[0], 10);
            var mon    = parts[1];
            var key;
            if (monthly) {
                key = mon;
            } else {
                var weekNum = Math.floor((day - 1) / 7);
                key = mon + ' W' + (weekNum + 1);
            }
            if (!buckets[key]) { buckets[key] = { opens: 0, clicks: 0, bounces: 0 }; order.push(key); }
            buckets[key].opens   += opens[i]   || 0;
            buckets[key].clicks  += clicks[i]  || 0;
            buckets[key].bounces += bounces[i] || 0;
        });

        return {
            labels:  order,
            opens:   order.map(function (k) { return buckets[k].opens; }),
            clicks:  order.map(function (k) { return buckets[k].clicks; }),
            bounces: order.map(function (k) { return buckets[k].bounces; })
        };
    }

    function loadEmailComboChart() {
        var range    = getCrmDateRange();
        var rangeDays = Math.round((range.to - range.from) / (1000 * 60 * 60 * 24));
        $('#crm-email-combo-loading').show();
        $('#crm-email-combo-nodata').hide();
        $('#crm-email-combo-wrap').hide();
        crmEmailComboChart = destroyChart(crmEmailComboChart);

        $.getJSON('/Admin/ExecutiveDashboard/GetCombinedTimeline', { fromDate: range.fromStr, toDate: range.toStr })
            .done(function (r) {
                $('#crm-email-combo-loading').hide();
                if (!r.success) {
                    $('#crm-email-combo-nodata').show();
                    return;
                }

                var totalSent  = r.totalSent || 0;
                var totalDel   = r.totalDelivered || 0;
                var sumOpens   = (r.opens   || []).reduce(function (s, v) { return s + v; }, 0);
                var sumClicks  = (r.clicks  || []).reduce(function (s, v) { return s + v; }, 0);
                var sumBounces = (r.bounces || []).reduce(function (s, v) { return s + v; }, 0);
                function ratePct(n, d) { return d > 0 ? (n / d * 100).toFixed(1) + '%' : '—'; }
                var cards = $('#crm-email-modal-summary .crm-email-sum-value');
                if (cards.length === 4) {
                    $(cards[0]).text(ratePct(sumOpens,   totalSent));
                    $(cards[1]).text(ratePct(totalDel,   totalSent));
                    $(cards[2]).text(ratePct(sumClicks,  totalSent));
                    $(cards[3]).text(ratePct(sumBounces, totalSent));
                }

                if (!r.dates || !r.dates.length) {
                    $('#crm-email-combo-nodata').show();
                    $('#crm-email-cmp-tbody').html('<tr><td colspan="6" class="text-center crm-td-neutral">—</td></tr>');
                    return;
                }
                $('#crm-email-combo-wrap').show();
                var ctx = document.getElementById('crm-email-combo-chart');
                if (!ctx) return;

                var b = bucketDailyData(r.dates, r.opens, r.clicks, r.bounces, rangeDays);

                crmEmailComboChart = new Chart(ctx.getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: b.labels,
                        datasets: [
                            { label: zohoTimelineRes.opens,   data: b.opens,   backgroundColor: 'rgba(59,130,246,0.65)', borderRadius: 3 },
                            { label: zohoTimelineRes.clicks,  data: b.clicks,  backgroundColor: 'rgba(245,158,11,0.65)', borderRadius: 3 },
                            { label: zohoTimelineRes.bounces, data: b.bounces, backgroundColor: 'rgba(239,68,68,0.55)',  borderRadius: 3 }
                        ]
                    },
                    options: {
                        responsive: true, maintainAspectRatio: false,
                        interaction: { mode: 'index', intersect: false },
                        plugins: { legend: { position: 'top', labels: { boxWidth: 12, font: { size: 11 } } } },
                        scales: {
                            y: { beginAtZero: true, ticks: { font: { size: 11 } }, grid: { color: 'rgba(0,0,0,0.05)' } },
                            x: { ticks: { font: { size: 11 }, maxRotation: 35 } }
                        }
                    }
                });
                $.getJSON('/Admin/ExecutiveDashboard/GetCampaignPeriodStats', { fromDate: range.fromStr, toDate: range.toStr })
                    .done(function (pr) {
                        if (!pr.success || !pr.campaigns || !pr.campaigns.length) {
                            $('#crm-email-cmp-tbody').html('<tr><td colspan="6" class="text-center crm-td-neutral">—</td></tr>');
                            return;
                        }
                        var maxOpens = Math.max.apply(null, pr.campaigns.map(function (c) { return c.opens || 0; })) || 1;
                        var trows = '';
                        pr.campaigns.forEach(function (c, i) {
                            var openCls = c.opens > 0 ? (c.opens >= maxOpens * 0.7 ? 'crm-email-pct-good' : 'crm-email-pct-warn') : 'crm-td-neutral';
                            var bncCls  = c.bounces > 0 && c.emailsSent > 0 && (c.bounces / c.emailsSent) > 0.1 ? 'crm-email-pct-bad'
                                        : c.bounces > 0 && c.emailsSent > 0 && (c.bounces / c.emailsSent) > 0.05 ? 'crm-email-pct-warn'
                                        : 'crm-td-neutral';
                            var origIdx = crmZohoCampaigns.findIndex(function (x) { return x.campaignKey === c.campaignKey; });
                            trows += '<tr>' +
                                '<td class="crm-email-rank">' + (i + 1) + '</td>' +
                                '<td><div class="crm-email-cmp-name"><a class="crm-zoho-name-link" data-zoho-idx="' + origIdx + '" href="#" title="' + escHtml(c.name) + '">' + escHtml(c.name) + '</a></div>' +
                                    (c.sentOn ? '<div class="crm-email-cmp-date">' + c.sentOn + '</div>' : '') + '</td>' +
                                '<td class="text-right crm-td-neutral">' + (c.emailsSent || 0).toLocaleString() + '</td>' +
                                '<td class="text-right ' + openCls + '">' + (c.opens || 0).toLocaleString() + '</td>' +
                                '<td class="text-right crm-td-neutral">' + (c.clicks || 0).toLocaleString() + '</td>' +
                                '<td class="text-right ' + bncCls + '">' + (c.bounces || 0).toLocaleString() + '</td>' +
                            '</tr>';
                        });
                        $('#crm-email-cmp-tbody').html(trows);
                    })
                    .fail(function () {
                        $('#crm-email-cmp-tbody').html('<tr><td colspan="6" class="text-center crm-td-neutral">—</td></tr>');
                    });
            })
            .fail(function () {
                $('#crm-email-combo-loading').hide();
                $('#crm-email-combo-nodata').show();
            });
    }

