            return '<tr><td class="crm-zoho-modal-label">' + label + '</td>' +
                   '<td class="crm-zoho-modal-count">' + (count || 0).toLocaleString() + pctText + '</td></tr>';
        }
        function rateRow(label, val) {
            return '<tr><td class="crm-zoho-modal-label">' + label + '</td>' +
                   '<td class="crm-zoho-modal-count">' + val + '</td></tr>';
        }

        var html = '<div class="crm-zoho-modal-meta">';
        if (c.emailSubject) html += '<div class="crm-zoho-modal-meta-row"><span class="crm-zoho-modal-meta-key">' + zohoModalRes.subject + ':</span> ' + c.emailSubject + '</div>';
        if (c.emailFrom)    html += '<div class="crm-zoho-modal-meta-row"><span class="crm-zoho-modal-meta-key">' + zohoModalRes.from + ':</span> ' + c.emailFrom + '</div>';
        if (c.sentOnFull)   html += '<div class="crm-zoho-modal-meta-row"><span class="crm-zoho-modal-meta-key">' + zohoModalRes.sentOn + ':</span> ' + c.sentOnFull + '</div>';
        if (c.createdOn)    html += '<div class="crm-zoho-modal-meta-row"><span class="crm-zoho-modal-meta-key">' + zohoModalRes.created + ':</span> ' + c.createdOn + '</div>';
