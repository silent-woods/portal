            + '<div class="tab-content">'
            + '<div class="tab-pane fade show active" id="crm-tab-leads">' + leadsHtml + '</div>'
            + '<div class="tab-pane fade" id="crm-tab-inqs">' + inqsHtml + '</div>'
            + '</div>';
    }
    var liFilterTitles = { all: crmRes.liFilterAll, converted: crmRes.liFilterConverted, replied: crmRes.liFilterReplied };

    $(document).on('click', '[data-li-filter]', function () {
        var filter = $(this).data('li-filter');
        $('#crmLinkedInContactsTitle').text(liFilterTitles[filter] || crmRes.liContacts);
        $('#crmLinkedInContactsBody').html('<div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>');
        $('#crmLinkedInContactsModal').modal('show');
        $.post('@Url.Action("GetCRMLinkedInContactsDetail", "ExecutiveDashboard", new { area = "Admin" })',
            addAntiForgeryToken({ filter: filter }))
            .done(function (rows) { $('#crmLinkedInContactsBody').html(buildLinkedInContactsTable(rows)); })
            .fail(function () { $('#crmLinkedInContactsBody').html('<p class="text-danger">' + crmRes.loadFailed + '</p>'); });
    });

    function buildLinkedInContactsTable(rows) {
        return crmBuildPagedTable(
            rows,
            '<th>' + crmRes.colLinkedInUrl + '</th><th>' + crmRes.colEmail + '</th><th>' + crmRes.colStatus + '</th><th>' + crmRes.colLastMessage + '</th><th>' + crmRes.colNextFollowup + '</th><th>' + crmRes.colRemaining + '</th>',
            function (r) {
                return '<tr>'
                    + '<td class="crm-td-url">'
                        + (r.linkedinUrl ? '<a href="' + escAttr(r.linkedinUrl) + '" target="_blank" rel="noopener"><i class="fab fa-linkedin crm-li-icon-inline"></i> ' + escHtml(r.linkedinUrl) + '</a>' : '—')
                        + '</td>'
                    + '<td class="crm-td-muted">' + escHtml(r.email || '—') + '</td>'
                    + '<td><span class="badge badge-secondary">' + escHtml(r.status) + '</span></td>'
                    + '<td class="crm-td-muted">' + escHtml(r.lastMessageDate || '—') + '</td>'
                    + '<td class="crm-td-neutral">' + escHtml(r.nextFollowUpDate || '—') + '</td>'
                    + '<td class="crm-td-neutral text-center">' + (r.remainingFollowUps || 0) + '</td>'
                    + '</tr>';
            },
            crmRes.noContacts
        );
    }

    function buildOverdueTable(rows) {
        return crmBuildPagedTable(
            rows,
            '<th>' + crmRes.colName + '</th><th>' + crmRes.colLinkedInUrl + '</th><th>' + crmRes.colNextFollowupDate + '</th><th>' + crmRes.colRemaining + '</th><th>' + crmRes.colStatus + '</th>',
            function (r) {
                return '<tr>'
                    + '<td class="crm-td-name">' + escHtml(r.name) + '</td>'
                    + '<td class="crm-td-url">'
                        + (r.linkedinUrl ? '<a href="' + escAttr(r.linkedinUrl) + '" target="_blank" rel="noopener">' + escHtml(r.linkedinUrl) + '</a>' : '—')
                        + '</td>'
                    + '<td class="crm-td-danger">' + escHtml(r.nextFollowUpDate || '—') + '</td>'
                    + '<td class="crm-td-neutral text-center">' + (r.remainingFollowUps || 0) + '</td>'
                    + '<td>' + escHtml(r.status || '—') + '</td>'
                    + '</tr>';
            },
            '<i class="fas fa-check-circle text-success"></i> ' + crmRes.allOnTrack
        );
    }

    function escHtml(s) {
        if (s == null) return '';
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
    function escAttr(s) { return escHtml(s); }

    var liState = { page: 1, pageSize: 20, sortBy: 'interestScore', sortDir: 'desc', totalCount: 0, loading: false };
    var liBaseUrl = '@Url.Action("GetLeadIntelligenceData", "ExecutiveDashboard", new { area = "Admin" })';

    function interestBadge(score) {
        var s = score || 0;
        var cls = s >= 81 ? 'crm-interest-high'
                : s >= 61 ? 'crm-interest-good'
                : s >= 31 ? 'crm-interest-medium'
                : s > 0   ? 'crm-interest-low'
                : 'crm-interest-none';
        return '<span class="crm-interest-badge ' + cls + '">' + s + '%</span>';
    }

    function loadLeadIntelligence() {
        if (liState.loading) return;
        liState.loading = true;
        $('#crm-top-leads-loading').show();
        $('#crm-top-leads-wrap').hide();
        $('#crm-top-leads-nodata').hide();

        $.getJSON(liBaseUrl, { page: liState.page, pageSize: liState.pageSize, sortBy: liState.sortBy, sortDir: liState.sortDir }, function (data) {
            liState.loading    = false;
            liState.totalCount = data.totalCount || 0;
            $('#crm-top-leads-loading').hide();

            var leads = data.leads || [];
            if (!leads.length && liState.page === 1) {
                $('#crm-top-leads-nodata').show();
                return;
            }

            var startNum = (liState.page - 1) * liState.pageSize + 1;
            var rows = '';
            leads.forEach(function (l, i) {
                rows += '<tr>'
                    + '<td class="crm-li-col-num text-muted">' + (startNum + i) + '</td>'
                    + '<td><a href="/Admin/Lead/Edit/' + l.id + '" target="_blank" class="crm-lead-name">' + escHtml(l.name || '—') + '</a>'
                    + (l.totalUnsubscribes > 0 ? ' <span class="crm-li-unsub-tag">&#128683; ' + crmRes.liTagUnsubscribed + '</span>' : '')
                    + '</td>'
                    + '<td class="crm-lead-company">' + escHtml(l.company || '—') + '</td>'
                    + '<td>' + interestBadge(l.interestScore) + '</td>'
                    + '<td class="text-center crm-li-num-cell">' + (l.totalOpens  || 0) + '</td>'
                    + '<td class="text-center crm-li-num-cell">' + (l.totalClicks || 0) + '</td>'
                    + '<td class="text-center crm-li-num-cell' + (l.totalBounces > 0 ? ' crm-li-bounce-cell' : '') + '">' + (l.totalBounces || 0) + '</td>'
                    + '</tr>';
            });
            $('#crm-top-leads-tbody').html(rows);

            var totalPages = Math.ceil(liState.totalCount / liState.pageSize);
            var end = Math.min(liState.page * liState.pageSize, liState.totalCount);
            $('#crm-top-leads-count').text(liState.totalCount > 0
                ? crmRes.liShowing.replace('{0}', startNum).replace('{1}', end).replace('{2}', liState.totalCount)
                : '');

            var pager = '';
            if (liState.page > 1)
                pager += '<button class="crm-page-btn" data-li-page="' + (liState.page - 1) + '">&lsaquo;</button>';
            var from = Math.max(1, liState.page - 2), to = Math.min(totalPages, liState.page + 2);
            for (var p = from; p <= to; p++)
                pager += '<button class="crm-page-btn' + (p === liState.page ? ' active' : '') + '" data-li-page="' + p + '">' + p + '</button>';
            if (liState.page < totalPages)
                pager += '<button class="crm-page-btn" data-li-page="' + (liState.page + 1) + '">&rsaquo;</button>';
            $('#crm-top-leads-pagination').html(pager);

            $('#crm-top-leads-wrap').show();
        }).fail(function () {
            liState.loading = false;
            $('#crm-top-leads-loading').hide();
        });
    }

    $(document).on('click', '#crm-top-leads-pagination [data-li-page]', function () {
        liState.page = parseInt($(this).attr('data-li-page'), 10);
        loadLeadIntelligence();
    });

    $(document).on('click', '.crm-li-col-sort', function () {
        var col = $(this).attr('data-li-sort');
        if (liState.sortBy === col) {
            liState.sortDir = liState.sortDir === 'desc' ? 'asc' : 'desc';
        } else {
            liState.sortBy  = col;
            liState.sortDir = 'desc';
        }
        liState.page = 1;
        $('.crm-li-col-sort').removeClass('crm-li-sort-active').find('i').attr('class', 'fas fa-sort crm-li-sort-icon');
        var icon = liState.sortDir === 'asc' ? 'fa-sort-up' : 'fa-sort-down';
        $(this).addClass('crm-li-sort-active').find('i').attr('class', 'fas ' + icon + ' crm-li-sort-icon');
        loadLeadIntelligence();
    });

    $(document).on('change', '#crm-li-exclude-unsub', function () {
        liState.excludeUnsubscribed = $(this).is(':checked');
        liState.page = 1;
        loadLeadIntelligence();
    });

    $(document).on('exec:load:crm', function () {
        var activeBar = crmState.granularity === 'month' ? '#crm-preset-bar-month' : '#crm-preset-bar-year';
        $(activeBar + ' .btn-preset').removeClass('active');
        if (crmState.preset) {
            $(activeBar + ' [data-crm-preset="' + crmState.preset + '"]').addClass('active');
        }
        $('[data-toggle="tooltip"]').tooltip();
        loadCRMData();
        loadLeadIntelligence();
    });
}());
</script>
