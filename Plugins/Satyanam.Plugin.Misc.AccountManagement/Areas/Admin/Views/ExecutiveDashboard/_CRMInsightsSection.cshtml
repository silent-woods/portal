        html += '<div class="crm-zoho-modal-stats-grid">';

        html += '<div class="crm-zoho-modal-stat-block"><div class="crm-zoho-modal-block-title">' + zohoModalRes.delivery + '</div>';
        html += '<table class="crm-zoho-modal-stat-table">';
        html += statRow(zohoModalRes.total,     c.emailsSent,     null,               '#374151');
        html += statRow(zohoModalRes.delivered, c.deliveredCount, c.deliveredPercent, '#10b981');
