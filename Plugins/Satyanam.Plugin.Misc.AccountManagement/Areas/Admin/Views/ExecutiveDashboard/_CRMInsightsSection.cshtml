        html += rateRow(zohoModalRes.clicksPerOpen, c.clicksPerOpen);
        html += '</table></div>';

        html += '<div class="crm-zoho-modal-stat-block"><div class="crm-zoho-modal-block-title">' + zohoModalRes.bounces + '</div>';
        html += '<table class="crm-zoho-modal-stat-table">';
        html += statRow(zohoModalRes.bounced,    c.bouncesCount, c.bouncePercent, '#ef4444');
        html += statRow(zohoModalRes.hardBounce, c.hardBounce,   null,            '#dc2626');
        html += statRow(zohoModalRes.softBounce, c.softBounce,   null,            '#f97316');
        html += '</table></div>';

        html += '<div class="crm-zoho-modal-stat-block"><div class="crm-zoho-modal-block-title">' + zohoModalRes.other + '</div>';
        html += '<table class="crm-zoho-modal-stat-table">';
