    var crmSparkCharts = {};
    var crmPipelineStageChart = null;
    var crmLeadsSourceChart = null;
    var crmWinLossChart = null;
    var crmMonthlyTrendChart = null;
    var crmLinkedInChart = null;
    var crmState = { granularity: 'month', preset: 'lastmonth' };
    function fmtINR(n) {
        if (n == null || n === '') return '—';
        var v = parseFloat(n);
        if (v >= 10000000) return '₹' + (v / 10000000).toFixed(2) + ' Cr';
        if (v >= 100000)   return '₹' + (v / 100000).toFixed(1) + ' L';
        if (v >= 1000)     return '₹' + (v / 1000).toFixed(0) + 'K';
        return '₹' + v.toFixed(0);
    }

    function trendHtml(current, previous, isAmt) {
        if (previous == null || previous === 0) {
            if (current > 0) return '<span class="kpi-trend up">↑ New</span>';
            return '<span class="kpi-trend neutral">—</span>';
        }
        var diff = ((current - previous) / Math.abs(previous)) * 100;
        var up = diff >= 0;
        var label = isAmt
            ? (up ? '↑ ' : '↓ ') + Math.abs(diff).toFixed(1) + '%'
            : (up ? '↑ ' : '↓ ') + Math.abs(diff).toFixed(1) + '%';
        return '<span class="kpi-trend ' + (up ? 'up' : 'down') + '">' + label + '</span>';
    }

    function destroyChart(ref) { if (ref) { try { ref.destroy(); } catch (e) {} } return null; }

    function buildPayload() {
        var p = { period: crmState.preset };
        if (!crmState.preset) {
            p.period = null;
            if (crmState.granularity === 'month') {
                p.monthFrom = parseInt($('#crm-month-from').val());
                p.yearFrom  = parseInt($('#crm-year-from-month').val());
                p.monthTo   = parseInt($('#crm-month-to').val());
                p.yearTo    = parseInt($('#crm-year-to-month').val());
            } else {
                p.yearFrom = parseInt($('#crm-year-from').val());
                p.yearTo   = parseInt($('#crm-year-to').val());
            }
        }
        return p;
    }

    function setLoading(show) {
        ['pipeline', 'won', 'leads', 'overdue'].forEach(function (k) {
            var el = document.getElementById('crm-load-' + k);
            if (el) el.style.display = show ? 'flex' : 'none';
        });
    }

    function drawSparkline(id, points, color) {
        if (crmSparkCharts[id]) { crmSparkCharts[id].destroy(); delete crmSparkCharts[id]; }
        var canvas = document.getElementById(id);
        if (!canvas || !points || !points.length) return;
        crmSparkCharts[id] = new Chart(canvas.getContext('2d'), {
            type: 'line',
            data: {
                labels: points.map(function (_, i) { return i; }),
                datasets: [{ data: points, borderColor: color, borderWidth: 1.5, pointRadius: 0, tension: 0.3, fill: false }]
            },
            options: {
                animation: false, responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false }, tooltip: { enabled: false } },
                scales: { x: { display: false }, y: { display: false } }
            }
        });
    }
    var linkedInLoaded = false;

    function loadCRMData() {
        setLoading(true);
        $.post('@Url.Action("GetCRMInsightsData", "ExecutiveDashboard", new { area = "Admin" })', addAntiForgeryToken(buildPayload()))
            .done(function (d) {
                setLoading(false);
                renderKPIs(d);
                renderPipelineStageChart(d);
                renderLeadsSourceChart(d);
                renderWinLossChart(d);
                renderMonthlyTrendChart(d);
                if (!linkedInLoaded) {
                    renderLinkedIn(d);
                    linkedInLoaded = true;
                }
            })
            .fail(function () { setLoading(false); });
    }

    function renderKPIs(d) {
        $('#crm-val-pipeline').text(fmtINR(d.totalPipelineValue));
        $('#crm-sub-pipeline').text((d.pipelineDealsCount || 0) + ' ' + (d.pipelineDealsCount !== 1 ? crmRes.deals : crmRes.deal));
        $('#crm-val-won').text(d.dealsWonCount + ' ' + (d.dealsWonCount !== 1 ? crmRes.deals : crmRes.deal));
        $('#crm-trend-won').replaceWith($(trendHtml(d.dealsWonValue, d.prevDealsWonValue, true)).attr('id', 'crm-trend-won'));
        $('#crm-sub-won').text(fmtINR(d.dealsWonValue));
        drawSparkline('crm-spark-won', d.dealsWonPoints, '#16a34a');
        var total = (d.newLeadsCount || 0) + (d.newInquiriesCount || 0);
        var prevTotal = (d.prevNewLeadsCount || 0) + (d.prevNewInquiriesCount || 0);
        $('#crm-val-leads').text(total);
        $('#crm-trend-leads').replaceWith($(trendHtml(total, prevTotal, false)).attr('id', 'crm-trend-leads'));
        $('#crm-sub-leads').text(d.newLeadsCount + ' ' + crmRes.leads + ', ' + d.newInquiriesCount + ' ' + crmRes.inquiries);
        drawSparkline('crm-spark-leads', d.newLeadsPoints, '#7c3aed');
        var ov = d.overdueFollowupsCount || 0;
        $('#crm-val-overdue').text(ov);
        $('#crm-sub-overdue').text(ov > 0 ? crmRes.actionRequired : crmRes.allOnTrack);
    }

    function renderLinkedIn(d) {
        $('#crm-li-total').text(d.linkedInTotalCount || 0);
        $('#crm-li-converted').text(d.linkedInConvertedCount || 0);
        var rate = d.linkedInConversionRate != null ? parseFloat(d.linkedInConversionRate).toFixed(1) + '%' : '0%';
        $('#crm-li-conv-rate').text(crmRes.conversion + rate);
        $('#crm-li-replied').text(d.linkedInRepliedCount || 0);

        var pts = d.linkedInStatusCounts || [];
        if (!pts.length) { $('#crm-li-donut-center').text(crmRes.noData); return; }

        var labels = pts.map(function (p) { return p.statusName; });
        var counts = pts.map(function (p) { return p.count; });
        var colors = pts.map(function (p) { return p.color; });
        var total  = counts.reduce(function (a, b) { return a + b; }, 0);
        $('#crm-li-donut-center').html('<div>' + total + '</div><div class="crm-donut-center-sub">' + crmRes.contacts + '</div>');

        crmLinkedInChart = destroyChart(crmLinkedInChart);
        var ctx = document.getElementById('crm-linkedin-status-chart');
        if (!ctx) return;
        crmLinkedInChart = new Chart(ctx.getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: labels,
                datasets: [{ data: counts, backgroundColor: colors, borderWidth: 2, borderColor: '#fff', hoverOffset: 6 }]
            },
            options: {
                responsive: true, maintainAspectRatio: false, cutout: '62%',
                plugins: {
                    legend: { position: 'bottom', labels: { boxWidth: 12, font: { size: 11 }, padding: 14 } },
                    tooltip: {
                        callbacks: {
                            label: function (ctx) {
                                var val = ctx.parsed;
                                var pct = total > 0 ? ' (' + (val / total * 100).toFixed(1) + '%)' : '';
                                return ' ' + ctx.label + ': ' + val + pct;
                            }
                        }
                    }
                }
            }
        });
    }

    function renderPipelineStageChart(d) {
        var pts = d.dealsByStage || [];
