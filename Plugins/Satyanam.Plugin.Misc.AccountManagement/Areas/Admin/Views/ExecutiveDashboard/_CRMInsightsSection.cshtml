<div class="card card-default crm-section-card">
    <div class="card-body">

        <div class="section-header crm-section-header">
            <span class="section-title">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Section.Title")</span>
            <div class="crm-filters-row">
                <div class="btn-group crm-granularity-toggle" role="group">
                    <button type="button" class="btn btn-outline-secondary btn-sm active" data-crm-granularity="month">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Granularity.Month")</button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-crm-granularity="year">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Granularity.Year")</button>
                </div>
            </div>
        </div>

        <div id="crm-preset-bar-month" class="preset-bar">
            <button class="btn-preset" data-crm-preset="currentmonth">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Preset.ThisMonth")</button>
            <button class="btn-preset active" data-crm-preset="lastmonth">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Preset.LastMonth")</button>
            <button class="btn-preset" data-crm-preset="last3months">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Preset.Last3Months")</button>
            <button class="btn-preset" data-crm-preset="last6months">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Preset.Last6Months")</button>
            <div class="period-inputs ms-2">
                <select id="crm-month-from">
                    @for (var m = 1; m <= 12; m++) { <option value="@m">@(new DateTime(2000, m, 1).ToString("MMM"))</option> }
                </select>
                <select id="crm-year-from-month">
                    @for (var y = DateTime.Now.Year; y >= DateTime.Now.Year - 5; y--) { <option value="@y">@y</option> }
                </select>
                <span class="crm-period-sep">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Period.To")</span>
                <select id="crm-month-to">
                    @for (var m = 1; m <= 12; m++) { <option value="@m">@(new DateTime(2000, m, 1).ToString("MMM"))</option> }
                </select>
                <select id="crm-year-to-month">
                    @for (var y = DateTime.Now.Year; y >= DateTime.Now.Year - 5; y--) { <option value="@y">@y</option> }
                </select>
            </div>
        </div>

        <div id="crm-preset-bar-year" class="preset-bar" style="display:none;">
            @{ var fyM = ViewBag.FyStartMonth != null ? (int)ViewBag.FyStartMonth : 1; }
            <button class="btn-preset active" data-crm-preset="thisyear">@(fyM > 1 ? T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Preset.ThisFY").Text : T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Preset.ThisYear").Text)</button>
            <button class="btn-preset" data-crm-preset="lastyear">@(fyM > 1 ? T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Preset.LastFY").Text : T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Preset.LastYear").Text)</button>
            <div class="period-inputs ms-2">
                <select id="crm-year-from">
                    @for (var y = DateTime.Now.Year; y >= DateTime.Now.Year - 5; y--) { <option value="@y">@y</option> }
                </select>
                <span class="crm-period-sep">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Period.To")</span>
                <select id="crm-year-to">
                    @for (var y = DateTime.Now.Year; y >= DateTime.Now.Year - 5; y--) { <option value="@y">@y</option> }
                </select>
            </div>
        </div>
        <div class="kpi-grid">

            <div class="kpi-card crm-pipeline" data-crm-modal="pipeline">
                <div class="kpi-card-top">
                    <span class="kpi-label kpi-label-wrap">
                        @T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.KPI.Pipeline.Label")
                        <i class="fas fa-info-circle kpi-info-icon" data-toggle="tooltip" data-placement="top" title="@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.KPI.Pipeline.Tooltip")"></i>
                    </span>
                    <div class="kpi-icon crm-pipeline-icon"><i class="fas fa-funnel-dollar"></i></div>
                </div>
                <div class="kpi-value" id="crm-val-pipeline">—</div>
                <div class="kpi-subtitle" id="crm-sub-pipeline"></div>
                <div class="kpi-sparkline-wrap"><canvas id="crm-spark-pipeline"></canvas></div>
                <div class="kpi-loading" id="crm-load-pipeline"><div class="spinner-sm"></div></div>
            </div>

            <div class="kpi-card crm-won" data-crm-modal="dealswon">
                <div class="kpi-card-top">
                    <span class="kpi-label kpi-label-wrap">
                        @T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.KPI.DealsWon.Label")
                        <i class="fas fa-info-circle kpi-info-icon" data-toggle="tooltip" data-placement="top" title="@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.KPI.DealsWon.Tooltip")"></i>
                    </span>
                    <div class="kpi-icon crm-won-icon"><i class="fas fa-trophy"></i></div>
                </div>
                <div class="kpi-value" id="crm-val-won">—</div>
                <div><span class="kpi-trend neutral" id="crm-trend-won">—</span></div>
                <div class="kpi-subtitle" id="crm-sub-won"></div>
                <div class="kpi-sparkline-wrap"><canvas id="crm-spark-won"></canvas></div>
                <div class="kpi-loading" id="crm-load-won"><div class="spinner-sm"></div></div>
            </div>

            <div class="kpi-card crm-leads" data-crm-modal="leads">
                <div class="kpi-card-top">
                    <span class="kpi-label kpi-label-wrap">
                        @T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.KPI.Leads.Label")
                        <i class="fas fa-info-circle kpi-info-icon" data-toggle="tooltip" data-placement="top" title="@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.KPI.Leads.Tooltip")"></i>
                    </span>
                    <div class="kpi-icon crm-leads-icon"><i class="fas fa-user-plus"></i></div>
                </div>
                <div class="kpi-value" id="crm-val-leads">—</div>
                <div><span class="kpi-trend neutral" id="crm-trend-leads">—</span></div>
                <div class="kpi-subtitle" id="crm-sub-leads"></div>
                <div class="kpi-sparkline-wrap"><canvas id="crm-spark-leads"></canvas></div>
                <div class="kpi-loading" id="crm-load-leads"><div class="spinner-sm"></div></div>
            </div>

            <div class="kpi-card crm-overdue" data-crm-modal="overdue">
                <div class="kpi-card-top">
                    <span class="kpi-label kpi-label-wrap">
                        @T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.KPI.Overdue.Label")
                        <i class="fas fa-info-circle kpi-info-icon" data-toggle="tooltip" data-placement="top" title="@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.KPI.Overdue.Tooltip")"></i>
                    </span>
                    <div class="kpi-icon crm-overdue-icon"><i class="fas fa-exclamation-triangle"></i></div>
                </div>
                <div class="kpi-value crm-overdue-value" id="crm-val-overdue">—</div>
                <div class="kpi-subtitle" id="crm-sub-overdue"></div>
                <div class="kpi-sparkline-wrap"></div>
                <div class="kpi-loading" id="crm-load-overdue"><div class="spinner-sm"></div></div>
            </div>

        </div>
        <div class="cashflow-chart-section crm-chart-section crm-linkedin-section">
            <div class="cashflow-chart-header">
                <span class="cashflow-chart-title"><i class="fab fa-linkedin crm-li-title-icon"></i> @T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.LinkedIn.SectionTitle")</span>
                <div class="crm-li-summary" id="crm-li-summary"></div>
            </div>
            <div class="crm-li-stats-row">
                <div class="crm-li-stat-card crm-li-stat-total" data-li-filter="all" title="@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.LinkedIn.TotalContacts.Tooltip")">
                    <div class="crm-li-stat-label">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.LinkedIn.TotalContacts") <i class="fas fa-external-link-alt crm-li-card-icon"></i></div>
                    <div class="crm-li-stat-value" id="crm-li-total">—</div>
                </div>
                <div class="crm-li-stat-card crm-li-stat-converted" data-li-filter="converted" title="@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.LinkedIn.Converted.Tooltip")">
                    <div class="crm-li-stat-label">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.LinkedIn.Converted") <i class="fas fa-external-link-alt crm-li-card-icon"></i></div>
                    <div class="crm-li-stat-value" id="crm-li-converted">—</div>
                    <div class="crm-li-stat-sub" id="crm-li-conv-rate"></div>
                </div>
                <div class="crm-li-stat-card crm-li-stat-replied" data-li-filter="replied" title="@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.LinkedIn.RepliedInTalk.Tooltip")">
                    <div class="crm-li-stat-label">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.LinkedIn.RepliedInTalk") <i class="fas fa-external-link-alt crm-li-card-icon"></i></div>
                    <div class="crm-li-stat-value" id="crm-li-replied">—</div>
                </div>
            </div>
            <div class="crm-li-chart-area">
                <div class="crm-li-chart-wrap">
                    <canvas id="crm-linkedin-status-chart"></canvas>
                    <div class="crm-li-donut-center" id="crm-li-donut-center"></div>
                </div>
            </div>
        </div>
        <div class="cashflow-chart-section crm-chart-section">
            <div class="cashflow-chart-header">
                <span class="cashflow-chart-title">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Chart.PipelineByStage")</span>
            </div>
            <div class="cashflow-chart-wrap">
                <canvas id="crm-pipeline-stage-chart"></canvas>
            </div>
        </div>
        <div class="crm-two-col-charts">
            <div class="cashflow-chart-section crm-chart-section crm-chart-half">
                <div class="cashflow-chart-header">
                    <span class="cashflow-chart-title">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Chart.LeadsBySource")</span>
                </div>
                <div class="crm-donut-wrap">
                    <canvas id="crm-leads-source-chart"></canvas>
                </div>
            </div>
            <div class="cashflow-chart-section crm-chart-section crm-chart-half">
                <div class="cashflow-chart-header">
                    <span class="cashflow-chart-title">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Chart.WinLossRate")</span>
                </div>
                <div class="crm-donut-wrap">
                    <canvas id="crm-winloss-chart"></canvas>
                    <div class="crm-winloss-center" id="crm-winloss-center"></div>
                </div>
            </div>
        </div>
        <div class="cashflow-chart-section crm-chart-section">
            <div class="cashflow-chart-header">
                <span class="cashflow-chart-title">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Chart.MonthlyTrend")</span>
            </div>
            <div class="cashflow-chart-wrap">
                <canvas id="crm-monthly-trend-chart"></canvas>
            </div>
        </div>

    </div>
</div>
<div class="modal fade" id="crmPipelineModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Modal.Pipeline.Title")</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body" id="crmPipelineModalBody">
                <div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>
            </div>
            <div class="modal-footer">
                <a href="/Admin/Deals/List" target="_blank" class="btn btn-sm btn-outline-primary">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Link.ViewAllDeals")</a>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="crmDealsWonModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="crmDealsWonModalTitle">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Modal.DealsWon.Title")</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body" id="crmDealsWonModalBody">
                <div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>
            </div>
            <div class="modal-footer">
                <a href="/Admin/Deals/List" target="_blank" class="btn btn-sm btn-outline-primary">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Link.ViewAllDeals")</a>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="crmLeadsModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="crmLeadsModalTitle">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Modal.Leads.Title")</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body" id="crmLeadsModalBody">
                <div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>
            </div>
            <div class="modal-footer">
                <a href="/Admin/Lead/List" target="_blank" class="btn btn-sm btn-outline-primary me-2">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Link.ViewAllLeads")</a>
                <a href="/Admin/Inquiry/List" target="_blank" class="btn btn-sm btn-outline-secondary">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Link.ViewAllInquiries")</a>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="crmOverdueModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Modal.Overdue.Title")</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body" id="crmOverdueModalBody">
                <div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>
            </div>
            <div class="modal-footer">
                <a href="/Admin/LinkedInFollowups/List" target="_blank" class="btn btn-sm btn-outline-primary">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Link.ViewAllFollowups")</a>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="crmLinkedInContactsModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header crm-li-modal-header">
                <h5 class="modal-title"><i class="fab fa-linkedin crm-li-title-icon"></i> <span id="crmLinkedInContactsTitle">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Modal.LinkedIn.Title")</span></h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body" id="crmLinkedInContactsBody">
                <div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>
            </div>
            <div class="modal-footer">
                <a href="/Admin/LinkedInFollowups/List" target="_blank" class="btn btn-sm btn-outline-primary">@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Link.ViewAllFollowups")</a>
            </div>
        </div>
    </div>
</div>

<style>
    .kpi-card.crm-pipeline { border-left: 5px solid #2563eb; }
    .kpi-card.crm-won      { border-left: 5px solid #16a34a; }
    .kpi-card.crm-leads    { border-left: 5px solid #7c3aed; }
    .kpi-card.crm-overdue  { border-left: 5px solid #dc2626; }
    .kpi-icon.crm-pipeline-icon { background: rgba(37,99,235,0.10); color: #2563eb; }
    .kpi-icon.crm-won-icon      { background: rgba(22,163,74,0.10);  color: #16a34a; }
    .kpi-icon.crm-leads-icon    { background: rgba(124,58,237,0.10); color: #7c3aed; }
    .kpi-icon.crm-overdue-icon  { background: rgba(220,38,38,0.10);  color: #dc2626; }
    .crm-overdue-value          { color: #dc2626; }
    .crm-section-card      { margin-top: 0; }
    .crm-section-header    { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; margin-bottom: 12px; }
    .crm-filters-row       { display: flex; align-items: center; gap: 8px; }
    .crm-period-sep        { font-size: 12px; color: #6b7280; padding: 0 4px; }
    .crm-chart-section     { margin-top: 20px; }
    .crm-two-col-charts    { display: flex; gap: 20px; margin-top: 20px; flex-wrap: wrap; }
    .crm-chart-half        { flex: 1; min-width: 260px; margin-top: 0 !important; }
    .crm-donut-wrap        { position: relative; max-width: 320px; margin: 0 auto; height: 260px; }
    .crm-winloss-center    { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); text-align: center; pointer-events: none; }
    .crm-linkedin-section  { border-left: 4px solid #0a66c2; padding-left: 16px; background: #f8faff; border-radius: 0 8px 8px 0; }
    .crm-li-title-icon     { color: #0a66c2; margin-right: 6px; }
    .crm-li-summary        { font-size: 12px; color: #6b7280; font-style: italic; }
    .crm-li-stats-row      { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 20px; margin-top: 8px; }
    .crm-li-stat-card      { flex: 1; min-width: 130px; background: #fff; border: 1px solid #e5e7eb; border-radius: 8px; padding: 14px 18px; }
    .crm-li-stat-card.crm-li-stat-total       { border-top: 3px solid #0a66c2; }
    .crm-li-stat-card.crm-li-stat-converted   { border-top: 3px solid #16a34a; }
    .crm-li-stat-card.crm-li-stat-replied     { border-top: 3px solid #f59e0b; }
    .crm-li-stat-card.crm-li-stat-overdue-li  { border-top: 3px solid #dc2626; }
    .crm-li-stat-label     { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; color: #6b7280; margin-bottom: 4px; }
    .crm-li-stat-value     { font-size: 28px; font-weight: 700; color: #111827; line-height: 1.1; }
    .crm-li-stat-sub       { font-size: 12px; color: #6b7280; margin-top: 3px; }
    .crm-li-stat-card[data-li-filter]:hover { box-shadow: 0 2px 8px rgba(10,102,194,0.15); border-color: #0a66c2 !important; transition: box-shadow .15s, border-color .15s; }
    .crm-li-card-icon      { font-size: 9px; color: #9ca3af; margin-left: 4px; vertical-align: middle; }
    .crm-li-chart-area     { display: flex; justify-content: center; }
    .crm-li-chart-wrap     { width: 100%; max-width: 560px; height: 300px; position: relative; }
    .crm-li-donut-center   { position: absolute; top: 36%; left: 50%; transform: translate(-50%,-50%); text-align: center; pointer-events: none; font-size: 14px; font-weight: 700; color: #374151; }
    .crm-detail-table      { font-size: 13px; }
    .crm-thead-row         { background: #f9fafb; }
    .crm-thead-row th      { font-weight: 600; }
    .crm-td-name           { vertical-align: middle; font-weight: 500; }
    .crm-td-amount         { vertical-align: middle; font-weight: 600; color: #059669; }
    .crm-td-muted          { vertical-align: middle; color: #6b7280; }
    .crm-td-neutral        { vertical-align: middle; color: #374151; }
    .crm-td-danger         { vertical-align: middle; color: #dc2626; font-weight: 600; }
    .crm-modal-tabs        { margin-bottom: 16px; }
    .kpi-card[data-crm-modal]         { cursor: pointer; }
    .crm-li-stat-card[data-li-filter] { cursor: pointer; }
    .crm-li-modal-header   { border-bottom: 2px solid #0a66c2; }
    .crm-li-icon-inline    { color: #0a66c2; }
    .crm-td-url            { max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; vertical-align: middle; }
    .crm-winloss-rate      { font-size: 20px; font-weight: 700; color: #111827; }
    .crm-winloss-label     { font-size: 10px; color: #6b7280; }
    .crm-donut-center-sub  { font-size: 10px; color: #6b7280; }
</style>

<script>
(function () {
    var crmRes = {
        pipelineValue:      '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Chart.PipelineValue").Text',
        winRate:            '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Chart.WinRate").Text',
        won:                '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Chart.Won").Text',
        lost:               '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Chart.Lost").Text',
        lostToComp:         '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Chart.LostToComp").Text',
        newLeads:           '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Chart.NewLeads").Text',
        dealsWon:           '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Chart.DealsWon").Text',
        noOpenDeals:        '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Message.NoOpenDeals").Text',
        noDealsWon:         '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Message.NoDealsWon").Text',
        noLeads:            '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Message.NoLeads").Text',
