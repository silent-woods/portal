        }
    });
    var _crmPT = {};   
    var CRM_PAGE_SIZE = 15;

    function crmBuildPagedTable(rows, headerHtml, rowFn, emptyMsg) {
        if (!rows || !rows.length) return '<p class="text-muted text-center py-3">' + emptyMsg + '</p>';
        var tid = 'crm-pt-' + Math.random().toString(36).substr(2, 8);
        _crmPT[tid] = { rows: rows, rowFn: rowFn, pageSize: CRM_PAGE_SIZE, page: 0 };
        var totalPages = Math.ceil(rows.length / CRM_PAGE_SIZE);
        var html = '<div id="' + tid + '">'
            + '<div class="table-responsive"><table class="table table-hover crm-detail-table">'
            + '<thead><tr class="crm-thead-row">' + headerHtml + '</tr></thead>'
            + '<tbody id="' + tid + '-body">' + _crmPTRows(tid, 0) + '</tbody>'
            + '</table></div>'
            + '<div class="ops-pagination-footer">'
            + '<span class="ops-pagination-info" id="' + tid + '-info">' + _crmPTInfo(tid) + '</span>';
        if (totalPages > 1) {
            html += '<div class="ops-pagination-btns">'
                + '<button class="btn btn-sm btn-outline-secondary crm-pt-prev" data-tid="' + tid + '" disabled>‹ Prev</button>'
                + '<button class="btn btn-sm btn-outline-secondary crm-pt-next" data-tid="' + tid + '">Next ›</button>'
                + '</div>';
        }
        html += '</div></div>';
        return html;
    }

    function _crmPTRows(tid, page) {
        var d = _crmPT[tid]; if (!d) return '';
        var s = page * d.pageSize, e = Math.min(s + d.pageSize, d.rows.length), out = '';
        for (var i = s; i < e; i++) out += d.rowFn(d.rows[i]);
        return out;
    }

    function _crmPTInfo(tid) {
        var d = _crmPT[tid]; if (!d) return '';
        var s = d.page * d.pageSize + 1, e = Math.min(s + d.pageSize - 1, d.rows.length);
        return 'Showing ' + s + '–' + e + ' of ' + d.rows.length;
    }

    $(document).on('click', '.crm-pt-prev, .crm-pt-next', function () {
        var tid = $(this).data('tid'), d = _crmPT[tid]; if (!d) return;
        var total = Math.ceil(d.rows.length / d.pageSize);
        d.page = $(this).hasClass('crm-pt-next') ? d.page + 1 : d.page - 1;
        d.page = Math.max(0, Math.min(d.page, total - 1));
        $('#' + tid + '-body').html(_crmPTRows(tid, d.page));
        $('#' + tid + '-info').text(_crmPTInfo(tid));
        $('#' + tid).find('.crm-pt-prev').prop('disabled', d.page === 0);
        $('#' + tid).find('.crm-pt-next').prop('disabled', d.page >= total - 1);
    });
    function buildPipelineTable(rows) {
        return crmBuildPagedTable(
            rows,
            '<th>' + crmRes.colDealName + '</th><th>' + crmRes.colCompany + '</th><th>' + crmRes.colStage + '</th><th>' + crmRes.colAmount + '</th><th>' + crmRes.colProbability + '</th><th>' + crmRes.colClosingDate + '</th>',
            function (r) {
                return '<tr>'
                    + '<td class="crm-td-name">' + escHtml(r.dealName) + '</td>'
                    + '<td class="crm-td-neutral">' + escHtml(r.company || '—') + '</td>'
                    + '<td><span class="badge badge-info">' + escHtml(r.stage || '—') + '</span></td>'
                    + '<td class="crm-td-amount">' + fmtINR(r.amount) + '</td>'
                    + '<td class="crm-td-neutral">' + (r.probability != null ? r.probability + '%' : '—') + '</td>'
                    + '<td class="crm-td-muted">' + escHtml(r.closingDate || '—') + '</td>'
                    + '</tr>';
            },
            crmRes.noOpenDeals
        );
    }

    function buildDealsWonTable(rows) {
        return crmBuildPagedTable(
            rows,
            '<th>' + crmRes.colDealName + '</th><th>' + crmRes.colCompany + '</th><th>' + crmRes.colAmount + '</th><th>' + crmRes.colProbability + '</th><th>' + crmRes.colClosingDate + '</th>',
            function (r) {
                return '<tr>'
                    + '<td class="crm-td-name">' + escHtml(r.dealName) + '</td>'
                    + '<td class="crm-td-neutral">' + escHtml(r.company || '—') + '</td>'
                    + '<td class="crm-td-amount">' + fmtINR(r.amount) + '</td>'
                    + '<td class="crm-td-neutral">' + (r.probability != null ? r.probability + '%' : '—') + '</td>'
                    + '<td class="crm-td-muted">' + escHtml(r.closingDate || '—') + '</td>'
                    + '</tr>';
            },
            crmRes.noDealsWon
        );
    }

    function buildLeadsInquiriesHtml(data) {
        var leads = data.leads || [];
        var inqs  = data.inquiries || [];

        var leadsHtml = crmBuildPagedTable(
            leads,
            '<th>' + crmRes.colName + '</th><th>' + crmRes.colCompany + '</th><th>' + crmRes.colSource + '</th><th>' + crmRes.colCreated + '</th>',
            function (r) {
                return '<tr>'
                    + '<td class="crm-td-name">' + escHtml(r.name) + '</td>'
                    + '<td class="crm-td-neutral">' + escHtml(r.company || '—') + '</td>'
                    + '<td class="crm-td-muted">' + escHtml(r.source || '—') + '</td>'
                    + '<td class="crm-td-muted">' + escHtml(r.createdOn) + '</td>'
                    + '</tr>';
            },
            crmRes.noLeads
        );

        var inqsHtml = crmBuildPagedTable(
            inqs,
            '<th>' + crmRes.colName + '</th><th>' + crmRes.colCompany + '</th><th>' + crmRes.colProjectType + '</th><th>' + crmRes.colBudget + '</th><th>' + crmRes.colCreated + '</th>',
            function (r) {
                return '<tr>'
                    + '<td class="crm-td-name">' + escHtml(r.name) + '</td>'
                    + '<td class="crm-td-neutral">' + escHtml(r.company || '—') + '</td>'
                    + '<td class="crm-td-neutral">' + escHtml(r.projectType || '—') + '</td>'
                    + '<td class="crm-td-amount">' + (r.budget ? fmtINR(r.budget) : '—') + '</td>'
                    + '<td class="crm-td-muted">' + escHtml(r.createdOn) + '</td>'
                    + '</tr>';
            },
            crmRes.noInquiries
        );

        return '<ul class="nav nav-tabs crm-modal-tabs" role="tablist">'
            + '<li class="nav-item"><a class="nav-link active" data-toggle="tab" href="#crm-tab-leads">' + crmRes.tabLeads + ' (' + leads.length + ')</a></li>'
            + '<li class="nav-item"><a class="nav-link" data-toggle="tab" href="#crm-tab-inqs">' + crmRes.tabInquiries + ' (' + inqs.length + ')</a></li>'
            + '</ul>'
            + '<div class="tab-content">'
            + '<div class="tab-pane fade show active" id="crm-tab-leads">' + leadsHtml + '</div>'
            + '<div class="tab-pane fade" id="crm-tab-inqs">' + inqsHtml + '</div>'
            + '</div>';
    }
    var liFilterTitles = { all: crmRes.liFilterAll, converted: crmRes.liFilterConverted, replied: crmRes.liFilterReplied };

    $(document).on('click', '[data-li-filter]', function () {
        var filter = $(this).data('li-filter');
        $('#crmLinkedInContactsTitle').text(liFilterTitles[filter] || crmRes.liContacts);
        $('#crmLinkedInContactsBody').html('<div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>');
        $('#crmLinkedInContactsModal').modal('show');
        $.post('@Url.Action("GetCRMLinkedInContactsDetail", "ExecutiveDashboard", new { area = "Admin" })',
            addAntiForgeryToken({ filter: filter }))
            .done(function (rows) { $('#crmLinkedInContactsBody').html(buildLinkedInContactsTable(rows)); })
            .fail(function () { $('#crmLinkedInContactsBody').html('<p class="text-danger">' + crmRes.loadFailed + '</p>'); });
    });

    function buildLinkedInContactsTable(rows) {
        return crmBuildPagedTable(
            rows,
            '<th>' + crmRes.colLinkedInUrl + '</th><th>' + crmRes.colEmail + '</th><th>' + crmRes.colStatus + '</th><th>' + crmRes.colLastMessage + '</th><th>' + crmRes.colNextFollowup + '</th><th>' + crmRes.colRemaining + '</th>',
            function (r) {
                return '<tr>'
                    + '<td class="crm-td-url">'
                        + (r.linkedinUrl ? '<a href="' + escAttr(r.linkedinUrl) + '" target="_blank" rel="noopener"><i class="fab fa-linkedin crm-li-icon-inline"></i> ' + escHtml(r.linkedinUrl) + '</a>' : '—')
                        + '</td>'
                    + '<td class="crm-td-muted">' + escHtml(r.email || '—') + '</td>'
                    + '<td><span class="badge badge-secondary">' + escHtml(r.status) + '</span></td>'
                    + '<td class="crm-td-muted">' + escHtml(r.lastMessageDate || '—') + '</td>'
                    + '<td class="crm-td-neutral">' + escHtml(r.nextFollowUpDate || '—') + '</td>'
                    + '<td class="crm-td-neutral text-center">' + (r.remainingFollowUps || 0) + '</td>'
                    + '</tr>';
            },
            crmRes.noContacts
        );
    }

    function buildOverdueTable(rows) {
        return crmBuildPagedTable(
            rows,
            '<th>' + crmRes.colName + '</th><th>' + crmRes.colLinkedInUrl + '</th><th>' + crmRes.colNextFollowupDate + '</th><th>' + crmRes.colRemaining + '</th><th>' + crmRes.colStatus + '</th>',
            function (r) {
                return '<tr>'
                    + '<td class="crm-td-name">' + escHtml(r.name) + '</td>'
                    + '<td class="crm-td-url">'
                        + (r.linkedinUrl ? '<a href="' + escAttr(r.linkedinUrl) + '" target="_blank" rel="noopener">' + escHtml(r.linkedinUrl) + '</a>' : '—')
                        + '</td>'
                    + '<td class="crm-td-danger">' + escHtml(r.nextFollowUpDate || '—') + '</td>'
                    + '<td class="crm-td-neutral text-center">' + (r.remainingFollowUps || 0) + '</td>'
                    + '<td>' + escHtml(r.status || '—') + '</td>'
                    + '</tr>';
            },
            '<i class="fas fa-check-circle text-success"></i> ' + crmRes.allOnTrack
        );
    }

    function escHtml(s) {
        if (s == null) return '';
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
    function escAttr(s) { return escHtml(s); }
    $(document).on('exec:load:crm', function () {
        var activeBar = crmState.granularity === 'month' ? '#crm-preset-bar-month' : '#crm-preset-bar-year';
        $(activeBar + ' .btn-preset').removeClass('active');
        if (crmState.preset) {
            $(activeBar + ' [data-crm-preset="' + crmState.preset + '"]').addClass('active');
        }
        $('[data-toggle="tooltip"]').tooltip();
        loadCRMData(); 
    });
}());
</script>
