    function fmtINR(n) {
        if (n == null || n === '') return '—';
        var v = parseFloat(n);
        if (v >= 10000000) return '₹' + (v / 10000000).toFixed(2) + ' Cr';
        if (v >= 100000)   return '₹' + (v / 100000).toFixed(1) + ' L';
        if (v >= 1000)     return '₹' + (v / 1000).toFixed(0) + 'K';
        return '₹' + v.toFixed(0);
    }

    function trendHtml(current, previous, isAmt) {
        if (previous == null || previous === 0) {
            if (current > 0) return '<span class="kpi-trend up">↑ New</span>';
            return '<span class="kpi-trend neutral">—</span>';
        }
        var diff = ((current - previous) / Math.abs(previous)) * 100;
        var up = diff >= 0;
        var label = isAmt
            ? (up ? '↑ ' : '↓ ') + Math.abs(diff).toFixed(1) + '%'
            : (up ? '↑ ' : '↓ ') + Math.abs(diff).toFixed(1) + '%';
        return '<span class="kpi-trend ' + (up ? 'up' : 'down') + '">' + label + '</span>';
    }

    function destroyChart(ref) { if (ref) { try { ref.destroy(); } catch (e) {} } return null; }

    function buildPayload() {
        var p = { period: crmState.preset };
        if (!crmState.preset) {
            p.period = null;
            if (crmState.granularity === 'month') {
                p.monthFrom = parseInt($('#crm-month-from').val());
                p.yearFrom  = parseInt($('#crm-year-from-month').val());
                p.monthTo   = parseInt($('#crm-month-to').val());
                p.yearTo    = parseInt($('#crm-year-to-month').val());
            } else {
                p.yearFrom = parseInt($('#crm-year-from').val());
                p.yearTo   = parseInt($('#crm-year-to').val());
            }
        }
        return p;
    }
    function getCrmDateRange() {
        var now   = new Date();
        var today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
        var from, to = today, label;
        var preset = crmState.preset;
        if (preset === 'currentmonth') {
            from  = new Date(today.getFullYear(), today.getMonth(), 1);
            label = '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Preset.ThisMonth").Text';
        } else if (preset === 'lastmonth') {
            from  = new Date(today.getFullYear(), today.getMonth() - 1, 1);
            to    = new Date(today.getFullYear(), today.getMonth(), 0);
            label = '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Preset.LastMonth").Text';
        } else if (preset === 'last3months') {
            from  = new Date(today.getFullYear(), today.getMonth() - 3, 1);
            label = '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Preset.Last3Months").Text';
        } else if (preset === 'last6months') {
            from  = new Date(today.getFullYear(), today.getMonth() - 6, 1);
            label = '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Preset.Last6Months").Text';
        } else if (preset === 'thisyear') {
            from  = new Date(today.getFullYear(), 0, 1);
            label = '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Preset.ThisYear").Text';
        } else if (preset === 'lastyear') {
            from  = new Date(today.getFullYear() - 1, 0, 1);
            to    = new Date(today.getFullYear() - 1, 11, 31);
            label = '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Preset.LastYear").Text';
        } else if (preset === 'last2years') {
            from  = new Date(today.getFullYear() - 2, 0, 1);
            label = '@T("Satyanam.Plugin.Misc.AccountManagement.Admin.ExecutiveDashboard.CRM.Preset.Last2Years").Text';
        } else {
            if (crmState.granularity === 'month') {
                var mf = parseInt($('#crm-month-from').val())    || 1;
                var yf = parseInt($('#crm-year-from-month').val()) || today.getFullYear();
                var mt = parseInt($('#crm-month-to').val())      || 12;
                var yt = parseInt($('#crm-year-to-month').val())   || today.getFullYear();
                from   = new Date(yf, mf - 1, 1);
                to     = new Date(yt, mt, 0); 
            } else {
                var yf2 = parseInt($('#crm-year-from').val()) || today.getFullYear();
                var yt2 = parseInt($('#crm-year-to').val())   || today.getFullYear();
                from    = new Date(yf2, 0, 1);
                to      = new Date(yt2, 11, 31);
            }
            var mNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
            label = mNames[from.getMonth()] + ' ' + from.getFullYear() + ' – ' + mNames[to.getMonth()] + ' ' + to.getFullYear();
        }

        function pad(d) { return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0'); }
        return { from: from, to: to, fromStr: pad(from), toStr: pad(to), label: label };
    }

    function getPrevPeriodRange(range) {
        var span    = range.to.getTime() - range.from.getTime();
        var prevTo  = new Date(range.from.getTime() - 24 * 60 * 60 * 1000);
        var prevFrom = new Date(prevTo.getTime() - span);
        function pad(d) { return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0'); }
        return { from: prevFrom, to: prevTo, fromStr: pad(prevFrom), toStr: pad(prevTo) };
    }

    function loadEmailKpiCard() {
        var range     = getCrmDateRange();
        var prevRange = getPrevPeriodRange(range);

        var currCall = $.getJSON('/Admin/ExecutiveDashboard/GetCombinedTimeline', { fromDate: range.fromStr,      toDate: range.toStr      });
        var prevCall = $.getJSON('/Admin/ExecutiveDashboard/GetCombinedTimeline', { fromDate: prevRange.fromStr,  toDate: prevRange.toStr  });

        $.when(currCall, prevCall).done(function (curr, prev) {
            var r  = curr[0];
            var rp = prev[0];
            if (!r || !r.success) return;

            var totalSent = r.totalSent || 0;
            var sumOpens  = (r.opens  || []).reduce(function (s, v) { return s + v; }, 0);
            var pSumOpens = (rp && rp.opens ? rp.opens : []).reduce(function (s, v) { return s + v; }, 0);

            var openRate  = totalSent > 0 ? sumOpens  / totalSent * 100 : 0;
            var pOpenRate = totalSent > 0 ? pSumOpens / totalSent * 100 : 0;

            var inPeriod = (crmZohoCampaigns || []).filter(function (c) {
                if (!c.sentTimeIso) return false;
                var dt = new Date(c.sentTimeIso);
                return dt >= range.from && dt <= range.to;
            }).length;
            var sentCount = inPeriod || (crmZohoCampaigns || []).length;

            $('#crm-val-email').text(openRate.toFixed(1) + '%');
            $('#crm-sub-email').text(sentCount + ' ' + crmRes.emailKpiCampaigns);

            var emailTrendSpan = pOpenRate > 0
                ? trendHtml_(openRate, pOpenRate, false)
                : '<span class="kpi-trend neutral">—</span>';
            $('#crm-trend-email').replaceWith($(emailTrendSpan).attr('id', 'crm-trend-email'));

            var openPoints = (r.opens || []).slice(-12);
            drawSparkline('crm-spark-email', openPoints, '#f59e0b');
        });
    }

    function setLoading(show) {
        ['pipeline', 'won', 'leads', 'overdue', 'email'].forEach(function (k) {
