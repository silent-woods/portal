@model EmployeeModel

@if (Model.Id > 0)
{
    var canEdit   = await permissionService.AuthorizeAsync(StandardPermissionProvider.ManageAssets, PermissionAction.Edit);
    var canDelete = await permissionService.AuthorizeAsync(StandardPermissionProvider.ManageAssets, PermissionAction.Delete);

    <div class="am-card">
        <div class="am-card-header">
            <div class="am-card-title"><i class="fas fa-laptop"></i> @T("Admin.HRM.Employee.Assets")</div>
            @if (await permissionService.AuthorizeAsync(StandardPermissionProvider.ManageAssets, PermissionAction.Add))
            {
                <button type="button" id="assets-add-btn" class="btn btn-primary btn-sm">
                    <i class="fas fa-plus"></i> @T("Admin.Employee.Experience.AddButton")
                </button>
            }
        </div>
        <div class="am-dt-wrap">
            <table id="assets-table" class="am-dt">
                <thead><tr>
                    <th>@T("Admin.Assets.Fields.Type")</th>
                    <th>@T("Admin.Assets.Fields.Name")</th>
                    <th>@T("Admin.Assets.Fields.Description")</th>
                    <th>@T("Admin.Recruitements.Fields.Documents")</th>
                        @if (canEdit || canDelete)
                        {
                            <th>@T("Admin.Common.Actions")</th>
                        }
                </tr></thead>
                <tbody></tbody>
            </table>
        </div>
        <div id="assets-footer" class="am-dt-footer">
            <span class="am-dt-count">@T("Admin.Common.Loading")</span>
            <div class="am-dt-pager"></div>
        </div>
    </div>

    <script>
    (function () {
        var token     = $('input[name="__RequestVerificationToken"]').first().val();
        var canEdit   = @(canEdit ? "true" : "false");
        var canDel    = @(canDelete ? "true" : "false");
        var dlBase    = '@Url.Content("~/Admin/Download/DownloadFile")?downloadGuid=';
        var dlLabel   = '@T("Admin.Orders.OrderNotes.Fields.Download.Link").Text';
        var dlNone    = '@T("Admin.Orders.OrderNotes.Fields.Download.Link.No").Text';
        var popupBase = '@Url.Action("AssetsPopup", "Employee", new { employeeId = Model.Id })' + '&id=';
        var addUrl    = '@Url.Action("AssetsPopup", "Employee", new { employeeId = Model.Id })';
        var saveUrl   = '@Url.Action("AssetsPopupSave", "Employee")';

        var tbl = amEmpTable({
            tableId: 'assets-table', footerId: 'assets-footer',
            listUrl:   '@Url.Action("AssetsList",   "Employee")',
            deleteUrl: '@Url.Action("AssetsDelete", "Employee")',
            empId: @Model.Id, pageSize: 10, token: token,
            confirmMsg: 'Delete this asset?',
            onLoad: function (t) { amSyncCount('am-stat-assets', 'am-badge-assets', t); },
            renderRow: function (row) {
                var dl  = row.DocumentId > 0
                    ? '<a class="btn btn-sm btn-outline-secondary" href="' + dlBase + row.DownloadGuid + '"><i class="fas fa-download"></i> ' + dlLabel + '</a>'
                    : '<span class="am-dt-muted">' + dlNone + '</span>';
                var act = '';
                if (canEdit) act += '<button type="button" class="btn am-dt-edit" data-id="' + row.Id + '"><i class="fas fa-pencil-alt"></i></button>';
                if (canDel)  act += '<button type="button" class="btn am-dt-del"  data-id="' + row.Id + '"><i class="fas fa-trash-alt"></i></button>';
                return '<tr>' +
                    '<td class="am-dt-name">' + (row.Type        || '—') + '</td>' +
                    '<td>' + (row.Name        || '<span class="am-dt-muted">—</span>') + '</td>' +
                    '<td>' + (row.Description || '<span class="am-dt-muted">—</span>') + '</td>' +
                    '<td>' + dl + '</td>' +
                    (canEdit || canDel ? '<td><div class="am-dt-actions">' + act + '</div></td>' : '') +
                    '</tr>';
            }
        });

        $(document).off('click.assets-edit').on('click.assets-edit', '#assets-table .am-dt-edit', function () {
            var id = $(this).data('id');
            amOpenPopup({ url: popupBase + id, saveUrl: saveUrl, title: 'Edit Asset', onSaved: function () { tbl.reload(); } });
        });

        var addBtn = document.getElementById('assets-add-btn');
        if (addBtn) addBtn.onclick = function () {
            amOpenPopup({ url: addUrl, saveUrl: saveUrl, title: 'Add Asset', onSaved: function () { tbl.reload(); } });
        };
    }());
    </script>
}
else
{
    <div class="am-save-first"><i class="fas fa-info-circle"></i> @T("Admin.Employee.Assets.SaveBeforeEdit")</div>
}
