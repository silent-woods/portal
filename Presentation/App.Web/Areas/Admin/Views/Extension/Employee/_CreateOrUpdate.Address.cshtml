@model EmployeeModel
<input type="hidden" asp-for="Id" />

@if (Model.Id > 0)
{
    var canEdit   = await permissionService.AuthorizeAsync(StandardPermissionProvider.ManageEmployeeAddress, PermissionAction.Edit);
    var canDelete = await permissionService.AuthorizeAsync(StandardPermissionProvider.ManageEmployeeAddress, PermissionAction.Delete);

    <div class="am-card">
        <div class="am-card-header">
            <div class="am-card-title"><i class="fas fa-map-marker-alt"></i> @T("Admin.HRM.Employee.Address")</div>
            @if (await permissionService.AuthorizeAsync(StandardPermissionProvider.ManageEmployeeAddress, PermissionAction.Add))
            {
                <button type="button" id="addr-add-btn" class="btn btn-primary btn-sm">
                    <i class="fas fa-plus"></i> @T("Admin.Employee.Address.AddButton")
                </button>
            }
        </div>
        <div class="am-dt-wrap">
            <table id="addr-table" class="am-dt">
                <thead><tr>
                    <th>@T("Admin.Address.Fields.FirstName")</th>
                    <th>@T("Admin.Address.Fields.LastName")</th>
                    <th>@T("Admin.Address.Fields.Email")</th>
                    <th>@T("Admin.Address.Fields.PhoneNumber")</th>
                    <th>@T("Admin.Address.Fields.Address1")</th>
                    <th>@T("Admin.Address.Fields.FaxNumber")</th>
                        @if (canEdit || canDelete)
                        {
                            <th>@T("Admin.Common.Actions")</th>
                        }
                </tr></thead>
                <tbody></tbody>
            </table>
        </div>
        <div id="addr-footer" class="am-dt-footer">
            <span class="am-dt-count">@T("Admin.Common.Loading")</span>
            <div class="am-dt-pager"></div>
        </div>
    </div>

    <script>
    (function () {
        var token     = $('input[name="__RequestVerificationToken"]').first().val();
        var canEdit   = @(canEdit ? "true" : "false");
        var canDel    = @(canDelete ? "true" : "false");
        var popupBase = '@Url.Action("AddressPopup", "Employee", new { employeeId = Model.Id })' + '&id=';
        var addUrl    = '@Url.Action("AddressPopup", "Employee", new { employeeId = Model.Id })';
        var saveUrl   = '@Url.Action("AddressPopupSave", "Employee")';

        var tbl = amEmpTable({
            tableId: 'addr-table', footerId: 'addr-footer',
            listUrl:   '@Url.Action("AddressList",   "Employee")',
            deleteUrl: '@Url.Action("AddressDelete", "Employee")',
            empId: @Model.Id, pageSize: 10, token: token,
            confirmMsg: 'Delete this address?',
            onLoad: function (t) { amSyncCount('am-stat-address', 'am-badge-address', t); },
            renderRow: function (row) {
                var act = '';
                if (canEdit) act += '<button type="button" class="btn am-dt-edit" data-id="' + row.Id + '"><i class="fas fa-pencil-alt"></i></button>';
                if (canDel)  act += '<button type="button" class="btn am-dt-del"  data-id="' + row.Id + '"><i class="fas fa-trash-alt"></i></button>';
                return '<tr>' +
                    '<td class="am-dt-name">' + (row.FirstName || '—') + '</td>' +
                    '<td>' + (row.LastName    || '<span class="am-dt-muted">—</span>') + '</td>' +
                    '<td>' + (row.Email       || '<span class="am-dt-muted">—</span>') + '</td>' +
                    '<td>' + (row.PhoneNumber || '<span class="am-dt-muted">—</span>') + '</td>' +
                    '<td>' + (row.Address1    || '<span class="am-dt-muted">—</span>') + '</td>' +
                    '<td>' + (row.FaxNumber   || '<span class="am-dt-muted">—</span>') + '</td>' +
                    (canEdit || canDel ? '<td><div class="am-dt-actions">' + act + '</div></td>' : '') +
                    '</tr>';
            }
        });

        $(document).off('click.addr-edit').on('click.addr-edit', '#addr-table .am-dt-edit', function () {
            var id = $(this).data('id');
            amOpenPopup({ url: popupBase + id, saveUrl: saveUrl, title: 'Edit Address', onSaved: function () { tbl.reload(); } });
        });

        var addBtn = document.getElementById('addr-add-btn');
        if (addBtn) addBtn.onclick = function () {
            amOpenPopup({ url: addUrl, saveUrl: saveUrl, title: 'Add Address', onSaved: function () { tbl.reload(); } });
        };
    }());
    </script>
}
else
{
    <div class="am-save-first"><i class="fas fa-info-circle"></i> @T("Admin.Employee.Address.SaveBeforeEdit")</div>
}
