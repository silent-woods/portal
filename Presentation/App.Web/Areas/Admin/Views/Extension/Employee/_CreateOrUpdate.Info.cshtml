@model EmployeeModel

<div class="am-card">
    <div class="am-card-header">
        <div class="am-card-title"><i class="fas fa-user"></i> @T("Admin.HRM.Employee.Info")</div>
    </div>
    <div class="am-card-body">

        <div class="am-form-section">@T("Admin.HRM.Employee.Section.Identity")</div>
        <div class="am-form-grid">

            <div class="am-field">
                <nop-label asp-for="FirstName" />
                <nop-editor asp-for="FirstName" asp-required="true" />
                <span asp-validation-for="FirstName"></span>
            </div>

            <div class="am-field">
                <nop-label asp-for="LastName" />
                <nop-editor asp-for="LastName" asp-required="true" />
                <span asp-validation-for="LastName"></span>
            </div>

            <div class="am-field">
                <nop-label asp-for="PersonalEmail" />
                <nop-editor asp-for="PersonalEmail" asp-required="true" />
                <span asp-validation-for="PersonalEmail"></span>
            </div>

            <div class="am-field">
                <nop-label asp-for="MobileNo" />
                <nop-editor asp-for="MobileNo" asp-required="true" />
                <span asp-validation-for="MobileNo"></span>
            </div>

            <div class="am-field">
                <nop-label asp-for="Gender" />
                <div class="am-radio-group">
                    <label class="am-radio-opt">
                        <input type="radio" name="Gender" id="Gender_Male" value="M" @(Model.Gender == "M" ? Html.Raw("checked") : null) />
                        @T("Admin.Customers.Customers.Fields.Gender.Male")
                    </label>
                    <label class="am-radio-opt">
                        <input type="radio" name="Gender" id="Gender_Female" value="F" @(Model.Gender == "F" ? Html.Raw("checked") : null) />
                        @T("Admin.Customers.Customers.Fields.Gender.Female")
                    </label>
                </div>
                <span asp-validation-for="Gender"></span>
            </div>

            <div class="am-field">
                <nop-label asp-for="SelectedManagerId" />
                <nop-select asp-for="SelectedManagerId" asp-items="Model.AvailableManager" asp-multiple="true" />
                <div class="am-field-hint">@T("Admin.Common.Fields.SelectedManagerId.Hint")</div>
                <script>
                    $(document).ready(function () {
                        var selectElement = $('#@Html.IdFor(model => model.SelectedManagerId)').data("kendoMultiSelect");
                        selectElement.setOptions({
                            autoClose: true,
                            filter: "contains",
                            change: function (e) {
                                if (this.value().length > 1) {
                                    var lastItem = this.value()[this.value().length - 1];
                                    this.value([lastItem]);
                                }
                            }
                        });
                        @if (Model.AvailableManager.Count == 0)
                        {
                            <text>
                            selectElement.setOptions({ enable: false, placeholder: '@T("Admin.Catalog.Employee.NoEmployee")' });
                            selectElement._placeholder();
                            selectElement._enable();
                            </text>
                        }
                    });
                </script>
            </div>

        </div>

        <div class="am-form-section">@T("Admin.Customers.Customers.Fields.Password")</div>
        <div class="am-form-grid">
            <div class="am-field am-span-2">
                <nop-label asp-for="Password" />
                <div class="am-pw-row">
                    <nop-editor asp-for="Password" html-attributes="@(new { autocomplete = "new-password" })" />
                    @if (Model.Id > 0)
                    {
                        <button type="submit" name="changepassword" class="btn btn-info btn-sm">
                            @T("Admin.Customers.Customers.Fields.Password.Change")
                        </button>
                    }
                    <button type="button" id="generatePasswordButton" class="btn btn-secondary btn-sm">
                        <i class="fas fa-random"></i> Generate
                    </button>
                </div>
                <span asp-validation-for="Password"></span>
                <script>
                    $(document).ready(function () {
                        function generateRandomPassword(length) {
                            var charset = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789";
                            var password = "";
                            for (var i = 0; i < length; i++) {
                                password += charset[Math.floor(Math.random() * charset.length)];
                            }
                            return password;
                        }
                        $('#generatePasswordButton').on('click', function () {
                            $('input[name="Password"]').val(generateRandomPassword(8));
                        });
                    });
                </script>
            </div>
        </div>

        <div class="am-form-section">@T("Admin.Employees.Fields.PictureId")</div>
        <div class="am-form-grid">
            <div class="am-field am-span-2">
                <div id="ExistingPicture" style="display:none; margin-bottom:10px;">
                    <nop-label asp-for="PictureUrl" />
                    <img id="BgPictureUrl" src="@(Model.PictureUrl)" alt="avatar" style="max-width:120px;border-radius:10px;margin-top:6px;" />
                </div>
                <div id="PictureUploader">
                    <nop-label asp-for="PictureId" />
                    <nop-editor asp-for="PictureId" />
                    <span asp-validation-for="PictureId"></span>
                </div>
            </div>
        </div>

    </div>
</div>
