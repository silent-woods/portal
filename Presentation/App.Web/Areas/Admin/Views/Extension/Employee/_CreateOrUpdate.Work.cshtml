@model EmployeeModel

<div class="am-card">
    <div class="am-card-header">
        <div class="am-card-title"><i class="fas fa-briefcase"></i> @T("Admin.HRM.Employee.Work")</div>
    </div>
    <div class="am-card-body">

        <div class="am-form-section">@T("Admin.HRM.Employee.Section.EmploymentDetails")</div>
        <div class="am-form-grid">

            <div class="am-field">
                <nop-label asp-for="OfficialEmail" />
                <nop-editor asp-for="OfficialEmail" asp-required="true" />
                <span asp-validation-for="OfficialEmail"></span>
            </div>

            <div class="am-field">
                <nop-label asp-for="Location" />
                <nop-editor asp-for="Location" />
            </div>

            <div class="am-field">
                <nop-label asp-for="DepartmentName" />
                <nop-select asp-for="DepartmentId" asp-items="Model.Departments" asp-required="true" />
                <span asp-validation-for="DepartmentId"></span>
            </div>

            <div class="am-field">
                <nop-label asp-for="DesignationName" />
                <nop-select asp-for="DesignationId" asp-items="Model.Designation" asp-required="true" />
                <span asp-validation-for="DesignationId"></span>
            </div>

            <div class="am-field">
                <nop-label asp-for="DateofJoining" />
                <nop-editor asp-for="DateofJoining" asp-required="true" />
                <span asp-validation-for="DateofJoining"></span>
            </div>

            <div class="am-field">
                <nop-label asp-for="DateOfBirth" />
                <nop-editor asp-for="DateOfBirth" asp-required="true" />
                <span asp-validation-for="DateOfBirth"></span>
            </div>

            <div class="am-checkbox-field am-span-2">
                <nop-editor asp-for="IsVendor" />
                <nop-label asp-for="IsVendor" />
            </div>

        </div>

    </div>
</div>
