@model EmployeeModel

@if (Model.Id > 0)
{
    var canEdit   = await permissionService.AuthorizeAsync(StandardPermissionProvider.ManageEducation, PermissionAction.Edit);
    var canDelete = await permissionService.AuthorizeAsync(StandardPermissionProvider.ManageEducation, PermissionAction.Delete);

    <div class="am-card">
        <div class="am-card-header">
            <div class="am-card-title"><i class="fas fa-graduation-cap"></i> @T("Admin.HRM.Employee.Education")</div>
            @if (await permissionService.AuthorizeAsync(StandardPermissionProvider.ManageEducation, PermissionAction.Add))
            {
                <button type="button" id="edu-add-btn" class="btn btn-primary btn-sm">
                    <i class="fas fa-plus"></i> @T("Admin.Employee.Education.AddButton")
                </button>
            }
        </div>
        <div class="am-dt-wrap">
            <table id="edu-table" class="am-dt">
                <thead><tr>
                    <th>@T("Admin.Educations.Fields.Course")</th>
                    <th>@T("Admin.Educations.Fields.InstitutionName")</th>
                    <th>@T("Admin.Educations.Fields.MarksScored")</th>
                    <th>@T("Admin.Educations.Fields.YearOfCompletion")</th>
                        @if (canEdit || canDelete)
                        {
                            <th>@T("Admin.Common.Actions")</th>
                        }
                </tr></thead>
                <tbody></tbody>
            </table>
        </div>
        <div id="edu-footer" class="am-dt-footer">
            <span class="am-dt-count">@T("Admin.Common.Loading")</span>
            <div class="am-dt-pager"></div>
        </div>
    </div>

    <script>
    (function () {
        var token       = $('input[name="__RequestVerificationToken"]').first().val();
        var canEdit     = @(canEdit ? "true" : "false");
        var canDel      = @(canDelete ? "true" : "false");
        var popupBase   = '@Url.Action("EducationPopup", "Employee", new { employeeId = Model.Id })'  + '&id=';
        var addUrl      = '@Url.Action("EducationPopup", "Employee", new { employeeId = Model.Id })';
        var saveUrl     = '@Url.Action("EducationPopupSave", "Employee")';

        var tbl = amEmpTable({
            tableId: 'edu-table', footerId: 'edu-footer',
            listUrl:   '@Url.Action("EducationList",   "Employee")',
            deleteUrl: '@Url.Action("EducationDelete", "Employee")',
            empId: @Model.Id, pageSize: 10, token: token,
            confirmMsg: 'Delete this education record?',
            onLoad: function (t) { amSyncCount('am-stat-education', 'am-badge-education', t); },
            renderRow: function (row) {
                var act = '';
                if (canEdit) act += '<button type="button" class="btn am-dt-edit" data-id="' + row.Id + '"><i class="fas fa-pencil-alt"></i></button>';
                if (canDel)  act += '<button type="button" class="btn am-dt-del"  data-id="' + row.Id + '"><i class="fas fa-trash-alt"></i></button>';
                return '<tr>' +
                    '<td class="am-dt-name">' + (row.Course           || '—') + '</td>' +
                    '<td>' + (row.InstitutionName || '<span class="am-dt-muted">—</span>') + '</td>' +
                    '<td>' + (row.MarksScored     || '<span class="am-dt-muted">—</span>') + '</td>' +
                    '<td>' + (row.YearOfCompletion|| '<span class="am-dt-muted">—</span>') + '</td>' +
                    (canEdit || canDel ? '<td><div class="am-dt-actions">' + act + '</div></td>' : '') +
                    '</tr>';
            }
        });

        $(document).off('click.edu-edit').on('click.edu-edit', '#edu-table .am-dt-edit', function () {
            var id = $(this).data('id');
            amOpenPopup({ url: popupBase + id, saveUrl: saveUrl, title: 'Edit Education', onSaved: function () { tbl.reload(); } });
        });

        var addBtn = document.getElementById('edu-add-btn');
        if (addBtn) addBtn.onclick = function () {
            amOpenPopup({ url: addUrl, saveUrl: saveUrl, title: 'Add Education', onSaved: function () { tbl.reload(); } });
        };
    }());
    </script>
}
else
{
    <div class="am-save-first"><i class="fas fa-info-circle"></i> @T("Admin.Catalog.Employee.Education.SaveBeforeEdit")</div>
}
