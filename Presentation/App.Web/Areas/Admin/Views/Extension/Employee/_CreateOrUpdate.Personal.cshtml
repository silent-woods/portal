@model EmployeeModel

<div class="am-card">
    <div class="am-card-header">
        <div class="am-card-title"><i class="fas fa-heart"></i> @T("Admin.HRM.Employee.Personal")</div>
    </div>
    <div class="am-card-body">

        <div class="am-form-section">@T("Admin.HRM.Employee.Section.PersonalInfo")</div>
        <div class="am-form-grid">

            <div class="am-field">
                <nop-label asp-for="EmployeeStatus" />
                <nop-select asp-for="EmployeeStatusId" asp-items="Model.EmployeesStatus" asp-required="true" />
                <span asp-validation-for="EmployeeStatusId"></span>
            </div>

            <div class="am-field">
                <nop-label asp-for="MaritalStatus" />
                <nop-select asp-for="MaritalStatusId" asp-items="Model.MaritalsStatus" />
                <span asp-validation-for="MaritalStatusId"></span>
            </div>

            <div class="am-field">
                <nop-label asp-for="BloodGroup" />
                <nop-select asp-for="BloodGroupId" asp-items="Model.BloodGroups" />
                <span asp-validation-for="BloodGroupId"></span>
            </div>

            <div class="am-field">
                <nop-label asp-for="FatherName" />
                <nop-editor asp-for="FatherName" />
                <span asp-validation-for="FatherName"></span>
            </div>

            <div class="am-field">
                <nop-label asp-for="MotherName" />
                <nop-editor asp-for="MotherName" />
                <span asp-validation-for="MotherName"></span>
            </div>

            <div class="am-field am-span-2">
                <nop-label asp-for="Hobbies" />
                <nop-editor asp-for="Hobbies" asp-template="RichEditor" />
            </div>

        </div>

        <div class="am-form-section">@T("Admin.HRM.Employee.Section.EmergencyContact")</div>
        <div class="am-form-grid am-cols-3">

            <div class="am-field">
                <nop-label asp-for="EmergencyContactPerson" />
                <nop-editor asp-for="EmergencyContactPerson" />
            </div>

            <div class="am-field">
                <nop-label asp-for="Relationship" />
                <nop-editor asp-for="Relationship" />
            </div>

            <div class="am-field">
                <nop-label asp-for="ContactNumber" />
                <nop-editor asp-for="ContactNumber" />
            </div>

        </div>

    </div>
</div>
