@using App.Web.Areas.Admin.Models.Extension.SkillSet
@model SkillSetModel
<div class="card-body">
    <div class="form-group row">
        <div class="col-md-3">
            <nop-label asp-for="SkillTags" />
        </div>
        <div class="col-md-4">
            <!-- THIS hidden field is critical -->
            <input type="hidden" name="SkillTags" id="SkillTags" value="@Model.SkillTags" />
            <!-- Kendo MultiSelect -->
            <select id="skillTagsMultiSelect"></select>
            <span asp-validation-for="SkillTags" class="text-danger"></span>
        </div>
    </div>
    <script>
                $(document).ready(function () {
            var initialSkills = [];
            var skillTagsValue = $("#SkillTags").val();
            if (skillTagsValue && skillTagsValue.length > 0) {
                initialSkills = skillTagsValue.split(",").map(function(skill) {
                    return {
                        Text: skill,
                        Value: skill
                    };
                });
            }
            var multiSelect = $("#skillTagsMultiSelect").kendoMultiSelect({
                dataTextField: "Text",
                dataValueField: "Value",
                dataSource: initialSkills,
                value: initialSkills.map(x => x.Value),
                placeholder: "Type skill and press Enter",
                filter: "contains",
                autoClose: false,
                tagMode: "multiple",
                change: function () {
                    updateHiddenField();
                }
            }).data("kendoMultiSelect");
            multiSelect.input.on("keydown", function (e) {
                if (e.keyCode === 13) {
                    var value = multiSelect.input.val().trim();
                    if (value === "")
                        return;
                    var exists = multiSelect.dataSource.data().some(function(item) {
                        return item.Value === value;
                    });
                    if (!exists) {
                        multiSelect.dataSource.add({
                            Text: value,
                            Value: value
                        });
                    }
                    var currentValues = multiSelect.value();
                    currentValues.push(value);
                    multiSelect.value(currentValues);
                    updateHiddenField();
                    multiSelect.input.val("");
                    e.preventDefault();
                }
            });
            function updateHiddenField() {
                var values = multiSelect.value();
                $("#SkillTags").val(values.join(","));
            }
            // CRITICAL FIX — sync before submit
            $("form").on("submit", function () {
                updateHiddenField();
            });
        });

    </script>

    <div class="form-group row">
        <div class="col-md-3">
            <nop-label asp-for="SelectedTechnologyIds" />
        </div>
        <div class="col-md-4">
            <select id="technologyMultiSelect" multiple="multiple" class="form-control"></select>
            <input type="hidden" name="SelectedTechnologyIds" id="SelectedTechnologyIds" />
            <span asp-validation-for="SelectedTechnologyIds" class="text-danger"></span>
        </div>
    </div>
    <script>
        $(document).ready(function () {

            var techData = @Html.Raw(Json.Serialize(Model.AvailableTechnologies));
            var techPreselected = @Html.Raw(Json.Serialize(Model.SelectedTechnologyIds));

            var techMultiSelect = $("#technologyMultiSelect").kendoMultiSelect({
                dataTextField: "Text",
                dataValueField: "Value",
                dataSource: techData,
                value: techPreselected,
                autoClose: false,
                filter: "contains",
                change: function () {
                    $("#SelectedTechnologyIds")
                        .val(this.value().join(","))
                        .trigger("change");
                }
            }).data("kendoMultiSelect");

            $("#SelectedTechnologyIds")
                .val(techMultiSelect.value().join(","))
                .trigger("change");
        });
    </script>

    <div class="form-group row">
        <div class="col-md-3">
            <nop-label asp-for="DisplayOrder" />
        </div>
        <div class="col-md-4">
            <nop-editor asp-for="DisplayOrder" />
            <span asp-validation-for="DisplayOrder"></span>
        </div>
    </div>
    <div class="form-group row">
        <div class="col-md-3">
            <nop-label asp-for="Published" />
        </div>
        <div class="col-md-4">
            <nop-editor asp-for="Published" />
            <span asp-validation-for="Published"></span>
        </div>
    </div>
</div>