@using App.Web.Areas.Admin.Models.Extension.SkillSet
@model SkillSetModel
@{
    //page title
    ViewBag.PageTitle = T("Admin.SkillSet.EditSkillSetDetails").Text;
    //active menu item (system name)
    NopHtml.SetActiveMenuItemSystemName("SkillSet");
}
<form asp-controller="SkillSet" asp-action="Edit" method="post">
    <div class="content-header clearfix">
        <h1 class="float-left">
            @T("Admin.SkillSet.EditSkillSetDetails")
            <small>
                <i class="fas fa-arrow-circle-left"></i>
                <a asp-action="List">@T("Admin.SkillSet.BackToList")</a>
            </small>
        </h1>
        <div class="float-right">
            <button type="submit" name="save" class="btn btn-primary">
                <i class="far fa-save"></i>
                @T("Admin.Common.Save")
            </button>
            <button type="submit" name="save-continue" class="btn btn-primary">
                <i class="far fa-save"></i>
                @T("Admin.Common.SaveContinue")
            </button>
        </div>
    </div>
    @await Html.PartialAsync("/Areas/Admin/Views/Extension/SkillSet/_CreateOrUpdate.cshtml", Model)
</form>