@using App.Web.Areas.Admin.Models.Extension.Candidates
@model CandidateModel
@{
    const string hideInfoBlockAttributeName = "CandidateDetails.HideInfoBlock";
    var customer = await workContext.GetCurrentCustomerAsync();
    var hideInfoBlock = await genericAttributeService.GetAttributeAsync<bool>(customer, hideInfoBlockAttributeName);
}
<input asp-for="Id" type="hidden" />
<section class="content">
    <div class="container-fluid">
        <div class="form-horizontal">
            <nop-cards id="Candidate-item-cards">
                <nop-card asp-name="Candidate-item-info" 
                          asp-icon="fas fa-info"
                          asp-title="@T("Admin.Candidate.Info")"
                          asp-hide-block-attribute-name="@hideInfoBlockAttributeName"
                          asp-hide="@hideInfoBlock">
                    @await Html.PartialAsync("/Areas/Admin/Views/Extension/Candidate/_CreateOrUpdate.Info.cshtml", Model)
                </nop-card>
            </nop-cards>
        </div>
    </div>
</section>
