<script>
        function copyTaskName(text, element) {

        const wrapper = element.closest(".copy-wrapper");

        if (navigator.clipboard && window.isSecureContext) {
            navigator.clipboard.writeText(text).then(() => {
                toggleCopied(wrapper);
            }).catch(() => {
                fallbackCopy(text, wrapper);
            });
        } else {
            fallbackCopy(text, wrapper);
        }
    }

    function fallbackCopy(text, wrapper) {
        var input = document.createElement("input");
        input.value = text;
        document.body.appendChild(input);

        input.select();
        document.execCommand("copy");

        document.body.removeChild(input);

        toggleCopied(wrapper);
    }

    function toggleCopied(wrapper) {
        wrapper.classList.add("active");

        setTimeout(() => {
            wrapper.classList.remove("active");
        }, 1500);
    }
</script>
<script>
    $(document).ready(function () {
        $("table").on("change", ".select-all-checkbox", function () {
            var table = $(this).closest("table");
            var checked = $(this).is(":checked");
            table.find(".row-checkbox:not(:disabled)").prop("checked", checked);
            updateMassFollowUpButton();
        });
        $("table").on("change", ".row-checkbox", function () {
            updateMassFollowUpButton();
            var table = $(this).closest("table");
            var total = table.find(".row-checkbox:not(:disabled)").length;
            var checkedCount = table.find(".row-checkbox:not(:disabled):checked").length;
            table.find(".select-all-checkbox").prop("checked", total > 0 && total === checkedCount);
        });
        function updateMassFollowUpButton() {
            var count = $(".row-checkbox:checked:not(:disabled)").length;
            if (count > 0) {
                $("#btnMassFollowUp").show();
                $("#massSelectedCount").text(count + " task(s) selected");
            } else {
                $("#btnMassFollowUp").hide();
                $("#massSelectedCount").text("");
            }
        }
        function getCurrentFilters() {
    return {
        taskName: $("#taskSearch").val(),
        projectIds: $('#projectFilter').val() || [],
        employeeIds: $('#employeeId').val() || [],
        showOnlyNotTrack: false,
        sourceType: "",
        percentageFilter: $("#percentageFilter").val(),
        from: $("#From").val(),
        to: $("#To").val(),
        processWorkflow: 0,
        statusId: $("#selectedStatusId").val() || 0
    };
    }
         $("table").on("click", ".btn-followup", function () {
        var row = $(this).closest("tr");
        var nextCell = row.find(".next-followup");
        var actionCell = row.find(".action-cell");
        row.data("originalNext", nextCell.text().trim());
        row.data("originalNextCss", { overflow: nextCell.css("overflow"), whiteSpace: nextCell.css("white-space"), width: nextCell.css("width") });
        nextCell.html("<div>Loading...</div>");
        $.ajax({
            url: "/Dashboard/GetFollowUpDurations",
            type: "GET",
            success: function (options) {

                let dropdownHtml = `<select class="next-review-dropdown">
                                        <option value="">Select Duration</option>`;

                options.forEach(function (opt) {
                    dropdownHtml += `<option value="${opt.value}">
                                        ${opt.text}
                                     </option>`;
                });
                dropdownHtml += `</select>`;

                nextCell.css({ overflow: "visible", whiteSpace: "normal", width: "360px" });
    nextCell.html(`
        <div class="followup-editor">
            <div class="duration-wrapper">
                ${dropdownHtml}
            </div>
            <input type="text" class="comment-input" placeholder="Enter follow-up comment" />
            <label class="complete-wrapper">
                <input type="checkbox" class="mark-complete" />
                <span>Mark Completed</span>
            </label>
        </div>
    `);

                actionCell.html(`
                    <button class="save-btn btn-save">Save</button>
                    <button class="cancel-btn btn-cancel">Cancel</button>
                `);
            },
            error: function () {
                nextCell.html("Failed to load durations");
            }
        });
    });
     $("table").on("click", ".btn-cancel", function () {
        var row = $(this).closest("tr");
        var nextCell = row.find(".next-followup");
        var actionCell = row.find(".action-cell");
        var originalNext = row.data("originalNext");
        var originalCss = row.data("originalNextCss") || {};
        nextCell.css({ overflow: originalCss.overflow || "", whiteSpace: originalCss.whiteSpace || "", width: originalCss.width || "" });
        nextCell.text(originalNext && originalNext !== "" ? originalNext : "-");
        actionCell.html(
            `<button class="follow-btn btn-followup">Follow-Up</button>`
        );
    });

            $("table").on("change", ".mark-complete", function () {
        var container = $(this).closest("td");
        var nextInput = container.find(".next-input");
        if ($(this).is(":checked")) {
            nextInput.val("");
            nextInput.prop("disabled", true);
        } else {
            nextInput.prop("disabled", false);
        }
    });
            $("table").on("click", ".btn-save", function () {

        var btn = $(this);

        if (btn.prop("disabled")) {
            return;
        }
        btn.prop("disabled", true).text("Saving...");

        var row = btn.closest("tr");
        var taskId = row.data("id");
        var nextCell = row.find(".next-followup");
        var actionCell = row.find(".action-cell");
        var selectedMinutes = parseInt(nextCell.find(".next-review-dropdown").val());
        var isCompleted = nextCell.find(".mark-complete").is(":checked");
        var comment = nextCell.find(".comment-input").val();

           if (!isCompleted) {
        if (!selectedMinutes) {
            alert("Please select review duration.");
            btn.prop("disabled", false).text("Save");
            return;
        }
    }
        var data = {
            id: taskId,
            durationMinutes: selectedMinutes,
            comment: comment,
            isCompleted: isCompleted
        };
        addAntiForgeryToken(data);
        $.ajax({
            url: "/Dashboard/SaveFollowUp",
            type: "POST",
            data: data,
            success: function (res) {
                if (res && res.success) {
                    captureOpenedAccordions();
                        var filters = getCurrentFilters();

    var postData = {
        taskName: filters.taskName,
        projectIds: filters.projectIds.join(","),
        employeeIds: filters.employeeIds.join(","),
        showOnlyNotTrack: filters.showOnlyNotTrack,
        sourceType: filters.sourceType,
        from: filters.from,
        to: filters.to,
        percentageFilter: filters.percentageFilter,
        processWorkflow: filters.processWorkflow,
        statusId: filters.statusId
    };

    addAntiForgeryToken(postData);

    $.ajax({
        url: "/Dashboard/SearchFollowup",
        type: "POST",
        data: postData,
        success: function (html) {
            $("#followupTablesContainer").html(html);
            restoreOpenedAccordions();
            if (parseInt($("#selectedStatusId").val()) === 0) {
                if (typeof updateStatusCountsFromTasks === "function") updateStatusCountsFromTasks();
            }
        },
        error: function () {
            alert("Error reloading filtered data.");
        }
    });

                } else {
                    alert("Error saving follow-up.");
                    btn.prop("disabled", false).text("Save");
                }
            },
            error: function () {
                alert("Network error occurred.");
                btn.prop("disabled", false).text("Save");
            }
        });
    });
        $("table").on("click", ".toggle-subgrid", function () {
        var btn = $(this);
        var parentRow = btn.closest("tr");
        var subgridRow = parentRow.next(".subgrid-row");
        var container = subgridRow.find(".subgrid-container");
        var taskId = btn.data("id");
        if (subgridRow.is(":visible")) {
            subgridRow.hide();
            btn.text("+");
            return;
        }
        btn.text("-");
        subgridRow.show();
        if (container.html().trim() !== "") {
            return;
        }
        $.ajax({
            url: "/Dashboard/GetFollowUpSubGrid",
            type: "GET",
            data: { followUpTaskId: taskId },
            success: function (html) {
                container.html(html);
            },
            error: function () {
                container.html("<div class='error'>Failed to load follow-ups</div>");
            }
        });
    });
    });
        $("table").on("click", "th.sortable", function () {
        var th = $(this);
        var table = th.closest("table");
        var tbody = table.find("tbody");
        var index = th.index();
        var type = th.data("type");
        var asc = !th.hasClass("asc");

        table.find("th").removeClass("asc desc");
        th.addClass(asc ? "asc" : "desc");
        var rows = tbody.find("tr").not(".subgrid-row").get();
        rows.sort(function (a, b) {
            var A = $(a).children("td").eq(index).text().trim();
            var B = $(b).children("td").eq(index).text().trim();

    if (type === "number") {
        A = parseFloat(A.replace(/[^\d.-]/g, "")) || 0;
        B = parseFloat(B.replace(/[^\d.-]/g, "")) || 0;
    }
    else if (type === "percentage") {
        A = parseFloat(A.replace("%", "")) || 0;
        B = parseFloat(B.replace("%", "")) || 0;
    }
    else if (type === "date") {
        A = A ? new Date(A) : new Date(0);
        B = B ? new Date(B) : new Date(0);
    }
    else {
        A = A.toLowerCase();
        B = B.toLowerCase();
    }

            if (A < B) return asc ? -1 : 1;
            if (A > B) return asc ? 1 : -1;
            return 0;
        });

        $.each(rows, function (i, row) {
            var subgrid = $(row).next(".subgrid-row");
            tbody.append(row);
            if (subgrid.length) {
                tbody.append(subgrid);
            }
        });
    });
</script>
