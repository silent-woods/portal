                            <td>@Html.Raw(t.TrackReason)</td>
                            <td class="next-followup">
                                @t.NextFollowupDateTime?.ToString("dd-MMM-yyyy hh:mm tt")
                            </td>
                            <td class="comment">@t.LastComment</td>
                            <td>
                                @t.LastFollowupDateTime?.ToString("dd-MMM-yyyy hh:mm tt")
                            </td>
                            <td>
